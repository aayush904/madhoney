{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  {{ 'component-localization-form.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  footer .newsletter-form__field-wrapper{
    max-width:100%;
  }

  .newsletter-form__button.field__button{
    right:5px;
  }

  footer .newsletter-form__field-wrapper input{
    height:auto!important;
    padding-top:1.65rem;
    padding-bottom:1.65rem;
    padding-left:16px;
    margin:0;
  }

  footer .newsletter-form{
    max-width: 100%!important;
  }

  .newsletter-form__message--success{
    display: flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 0.25rem;
      border-width: 1px;
      border-color: rgb(74,222,128);
      background-color: rgb(220,252,231);
      padding: 0.75rem;
      font-size: 0.875rem;
      margin-top: 0.8rem;
      width: 100%;
      line-height: 1.25rem;
      color: rgb(21,128,61);
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.52 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {

    && input{
      border-width: 2px!important;
      border-radius: 0!important;
    }
    && input::placeholder, && label {
      color: #E5CD87!important;
    }

    && .field__input:focus-visible, .select__select:focus-visible, .customer .field input:focus-visible, .customer select:focus-visible, .localization-form__select:focus-visible.localization-form__select:after{
      box-shadow: 0 0 0 calc(.1rem + 0px) #E5CD87;
    outline: 0;
    }
  }

  .section-{{ section.id }}-padding .mobile-collapse  li{
    margin-right:0!important;
  }

  [name="heading-collapse"]{
    display:none;
  }

  footer .newsletter-form .field__label{
    top:2rem;
  }

  @media screen and (min-width: 769px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }


    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer font-sans text-white bg-tertiary  sm:color-black gradient section-{{ section.id }}-padding">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width  gap-[0rem_10.61%] justify-between px-3 md:px-[16px] md:flex-wrap md:justify-center md:items-start sm:px-[16px!important] flex max-w-[86.26%] md:max-w-[116.6rem] sm:flex-col sm:max-w-[116.6rem] m-auto">
        {%- if section.blocks.size > 0 -%}
          {%- liquid
            if section.blocks.size == 9
              assign footer_grid_class = 'grid--3-col-tablet'
            elsif section.blocks.size > 6
              assign footer_grid_class = 'grid--4-col-desktop'
            elsif section.blocks.size > 4
              assign footer_grid_class = 'grid--3-col-tablet'
            endif
          -%}

          {% capture newsletter_social %}  
            <div class="flex flex-col md:items-center md:mb-[5rem] sm:mt-[5rem] ">
              {%- if section.settings.newsletter_enable -%}
                <div class=" flex flex-col gap-[1.6rem]">
                  <div class="flex flex-col gap-[16px]">
                    {%- if section.settings.newsletter_heading != blank -%}
                      <h3 class="text-secondary text-start sm:uppercase  sm:text-black  md:text-center sm:border-[none!important]" style="border:none">
                        {{ section.settings.newsletter_heading }}
                      </h3>
                    {%- endif -%}
                    {%- if section.settings.newsletter_description_1 != blank -%}
                      <p class="footer-block__description md:text-center">
                        {{ section.settings.newsletter_description_1 }}
                      </p>
                    {%- endif -%}
                  </div>
                  <div id="newsSignup" class="flex flex-col gap-[0.8rem] md:items-center md:justify-center">
                    {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="newsletter-form__field-wrapper">
                        <div class="field">
                          <input
                            id="NewsletterForm--{{ section.id }}"
                            type="email"
                            name="contact[email]"
                            class="field__input border-[#E5CD87!important] border-[2px] bg-transparent"
                            value="{{ form.email }}"
                            aria-required="true"
                            autocorrect="off"
                            autocapitalize="off"
                            style="border:2px solid #E5CD87; width:100%; max-width:100%;"
                            autocomplete="email"
                            {% if form.errors %}
                              autofocus
                              aria-invalid="true"
                              aria-describedby="ContactFooter-error"
                            {% elsif form.posted_successfully? %}
                              aria-describedby="ContactFooter-success"
                            {% endif %}
                            placeholder="{{ 'newsletter.label' | t }}"
                            required
                          >
                          <label class="field__label" for="NewsletterForm--{{ section.id }}">
                            {{ 'newsletter.label' | t }}
                          </label>
                          <button
                            type="submit"
                            class="newsletter-form__button field__button text-black"
                            name="commit"
                            id="Subscribe"
                            aria-label="{{ 'newsletter.button_label' | t }}"
                          >
                            <svg width="17" height="11" viewBox="0 0 17 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M1 5.85156H16M16 5.85156L11.5 1.35156M16 5.85156L11.5 10.3516" stroke="#3B2D1F" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                              
                          </button>
                        </div>
                        {%- if form.errors -%}
                          <small class="newsletter-form__message form__message  flex items-center gap-2 p-3 text-sm text-red-700 bg-red-100 border border-red-400 rounded-lg w-full min-w-full" id="ContactFooter-error">
                            {%- render 'icon-error' -%}
                            {{- form.errors.translated_fields.email | capitalize }}
                            {{ form.errors.messages.email -}}
                          </small>
                        {%- endif -%}
                      </div>
                      {%- if form.posted_successfully? -%}
                        <h3
                          class="newsletter-form__message newsletter-form__message--success form__message"
                          id="ContactFooter-success"
                          tabindex="-1"
                          autofocus
                        >
                          {% render 'icon-success' -%}
                          {{- 'newsletter.success' | t }}
                        </h3>
                      {%- endif -%}
                    {%- endform -%}
                    {%- if section.settings.newsletter_description_2 != blank -%}
                      <p class="footer-block__description text-start  md:text-center">
                        {{ section.settings.newsletter_description_2 }}
                      </p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

              {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                <div class="footer__follow-on-shop hidden sm:block">
                  {% comment %} TODO: enable theme-check once `login_button` is accepted as valid filter {% endcomment %}
                  {% # theme-check-disable %}
                  {{ shop | login_button: action: 'follow' }}
                  {% # theme-check-enable %}
                </div>
              {%- endif -%}

              {%- if section.settings.show_social and has_social_icons -%}
                <div class="flex-col gap-[16px] hidden ">
                  <h4 class="text-secondary  sm:text-black ">Follow Us On</h4>
                  {%- render 'social-icons' -%}
                </div>
              {%- endif -%}
            </div>
          {% endcapture %}

          <div class="flex {{ footer_grid_class }} justify-start text-start w-[27.76%] md:m-auto md:w-[65%] sm:w-full ">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'brand_information' -%}
                  <div
                    class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank and block.settings.menu == blank -%}
                      <h4 class="text-secondary  sm:text-black md:text-center ">
                        {{- block.settings.heading -}}
                      </h4>
                    {%- endif -%}

                    <div class="footer-block__brand-info flex flex-col md:justify-center md:items-center sm:items-center sm:text-center md:text-center gap-[4.8rem]">
                      <div class="w-full flex flex-col justify-start items-start md:items-center sm:items-center sm:text-center">
                        {%- if settings.brand_image != blank -%}
                          {%- assign brand_image_height = settings.brand_image_width
                            | divided_by: settings.brand_image.aspect_ratio
                          -%}
                          <div
                            class=" footer-block__image-wrapper global-media-settings bg-[transparent] md:text-center"
                            style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                          >
                            <a
                              href="{{ routes.root_url }}"
                              class="relative header__heading-link link link--text focus-inset"
                            >
                              {{
                                settings.brand_image
                                | image_url: width: 1100
                                | image_tag:
                                  loading: 'lazy',
                                  widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                                  height: brand_image_height,
                                  width: settings.brand_image_width
                              }}
                              <span class="h2 opacity-0 absolute top-0 lef-0 h-full w-full">{{ shop.name }}</span>
                            </a>
                          </div>
                        {%- endif -%}
                        {%- if settings.brand_headline != blank and settings.brand_headline != '' -%}
                          <h4 class="text-secondary  sm:text-black m-0  footer-block__heading rte">
                            {{ settings.brand_headline }}
                          </h4>
                        {%- endif -%}
                        {%- if settings.brand_description != blank -%}
                          <div class="rte text-start md:text-center sm:text-center sm:mb-[3.5rem] sm:text-[#000]">
                            {{ settings.brand_description }}
                          </div>
                        {%- endif -%}
                      </div>
                      <div class="block sm:hidden w-full">
                        {{ newsletter_social }}
                      </div>
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="flex sm:flex-col w-full md:max-w-[40%] gap-[0_13%] justify-between  relative max-w-[31.47%] sm:max-w-full">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                <div
                  class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank and block.settings.menu == blank -%}
                    <h4 class="text-secondary  sm:text-black  ">
                      {{- block.settings.heading -}}
                    </h4>
                  {%- endif -%}
                  {% render block %}
                </div>
              {%- when 'text' -%}
                <div
                  class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank and block.settings.menu == blank -%}
                    <h4 class="text-secondary  sm:text-black  ">
                      {{- block.settings.heading -}}
                    </h4>
                  {%- endif -%}
                  <div class="footer-block__details-content rte">
                    {{ block.settings.subtext }}
                  </div>
                </div>
              {%- when 'link_list' -%}
                <div
                  class="max-w-[34.46%] sm:max-w-full footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %} sm:m-[0!important]"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank and block.settings.menu == blank -%}
                    <h4 class="text-secondary  sm:text-black  ">
                      {{- block.settings.heading -}}
                    </h4>
                  {%- endif -%}
                  <div class="flex flex-col gap-[4.8rem]  sm:gap-0">
                    {%- if block.settings.menu != blank -%}
                      <label class="footer-collapse flex flex-col gap-[2.4rem]">
                        <input type="radio" name="heading-collapse">
                        <h4 class="text-secondary  sm:text-black  ">
                          {{- block.settings.heading -}}
                        </h4>

                        <ul class="mobile-collapse transition-all sm:h-0 sm:overflow-hidden sm:mt-[-3.8rem] footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li>
                              <a
                                href="{{ link.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                                aria-label="{{ link.title }}"
                              >
                                {{ link.title }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </label>
                    {%- endif -%}

                    {% if block.settings.menu_2 != blank %}
                      <label class="footer-collapse flex flex-col gap-[2.4rem]">
                        <input type="radio" name="heading-collapse">
                        <h4 class="text-secondary  sm:text-black  ">
                          {{ block.settings.heading_2 }}
                        </h4>
                        <ul class="mobile-collapse transition-all sm:h-0 sm:overflow-hidden sm:mt-[-3.8rem] footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu_2.links -%}
                            <li>
                              <a
                                aria-label="{{ link.title }}"
                                href="{{ link.url }}"
                                class="
                                  link link--text list-menu__item list-menu__item--link
                                  {% if link.active %} list-menu__item--active{% endif %}
                                "
                              >
                                {{ link.title }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </label>
                    {% endif %}
                  </div>
                </div>
              {%- when 'image' -%}
                <div
                  class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank and block.settings.menu == blank -%}
                    <h4 class="text-secondary  sm:text-black  ">
                      {{- block.settings.heading -}}
                    </h4>
                  {%- endif -%}
                  <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                    {%- if block.settings.image != blank -%}
                      {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                      <div
                        class="footer-block__image-wrapper global-media-settings"
                        style="max-width: min(100%, {{ block.settings.image_width }}px);"
                      >
                        <img
                          srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                          src="{{ block.settings.image | image_url: width: 760 }}"
                          alt="{{ block.settings.image.alt | escape }}"
                          loading="lazy"
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                        >
                      </div>
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                    {%- endif -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {% for block in section.blocks %}
          {%- case block.type -%}
            {% when 'brand_information' %}
              {%- if block.settings.show_contact -%}
                <div class="flex flex-col  md:w-[25%]  gap-[2.4rem] text-start items-start contact-{{ block.id }} w-[19.6%] sm:w-full md:justify-center md:max-w-max">
                  <style>
                    .contact-{{block.id}} ul:not(.social){
                      list-style-type: none;
                      display:flex;
                      flex-direction: column;
                      gap: 16px;
                    }
                  </style>
                  <label class="footer-collapse flex flex-col gap-[2.4rem] sm:w-full">
                    <input type="radio" name="heading-collapse">
                    <h4 class="text-secondary max-w-max sm:max-w-full sm:text-black m-0">
                      {{ block.settings.brand_headline }}
                    </h4>

                    <div class="mobile-collapse transition-all sm:h-0 sm:overflow-hidden sm:mt-[-3.8rem] md:break-all">
                      {{ settings.brand_contact_info }}
                    </div>
                  </label>
                  <div class="sm:block hidden w-full">
                    {{ newsletter_social }}
                  </div>
                  <div class="w-full">
                    {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                      <div class="footer__follow-on-shop sm:hidden  sm:mt-[2.5rem]">
                        {% comment %} TODO: enable theme-check once `login_button` is accepted as valid filter {% endcomment %}
                        {% # theme-check-disable %}
                        {{ shop | login_button: action: 'follow' }}
                        {% # theme-check-enable %}
                      </div>
                    {%- endif -%}

                    {%- if section.settings.show_social and has_social_icons -%}
                      <div class="flex-col flex items-start gap-[2.4rem] sm:gap-0 justify-center">
                        <h4
                          class="text-secondary text-start mb-[2.4rem] sm:mb-0 sm:text-black font-medium  sm:text-[1.8rem] "
                          style="border:none!important;"
                        >
                          Follow Us On
                        </h4>
                        {%- render 'social-icons' -%}
                      </div>
                    {%- endif -%}
                  </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}
      </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

  <div class="footer__content-bottom border-none flex justify-between sm:flex-column">
    <div class="w-full border-t boder-white sm:border-[#000]  m-auto flex gap-[0_4rem] justify-between xl:max-w-[1480px] max-w-[88%] md:max-w-[1100px] sm:max-w-full sm:mx-[16px] sm:flex-col-reverse">
      <div class="sm:p-[0!important]  footer__content-bottom-wrapper page-width items-start sm:items-center">
        <div class="sm:p-[0!important] footer__column footer__localization isolate">
          {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
            <noscript>
              {%- form 'localization', id: 'FooterCountryFormNoScript', class: 'localization-form' -%}
                <div class="localization-form__select">
                  <h4 class="text-secondary  sm:text-black  visually-hidden" id="FooterCountryLabelNoScript">
                    {{ 'localization.country_label' | t }}
                  </h4>
                  <select
                    class="localization-selector link"
                    name="country_code"
                    aria-labelledby="FooterCountryLabelNoScript"
                  >
                    {%- for country in localization.available_countries -%}
                      <option
                        value="{{ country.iso_code }}"
                        {%- if country.iso_code == localization.country.iso_code %}
                          selected
                        {% endif %}
                      >
                        {{ country.name }} ({{ country.currency.iso_code }}
                        {{ country.currency.symbol }})
                      </option>
                    {%- endfor -%}
                  </select>
                  {% render 'icon-caret' %}
                </div>
                <button class="button button--tertiary">{{ 'localization.update_country' | t }}</button>
              {%- endform -%}
            </noscript>
            <localization-form class="w-full">
              {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                <div class="no-js-hidden">
                  <h4
                    class="text-secondary  sm:text-black border-[none!important] caption-large text-body"
                    id="FooterCountryLabel"
                  >
                    {{ 'localization.country_label' | t }}
                  </h4>
                  {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}

          {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
            <noscript>
              {%- form 'localization', id: 'FooterLanguageFormNoScript', class: 'localization-form' -%}
                <div class="localization-form__select">
                  <h4 class="text-secondary  sm:text-black  visually-hidden" id="FooterLanguageLabelNoScript">
                    {{ 'localization.language_label' | t }}
                  </h4>
                  <select
                    class="localization-selector link"
                    name="locale_code"
                    aria-labelledby="FooterLanguageLabelNoScript"
                  >
                    {%- for language in localization.available_languages -%}
                      <option
                        value="{{ language.iso_code }}"
                        lang="{{ language.iso_code }}"
                        {%- if language.iso_code == localization.language.iso_code %}
                          selected
                        {% endif %}
                      >
                        {{ language.endonym_name | capitalize }}
                      </option>
                    {%- endfor -%}
                  </select>
                  {% render 'icon-caret' %}
                </div>
                <button class="button button--tertiary">{{ 'localization.update_language' | t }}</button>
              {%- endform -%}
            </noscript>

            <localization-form>
              {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                <div class="no-js-hidden">
                  <h4 class="text-secondary  sm:text-black  caption-large text-body" id="FooterLanguageLabel">
                    {{ 'localization.language_label' | t }}
                  </h4>
                  {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
        </div>
        <div class="footer__column footer__column--info  items-start sm:items-center">
          {%- if section.settings.payment_enable -%}
            <div class="footer__payment sm:m-auto">
              <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
              <ul class="list list-payment" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment__item">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        </div>
      </div>
      <div class="footer__content-bottom-wrapper sm:p-[0!important] justify-end sm:justify-center page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
        <div class="footer__copyright caption sm:sm:text-left">
          <small class="copyright__content sm:text-start">
            {{- section.settings.copy_right_content }} &copy; {{ 'now' | date: '%Y' }},
            {{ shop.name | link_to: routes.root_url -}}
          </small>
          {% if section.settings.show_shopify_powered %}
            <small class="copyright__content">{{ powered_by_link }}</small>
          {% endif %}
          {%- if section.settings.show_policy -%}
            <ul class="policies list-unstyled">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                  <li>
                    <small class="copyright__content"
                      ><a
                        aria-label="{{ policy.title }}"
                        href="{{ policy.url }}"
                      >
                        {{- policy.title -}}
                      </a></small
                    >
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
