{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  <script
    defer
  >
    // Step 1: Define countries array from Liquid
    const countries = [
      {%- for country in localization.available_countries -%}
        {% assign localization_isos = localization.country.iso_code | json %}
        {
          isoCode: "{{ country.iso_code }}",
          name: "{{ country.name | escape }}",
          currencyCode: "{{ country.currency.iso_code }}",
          currencySymbol: "{{ country.currency.symbol }}",
          isSelected: {% if  country.iso_code == localization_isos %} "true" {% else %} "false" {% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ];

    const showCurrencies = {{ show_currencies | json }};

    // Step 2: On DOM load, build <li> items and append them
    document.addEventListener('DOMContentLoaded', function () {
      const ul = document.querySelector('ul.countries');
      if (!ul || !Array.isArray(countries)) return;

      countries.forEach((country) => {
        const li = document.createElement('li');
        li.className = 'disclosure__item';
        li.setAttribute('tabindex', '-1');

        const a = document.createElement('a');
        a.className = 'link link--text disclosure__link caption-large focus-inset';
        a.href = '#';
        a.dataset.value = country.isoCode;
        a.id = country.name;
        if (country.isSelected) a.setAttribute('aria-current', 'true');

        const checkmarkSpan = document.createElement('span');
        if (!country.isSelected) checkmarkSpan.className = 'visibility-hidden';
        checkmarkSpan.innerHTML = `{{ 'icon-checkmark.svg' | inline_asset_content | strip_newlines }}`;

        const countryNameSpan = document.createElement('span');
        countryNameSpan.className = 'country';
        countryNameSpan.textContent = country.name;

        const currencySpan = document.createElement('span');
        currencySpan.className = 'localization-form__currency motion-reduce';
        if (!showCurrencies) currencySpan.classList.add('hidden');
        currencySpan.textContent = `${country.currencyCode} ${country.currencySymbol}`;

        // Append spans to anchor
        a.appendChild(checkmarkSpan);
        a.appendChild(countryNameSpan);
        a.appendChild(currencySpan);

        // Append anchor to list item
        li.appendChild(a);

        // Append li to ul
        ul.appendChild(li);
      });
    });
  </script>
  <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

