    overflow: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    user-select: none;
    cursor: grab;
  }

  .scroll-container:active,
  .icon-box-container:active,
  .scroll-slider .product-section-container:active {
    cursor: grabbing;
  }
</style>
<script defer="defer">
  document.addEventListener('DOMContentLoaded', () => {
    document
      .querySelectorAll('.scroll-container, .icon-box-container, .scroll-slider .product-section-container')
      .forEach((scrollContainer) => {
        let isDown = false;
        let startX;
        let scrollLeft;

        // Update cursor style based on overflow
        const isOverflowing = scrollContainer.scrollWidth > scrollContainer.clientWidth;
        scrollContainer.style.cursor = isOverflowing ? 'grab' : 'default';
        const updateOverflow = () => {
          if (isOverflowing) {
            // Mouse down event
            scrollContainer.addEventListener('mousedown', (e) => {
              isDown = true;
              scrollContainer.classList.add('active'); // Optional: add a class for styling while dragging
              startX = e.pageX - scrollContainer.offsetLeft;
              scrollLeft = scrollContainer.scrollLeft;
              scrollContainer.style.cursor = 'grabbing'; // Optional: change cursor style
            });

            // Mouse up event
            document.addEventListener('mouseup', () => {
              isDown = false;
              scrollContainer.classList.remove('active');
              scrollContainer.style.cursor = ''; // Reset cursor style
            });

            // Mouse move event
            scrollContainer.addEventListener('mousemove', (e) => {
              if (!isDown) return; // Stop if not dragging
              e.preventDefault();
              const x = e.pageX - scrollContainer.offsetLeft;
              const walk = x - startX; // Calculate movement
              scrollContainer.scrollLeft = scrollLeft - walk; // Update scroll position
            });

            // Mouse wheel scroll event
            scrollContainer.addEventListener('wheel', (e) => {
              const maxScrollLeft = scrollContainer.scrollWidth - scrollContainer.clientWidth - 5;
              if (
                (e.deltaY > 5 && scrollContainer.scrollLeft >= maxScrollLeft) || // Prevent scrolling right if at max
                (e.deltaY < 5 && scrollContainer.scrollLeft <= 5) // Prevent scrolling left if at min
              ) {
                return;
              } else {
                e.preventDefault();
              }

              scrollContainer.scrollBy({
                left: e.deltaY * 2, // Adjust scroll speed by multiplying deltaY
                behavior: 'smooth', // Enable smooth scrolling
              });
            });
            // Check if the scrollContainer has the class .show-scrollbar
            if (scrollContainer.classList.contains('show-scrollbar')) {
              scrollContainer.style.paddingBottom = hasHorizontalScroll ? '10px' : '0px';
            }
          } else {
            return;
          }
        };

        updateOverflow();
        window.addEventListener('resize', updateOverflow);
      });
      
      {% comment %} 
       toggle footer navigations  for  footer
      {% endcomment %}
      const labels = document.querySelectorAll('.footer-collapse');

      labels.forEach(label => {
        const radio = label.querySelector('input[type="radio"]');

        label.querySelector('h4').addEventListener('click', function (e) {
          e.preventDefault(); // stop the normal radio behavior

          // Toggle manually
          radio.checked = !radio.checked;
        });
      });

      
  });
</script>
