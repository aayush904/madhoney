{{ 'section-blog-post.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign words = article.content | strip_html | strip | split: ' ' | size
  assign read_minutes = words | divided_by: 200
  if read_minutes < 1
    assign read_minutes = 1
  endif

  assign primary_tag = article.tags | first
-%}

<section class="section color-{{ section.settings.color_scheme }}">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="article-breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ blog.url }}">{{ blog.title | escape }}</a>
        {%- if primary_tag != blank and section.settings.show_tag_in_breadcrumbs -%}
          <span aria-hidden="true"> / </span>
          <a href="{{ blog.url }}/tagged/{{ primary_tag | handleize }}">{{ primary_tag }}</a>
        {%- endif -%}
        <span aria-hidden="true"> / </span>
        <span>{{ article.title | escape }}</span>
      </nav>
    {%- endif -%}

    <header class="article-hero">
      <div class="article-hero__media">
        {%- if article.image -%}
          {%- liquid
            assign sizes = '(min-width: 990px) 36vw, 100vw'
            assign widths = '375, 550, 750, 990, 1200, 1500, 1800, 2400'
            assign h = article.image.width | divided_by: article.image.aspect_ratio | round
          -%}
          {{
            article.image
            | image_url: width: 2400
            | image_tag:
              class: 'article-hero__img',
              loading: 'eager',
              decoding: 'async',
              fetchpriority: 'high',
              sizes: sizes,
              widths: widths,
              height: h,
              draggable: 'false'
          }}
        {%- endif -%}
      </div>

      <div class="article-hero__content">
        {%- if section.settings.show_read_time -%}
          <div class="article-hero__kicker">{{ read_minutes }} min read</div>
        {%- endif -%}

        <h1 class="h2 article-hero__title">{{ article.title | escape }}</h1>

        <div class="article-hero__meta">
          {%- if section.settings.show_date -%}
            <span class="article-hero__date">
              {{ article.published_at | time_tag: format: 'date' }}
            </span>
          {%- endif -%}

          {%- if section.settings.show_author and article.author != blank -%}
            <span class="article-hero__author">
              {{ article.author | escape }}
            </span>
          {%- endif -%}
        </div>
      </div>
    </header>

    <div class="article-layout">
      <main class="article-main" id="ArticleContent-{{ section.id }}">
        <div class="article-content rte">
          {% if article.content contains '[ads_review]' %}
            {% capture f_review %}
              {% assign rating = article.metafields.custom.featured_review.value.rating.value | split: '.' | first | plus: 0  | default: 0 %}
              {% assign quote = article.metafields.custom.featured_review.value.review  %}
              {% assign author = article.metafields.custom.featured_review.value.author %}
              {% assign rev_image = article.metafields.custom.featured_review.value.background_image %}
              <section class="testimonial">
                <div class="testimonial__content">
                  <div class="testimonial__left">
                    <div class="testimonial__stars">
                        {%- for i in (1..rating) -%}★{%- endfor -%}
                    </div>

                    <div class="testimonial__quote">
                      "{{quote}}"
                    </div>
                    <div class="testimonial__author">
                      — {{author}}
                    </div>
                  </div>

                  <div class="testimonial__right">
                    {%- liquid
                      assign sizes = '(min-width: 990px) 36vw, 100vw'
                      assign widths = '500, 750, 950, 1080, 1200'
                      assign h = article.image.width | divided_by: article.image.aspect_ratio | round
                    -%}
                      {{
                        rev_image | image_url: width: 1200 | image_tag:
                          class: 'article-review',
                          loading: 'lazy',
                          decoding: 'async',
                          sizes: sizes,
                          widths: widths,
                          height: h,
                          draggable: 'false'
                      }} 
                  </div>
                </div>
              </section>
              <style>
                .testimonial {
                  background: #EADBC8; /* soft beige */
                  border-radius: 12px;
                  padding: 25px;
                  overflow: hidden;
                  overflow:hidden;
                  position:relative;
                }

                .testimonial__content {
                  display: flex;
                  align-items: center;
                  justify-content: start;
                  gap: 40px;
                  max-width: 1200px;
                  margin: 0 auto;
                }

                .testimonial__left {
                  flex: 1;
                  max-width: clamp(250px,30.32vw,580px);
                  z-index:1;
                }

                .testimonial__stars {
                  color: #F6BE00;
                  font-size: 28px;
                  margin-bottom: 10px;
                  letter-spacing: 4px;
                }

                .testimonial__quote {
                  font-size: clamp(18px, 1.46vw, 28px);
                  line-height: 1.4;
                  font-style: italic;
                  font-weight: 500;
                  margin: 0 0 35px;
                  color: #f5f5f5;
                }

                .testimonial__author {
                  font-size: clamp(12px, 0.83vw, 16px);
                  color: #f5f5f5;
                }

                .testimonial__right {
                  position:absolute;
                  min-width:100%;
                  min-height:100%;
                  inset:0;
                  z-index:0;
                }

                .testimonial__right img {
                  min-width: 100%;
                  height: auto;
                  border-radius: 8px;
                  object-fit: cover;
                  min-height:100%;
                }

                @media (max-width: 768px) {
                    .testimonial__right img {
                        object-fit: cover;
                        object-position: 50%;
                        width: 100%;
                        min-height: 100%;
                    }
                    #shopify-section-{{ section.id }} .article-layout{
                      display: block !important;
                    }
                }
              </style>
            {% endcapture %}
            {{ article.content | replace: '[ads_review]', f_review }}
          {% else %}
            {{ article.content }}
          {%- endif -%}
        </div>
        {%- liquid
          assign expert_heading = article.metafields.custom.expert.value.name | default: 'Meet our Expert'
          assign expert_content = article.metafields.custom.expert.value.detail
          assign expert_image = article.metafields.custom.expert.value.image
          assign show_expert = false
          if expert_content != blank or expert_image != blank
            assign show_expert = true
          endif
        -%}

        {%- if show_expert -%}
          <section class="article-expert" aria-label="{{ expert_heading | escape }}">
            <h2 class="h2 article-expert__heading">{{ expert_heading | escape }}</h2>

            <div class="article-expert__grid">
              <div class="article-expert__text rte">
                {%- if expert_content != blank -%}
                  {{ expert_content | metafield_tag }}
                {%- endif -%}
              </div>

              {%- if expert_image != blank -%}
                {%- liquid
                  assign img = expert_image.value
                  if img == blank
                    assign img = expert_image
                  endif
                  assign sizes = '(min-width: 990px) 220px, 40vw'
                  assign widths = '220, 320, 420, 540, 720'
                  assign h = img.width | divided_by: img.aspect_ratio | round
                -%}
                <div class="article-expert__media">
                  {{
                    img
                    | image_url: width: 280
                    | image_tag:
                      class: 'article-expert__img',
                      loading: 'lazy',
                      decoding: 'async',
                      sizes: sizes,
                      widths: widths,
                      height: h,
                      draggable: 'false'
                  }}
                </div>
              {%- endif -%}
            </div>
          </section>
        {%- endif -%}
      </main>

      {%- if section.settings.show_cheat_sheet and article.metafields.custom.cheat_sheet != blank -%}
        <aside class="article-sidebar">
          {%- render 'blog-sidebar',
            article: article,
            cheat_sheet: article.metafields.custom.cheat_sheet,
            heading: section.settings.cheat_sheet_heading
          -%}
        </aside>
      {%- endif -%}
    </div>
    {%- liquid
      assign share_url = request.origin | append: article.url
      assign share_url_enc = share_url | url_encode
      assign share_title_enc = article.title | strip | url_encode
      assign pin_media_enc = ''
      if article.image
        assign pin_media_enc = article.image | image_url: width: 1200 | url_encode
      endif
    -%}

    <div class="article-footer">
      <hr class="article-footer__sep" aria-hidden="true">

      <div class="article-share" aria-label="Share">
        <a
          class="article-share__link"
          href="https://www.facebook.com/sharer/sharer.php?u={{ share_url_enc }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on Facebook"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M13.5 22v-8h2.7l.4-3H13.5V9.1c0-.9.2-1.5 1.5-1.5H16.7V5.1c-.3 0-1.4-.1-2.6-.1-2.6 0-4.4 1.6-4.4 4.6V11H7.2v3h2.5v8h3.8z"/>
          </svg>
        </a>

        <a
          class="article-share__link"
          href="https://twitter.com/intent/tweet?url={{ share_url_enc }}&text={{ share_title_enc }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on X"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M18.9 2H22l-6.8 7.8L23 22h-6.2l-4.9-6.4L6.4 22H3.3l7.3-8.4L1 2h6.3l4.4 5.8L18.9 2zm-1.1 18h1.7L7.2 3.9H5.4L17.8 20z"/>
          </svg>
        </a>

        <a
          class="article-share__link"
          href="https://pinterest.com/pin/create/button/?url={{ share_url_enc }}{% if pin_media_enc != blank %}&media={{ pin_media_enc }}{% endif %}&description={{ share_title_enc }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on Pinterest"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.4-6s-.3-.6-.3-1.6c0-1.5.9-2.6 2-2.6.9 0 1.4.7 1.4 1.6 0 1-.6 2.5-.9 3.9-.3 1.2.6 2.2 1.8 2.2 2.2 0 3.9-2.3 3.9-5.6 0-2.9-2.1-4.9-5.1-4.9-3.5 0-5.5 2.6-5.5 5.3 0 1 .4 2.1.9 2.7.1.1.1.3.1.5l-.3 1c-.1.3-.3.4-.6.3-1.6-.7-2.6-2.8-2.6-4.6C4.6 6.6 7.1 4 12 4c4 0 7.1 2.8 7.1 6.6 0 4-2.5 7.2-6 7.2-1.2 0-2.3-.6-2.7-1.3l-.7 2.7c-.3 1-.9 2.2-1.3 3A10 10 0 1 0 12 2z"/>
          </svg>
        </a>

        <a
          class="article-share__link"
          href="mailto:?subject={{ share_title_enc }}&body={{ share_url_enc }}"
          aria-label="Share by email"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5L4 8V6l8 5 8-5v2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

{%- style -%}
  body{
    padding:0;
  }
      .section-{{ section.id }}-padding{
        padding-top: clamp({{ section.settings.padding_top | times: 0.43 | round: 0 }}px, {{ section.settings.padding_top | divided_by: 19.13 }}vw, {{ section.settings.padding_top }}px);
        padding-bottom: clamp({{ section.settings.padding_bottom | times: 0.43 | round: 0 }}px, {{ section.settings.padding_bottom | divided_by: 19.13 }}vw, {{ section.settings.padding_bottom }}px);
      }
      #shopify-section-{{ section.id }} h3,#shopify-section-{{ section.id }} h2, #shopify-section-{{ section.id }} h4{
        margin-top: revert;
      }

      #shopify-section-{{ section.id }} .section{
        background:transparent;
      }

      #shopify-section-{{ section.id }} blockquote h1,
      #shopify-section-{{ section.id }} blockquote h2,
      #shopify-section-{{ section.id }} blockquote h3,
      #shopify-section-{{ section.id }} blockquote h4,
      #shopify-section-{{ section.id }} blockquote h5,
      #shopify-section-{{ section.id }} blockquote h6 {
        margin:0;
      }

      #shopify-section-{{ section.id }} .article-breadcrumbs{
        font-size: clamp(1rem, 0.8vw, 1.4rem);
        line-height: 1.5;
        margin: 0 0 clamp(1.2rem, 1.2vw, 2.4rem);
        font-weight: 300;
      }
      #shopify-section-{{ section.id }} .article-breadcrumbs a{
        color: rgb(var(--color-foreground));
        text-decoration: underline !important;
        text-underline-offset: .2em;
      }

      #shopify-section-{{ section.id }} .article-breadcrumbs a:hover{
        color: var(--color-extra);
      }

      #shopify-section-{{ section.id }} .article-hero{
        display: grid;
        grid-template-columns: 1fr;
        border-radius: 14px;
        overflow: hidden;
        background: rgb(248, 237, 219);
      }

      #shopify-section-{{ section.id }} .article-hero__media{
        background: rgba(var(--color-foreground), 0.06);
      }
      #shopify-section-{{ section.id }} .article-hero__img{
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        -webkit-user-drag: none;
        user-drag: none;
      }

      #shopify-section-{{ section.id }} .article-hero__content{
        padding: clamp(24px, 2.1vw, 40px) clamp(18px, 2.8vw, 54px) clamp(24px, 2.4vw, 46px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.2rem;
      }

      #shopify-section-{{ section.id }} .article-hero__kicker{
        font-weight: 600;
        opacity: .85;
      }

      #shopify-section-{{ section.id }} .article-hero__title{
        margin: 0;
        line-height: 1.05;
        font-size: calc(var(--font-heading-scale) * clamp(2rem, 2.4vw, 4.6rem));
      }
      #shopify-section-{{ section.id }} .article-hero__title,
      #shopify-section-{{ section.id }} .article-hero__title a{
        letter-spacing: 0.5px;
      }

      #shopify-section-{{ section.id }} .article-hero__meta{
        display: flex;
        gap: 1.2rem;
        flex-wrap: wrap;
        opacity: .9;
      }

      #shopify-section-{{ section.id }} .article-layout{
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-top: clamp(3rem, 2.6vw, 5rem);
        align-items: start;
      }

      #shopify-section-{{ section.id }} .article-sidebar{
        position: relative;
      }

      #shopify-section-{{ section.id }} .cheat-sheet{
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 0 rgba(0,0,0,.06);
      }

      #shopify-section-{{ section.id }} .cheat-sheet__head{
        background: rgb(var(--color-foreground));
        /* background:var(--color-extra); */

        padding: 1.6rem 1.8rem;
        text-align: center;
      }

      #shopify-section-{{ section.id }} .cheat-sheet__title{
        color: #ffffff;
        margin: 0;
        line-height: 1.1;
      }

      #shopify-section-{{ section.id }} .cheat-sheet__body{
        padding: 2.4rem 1.6rem;
        background: #fbedd4;
      }

      #shopify-section-{{ section.id }} .cheat-sheet__body ul{
        margin: 0;
        padding-left: 1.6rem;
      }

      #shopify-section-{{ section.id }} .cheat-sheet__body li + li{
        margin-top: .9rem;
      }

      @media screen and (min-width: 990px){
        #shopify-section-{{ section.id }} .article-hero{
          grid-template-columns: 38% 62%;
          /* min-height: 420px; */
        }

        #shopify-section-{{ section.id }} .article-hero__media{
          height: 100%;
          /* min-height: 420px; */
        }

        #shopify-section-{{ section.id }} .article-layout{
          grid-template-columns: minmax(0, 1fr) 320px;
          gap: 4.8rem;
        }

        #shopify-section-{{ section.id }} .article-sidebar{
          position: sticky;
          top: calc(var(--header-height,13rem) + 2rem);
        }
      }


      #shopify-section-{{ section.id }} .article-expert{
      margin-top: clamp(3rem, 2.6vw, 5rem);
      max-width: 700px;
    }

    #shopify-section-{{ section.id }} .article-expert__heading{
      margin: 0 0 1.2rem;
    }

    #shopify-section-{{ section.id }} .article-expert__grid{
      display: grid;
      grid-template-columns: 1fr;
      gap: 0 2.2rem;
      align-items: start;
    }

    #shopify-section-{{ section.id }} .article-expert__media{
      max-width: clamp(100px,9.4vw,180px);
      grid-row: 1/2;
      grid-column: 1/2;
    }

    #shopify-section-{{ section.id }} .article-expert__img{
      width: 100%;
      height: auto;
      display: block;
      -webkit-user-drag: none;
      user-drag: none;
      border-radius:16px;
      max-width: clamp(100px,9.4vw,180px);
    }

    #shopify-section-{{ section.id }} .article-footer{
      margin-top: clamp(3rem, 2.6vw, 5rem);
    }

    #shopify-section-{{ section.id }} .article-footer__sep{
      border: 0;
      border-top: 2px solid rgb(var(--color-foreground));
      margin: 0;
    }

    #shopify-section-{{ section.id }} .article-share{
      display: flex;
      align-items: center;
      gap: 1.2rem;
      padding-top: 1.4rem;
    }

    #shopify-section-{{ section.id }} .article-share__link{
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: rgb(var(--color-foreground));
    }

    #shopify-section-{{ section.id }} .article-share__link:hover{
      color: var(--color-extra);
    }

    #shopify-section-{{ section.id }} .article-share__link svg{
      width: 18px;
      height: 18px;
      display: block;
    }

    @media screen and (min-width: 782px){
      #shopify-section-{{ section.id }} .article-expert__grid{
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 3.2rem;
      }

      #shopify-section-{{ section.id }} .article-expert__media{
        max-width: none;
        justify-self: end;
        grid-column: 2/3;
      }
    }
{%- endstyle -%}

{% schema %}
{
  "name": "Main article",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tag_in_breadcrumbs",
      "label": "Show first tag in breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_time",
      "label": "Show read time",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "header",
      "content": "Cheat sheet sidebar"
    },
    {
      "type": "checkbox",
      "id": "show_cheat_sheet",
      "label": "Show cheat sheet",
      "default": true
    },
    {
      "type": "text",
      "id": "cheat_sheet_heading",
      "label": "Cheat sheet heading",
      "default": "Cheat Sheet"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
