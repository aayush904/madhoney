{{ section.settings.iconbox_style }}

<style>
  #shopify-section-{{ section.id }} .slick-initialized .slick-slide .iconbox.flex {
    display: flex !important;
  }


  #shopify-section-{{ section.id }}
  .iconbox-wrapper.flex .slick-track {
    display: flex;
    gap: {{ section.settings.iconbox_gap }};
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} {
    {% if section.settings.background_on == 'main_section' %}
      {% if section.settings.background_type == 'color' and section.settings.background_color != "" %}
        background: {% if section.settings.background_gradient != ""%}
            {{section.settings.background_gradient}}
          {% else %}
          {{ section.settings.background_color }}
        {% endif %};
      {% elsif section.settings.background_type == 'image' and section.settings.background_image != blank %}
        background-image: {% if section.settings.background_gradient != "" %}
          {{ section.settings.background_gradient }}, {% endif %}url('{{ section.settings.background_image | image_url }}');
        background-position: {{ section.settings.background_position }};
        background-repeat: no-repeat;
        background-size: {{ section.settings.background_size }};
      {% endif %};
    {% endif %};

    && p {
      color: {{ section.settings.content_color }};
    }

    && h2, h1
    h3 {
      color: {{ section.settings.heading_color }};
    }
  }

  @media (max-width: 1200px) {
    #shopify-section-{{ section.id }} {
      && .wrapper {
        max-width: 116.6rem !important;
        width:100%;
      }

    }
  }


  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      && .wrapper {
        max-width: 100% !important;
      }

    }
  }

  #shopify-section-{{ section.id }} .wrapper.wrapper{
    width: {{ section.settings.width }};
    min-height: {{ section.settings.min_height }};
    padding: {{ section.settings.padding }};
    margin: {{ section.settings.margin }};
   {% if section.settings.background_on == 'content_part' %}
      {% if section.settings.background_type == 'color' and section.settings.background_color %}
        background: {{ section.settings.background_color }};
      {% elsif section.settings.background_type == 'image' and section.settings.background_image %}
        background: url('{{ section.settings.background_image  | image_url }}') no-repeat {{ section.settings.background_position }};
        background-size: {{ section.settings.background_size }};
      {% endif %};
  {% endif %};
    gap: {{ section.settings.content_iconbox_gap }};
  }

  @media(max-width:768px){
    {% if section.settings.padding contains '12rem' %}
      {% assign updated_padding = section.settings.padding | replace: '12rem', '6.25rem' %}

      #shopify-section-{{ section.id }} .wrapper.wrapper{
        padding: {{updated_padding}};
      }
    {% endif %}
  }
</style>

<div
  class="wrapper flex flex-col mx-auto relative {{ section.settings.custom_class }}"
  id="{{ section.settings.custom_id }}"
  style=""
>
  {% if section.settings.section_title or section.settings.section_description %}
    <div
      class="
              contentPart
        flex flex-col gap-6
        {% if section.settings.content_alignment  =='left' %}
          items-start text-left
        {% elsif  section.settings.content_alignment  =='center' %}
          items-center text-center
        {% else %}
          items-end text-right
        {% endif %}
      "
    >
      <{{ section.settings.heading_size }}>{{ section.settings.section_title }}</{{ section.settings.heading_size }}>
      {% if section.settings.section_description %}
        <p>{{ section.settings.section_description }}</p>
      {% endif %}
    </div>
  {% endif %}
  <div class="icon-box-container w-full overflow-hidden">
    <div
      class="iconbox-wrapper flex flex-wrap gap-[4rem_6rem] justify-center iconboxes"
      style="    gap: {{ section.settings.iconbox_gap }};"
    >
      {% for block in section.blocks %}
        <div
          class="iconbox ma-h-max flex sm:max-w-[100%!important] w-full {% if section.settings.image_layout == 'left' %} flex-row {% elsif section.settings.image_layout == 'top' %} flex-col {% elsif section.settings.image_layout == 'bottom' %} flex-col-reverse {% else %} flex-row-reverse {% endif %} {% if section.settings.icon_box_content_alignment  =='left' %} items-start text-left {% elsif  section.settings.icon_box_content_alignment  =='center' %} items-center text-center {% else %} items-end text-right {% endif %} sm:items-center sm:text-center "
          style="
            break-inside: avoid;
            {% if section.settings.icon_box_slider != 'true' %}
              max-width: {{ section.settings.content_part_width }};
            {% endif %}
          "
        >
          {% if block.settings.icon_type_select == 'image' %}
            {% if block.settings.icon_image != blank %}
              {% assign img_alt = block.settings.icon_image.alt
                | default: block.settings.icon_alt_text
                | default: block.settings.icon_title
                | strip_html
              %}
              {% if section.settings.is_image_link and block.settings.btn_link != blank %}
                <a
                  aria-label="{{ block.settings.icon_alt_text | default: section.settings.section_title }}"
                  href="{{ block.settings.btn_link }}"
                  {% if block.settings.isnotFollow == true %}
                    rel="nofollow"
                  {% endif %}
                >
                  {% comment %}
                    <img
                      src="{{ block.settings.icon_image | image_url }}"
                      alt="{{ block.settings.icon_image | default: block.settings.icon_alt_text }}"
                      class="w-64 h-auto mx-auto mb-[3.2rem]"
                      width="180"
                      height="180" loading="lazy"
                    >
                  {% endcomment %}
                  {{
                    block.settings.icon_image
                    | image_url: width: block.settings.icon_image.width
                    | image_tag:
                      widths: '320, 480, 768, 1024',
                      class: 'w-64 h-auto mx-auto mb-[3.2rem]',
                      alt: img_alt,
                      width: block.settings.icon_image.width,
                      height: block.settings.icon_image.height,
                      loading: 'lazy'
                  }}
                </a>
              {% else %}
                {% comment %}
                  <img
                    src="{{ block.settings.icon_image | image_url }}"
                    alt="{{ block.settings.icon_image | default: block.settings.icon_alt_text }}"
                    class="w-64 h-auto mx-auto mb-[3.2rem]"
                    width="180"
                    height="180"
                    loading="lazy"
                  >
                {% endcomment %}

                {{
                  block.settings.icon_image
                  | image_url: width: block.settings.icon_image.width
                  | image_tag:
                    widths: '320, 480, 768, 1024',
                    class: 'w-64 h-auto mx-auto mb-[3.2rem]',
                    alt: img_alt,
                    width: block.settings.icon_image.width,
                    height: block.settings.icon_image.height,
                    loading: 'lazy'
                }}
              {% endif %}
            {% endif %}
          {% else %}
            {% if section.settings.is_image_link and block.settings.btn_link != blank %}
              <a
                aria-label="{{ block.settings.icon_alt_text | default: section.settings.section_title }}"
                href="{{ block.settings.btn_link }}"
                {% if block.settings.isnotFollow == true %}
                  rel="nofollow"
                {% endif %}
              >
            {% endif %}
            {% if block.settings.icon_svg != blank %}
              {{ block.settings.icon_svg }}
            {% endif %}
            {% if section.settings.is_image_link and block.settings.btn_link != blank %}
              </a>
            {% endif %}
          {% endif %}
          {% if block.settings.icon_title != ''
            or block.settings.icon_description != ''
            or block.settings.btn_title != blank
          %}
            <div>
              {% if block.settings.icon_title != '' %}
                <{{ section.settings.box_title_tag }} class="text-[#997755] font-semibold mb-[1.2rem] sm:mb-[2rem] icon-box-heading">
                  {{ block.settings.icon_title }}
                </{{ section.settings.box_title_tag }}>
              {% endif %}

              {% if block.settings.icon_description != '' %}
                <p class="description">
                  {{ block.settings.icon_description }}
                </p>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.btn_title != blank %}
            <a href="{{ block.settings.btn_link }}" class="button btn-primary mt-[16px]">
              {{ block.settings.btn_title }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% if section.settings.icon_box_slider == 'true' %}
  {{ 'slick.css' | asset_url | stylesheet_tag }}
  {% comment %}
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"
    >
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.min.js" ></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.min.js" ></script>
  {% endcomment %}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      $('#shopify-section-{{ section.id }} .iconbox-wrapper').slick({
        slidesToShow: 3,
        slidesToScroll: 1,
        autoplay: true,
        autoplaySpeed: 2500,
        {% comment %} speed: 8000, {% endcomment %}
        pauseOnHover: true,
        arrows: false,
        draggable: true,
        {% comment %} cssEase: 'linear', {% endcomment %}
        responsive: [
          {
            breakpoint: 1335,
            settings: {
              slidesToShow: 2,
              slidesToScroll: 1,
            }
          },
          {
            breakpoint: 600,
            settings: {
              slidesToShow: 1.1,
              slidesToScroll: 1
            }
          }
        ]
      });
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "Icon Box Section",
  "class": "icon-box-section insec",
  "settings": [
    {
      "type": "header",
      "content": "Heading Tag"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ]
    },
    {
      "type": "html",
      "id": "section_title",
