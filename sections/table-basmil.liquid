{% stylesheet %}
  table {
    width: 100%;
    border-collapse: collapse;
    font-family: Lato, ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', Segoe UI Symbol,
      'Noto Color Emoji';
  }
  th,
  td {
    border: 1px solid #ddd;
    padding: 1rem 1.2rem;
    text-align: left;

    display: flex;
    align-items: center;
  }
  th {
    background-color: #f4f4f4;
    text-align: center;
    display: flex;
    align-items: center;
  }
{% endstylesheet %}

<style>
    #shopify-section-{{ section.id }} {
      {% if section.settings.background_on == "whole" %}
    background: {% if section.settings.background_type == 'color' %}{{ section.settings.background_color }}{% else %}url('{{ section.settings.background_image }}'){% endif %};
    background-size: {{ section.settings.background_size }};
    background-position: {{ section.settings.background_position }};"
    {% endif %}
      }


  #shopify-section-{{ section.id }} .wrapper{
    color:{{ section.settings.content_color }};
    padding: {{ section.settings.section_padding }};
    margin: {{ section.settings.section_margin }};
    {% if section.settings.background_on == "content" %}
    background: {% if section.settings.background_type == 'color' %}{{ section.settings.background_color }}{% else %}url('{{ section.settings.background_image }}'){% endif %};
    background-size: {{ section.settings.background_size }};
    background-position: {{ section.settings.background_position }};
    {% endif %}
    width: {{ section.settings.section_width }};
    min-height: {{ section.settings.section_min_height }};
    }

    .contentwrapper{
      gap:4rem ;
      width:100%;
    }
  @media(max-width:1280px){
    #shopify-section-{{ section.id }} .wrapper{
      max-width:1166px;
      width:100%;
    }
  }



    @media(max-width:768px){
          {% if section.settings.section_padding contains '12rem' %}
            {% assign updated_padding = section.settings.section_padding | replace: '12rem', '6.25rem' %}
              #shopify-section-{{ section.id }} .wrapper.wrapper{
              padding: {{ updated_padding }};
            }
          {% endif %}
      }
</style>
{% assign contents = '' %}
{% for block in section.blocks %}
  {% if block.type == 'heading' %}
    {% if forloop.index0 != 0 %}
      {% assign contents = contents | append: '###' %}
    {% endif %}

  {% else %}
    {% if forloop.last %}
      {% assign contents = contents | append: block.settings.table_content %}
    {% else %}
      {% assign contents = contents | append: block.settings.table_content | append: '***' %}
    {% endif %}
  {% endif %}
{% endfor %}

{%- assign rows = contents | split: '***###' -%}
{%- assign result_array = '' -%}

{%- for row in rows -%}
  {%- assign items = row | split: '***' -%}
  {%- assign result_array = result_array | append: items | append: '|' -%}
{%- endfor -%}

{%- assign final_array = result_array | split: '|' -%}

<div
  class="main-wrapper wrapper page-width text-image-slider p-4 flex items-center justify-center"
>
  <div
    class="flex flex-col items-center justify-center  sm:max-w-[100%!important] contentwrapper"
  >
    <!-- Main Section Heading and Description -->
    <div
      class="main-content sm:max-w-[100%!important]"
      style="
        {%- if  section.settings.alignment == 'left' -%} text-align: left;
        {%- elsif  section.settings.alignment == 'center' -%} text-align: center;
        {%- else -%} text-align: right; {%- endif -%} width:100%; max-width: {{ section.settings.content_part_width }};
      "
    >
      <h2 class="text-tertiary">{{ section.settings.main_heading }}</h2>
      {{ section.settings.main_content }}
    </div>

    <div class="table-wrapper">
      <table border="1" class="dynamic-table">
        <thead>
          <tr>
            {%- for block in section.blocks -%}
              {%- if block.type == 'heading' -%}
                <th>{{ block.settings.table_heading }}</th>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {% assign max_counter = 0 %}

          {% for item in final_array %}
            {% assign array = item | split: ',' %}
            {% if array.size > max_counter %}
              {% assign max_counter = array.size | minus: 1 %}
            {% endif %}
          {%- endfor -%}

          {% for i in (0..max_counter) %}
            <tr>
              {% for item in final_array %}
                {% assign cleaned_text = item | remove: '["' | remove: '"]' | strip | strip %}
                {% assign cleaned_text = cleaned_text | split: '", "' %}
                <td>{{ cleaned_text[i] | strip }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.table-wrapper tr').forEach(function (row) {
    // Get all the td elements of the current row
    let allTds = row.querySelectorAll('td,th');

    // Check if all td elements are empty
    let isEmpty = Array.from(allTds).every(function (td) {
      return td.textContent.trim() === ''; // Check if td content is empty after trimming whitespace
    });

    // If all td elements are empty, remove the row
    if (isEmpty) {
      row.remove();
    }
  });
</script>

{% schema %}
{
  "name": "Table Basmil",
  "class": "table-basmil",
  "settings": [
