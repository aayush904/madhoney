<style>
  #shopify-section-{{ section.id }} {
    .container {
      max-width: 100vw;
      margin: 0 auto;
      padding: 20px;
    }

    h1 {
      text-align: center;
      margin-bottom: 30px;
      color: #333;
    }

    /* Main Slider Styles */
    main-slider {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      height: max-content;
      z-index: 20;

      &&:before {
        width: 110vw;
        background: #000000e6;
        height: 100vh;
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
    }

    .variant-options.scroll-container{
      scrollbar-width:thin;
    }

    .main-slider .slick-slide {
      {% comment %} transition: none!important; {% endcomment %}
      width: 10vw;
      padding: 0 10px;
    }

    .main-slider .slide:not(.slick-current) {
      width: 10vw;

      && .product-infom {
        width: 0;
        height: 0;
        opacity: 0;
      }
    }

    .main-slider .slide {
      {% comment %} width: 10vw; {% endcomment %}
      height: auto;

      && video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      && .product-infom {
        {% comment %} transition: width 0.5s ease!important; {% endcomment %}
        overflow: hidden;
        width: 100%;
        opacity: 1;
      }
    }

    .main-slider .slick-current.slick-activer {
      transform: scale(1);
      width: 43.2vw;
    }

    .main-slider .slick-prev.slick-arrow:before {
      content: url('data:image/svg+xml,<svg width="41" height="41" viewBox="0 0 41 41" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20.0696" cy="20.5735" r="20.0696" fill="%23E0AF7E" fill-opacity="0.6"/><path d="M22.9219 26.8027L16.9219 20.8027L22.9219 14.8027" stroke="%23020403" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>');
    }

    .main-slider .slick-next.slick-arrow:before {
      content: url('data:image/svg+xml,<svg width="41" height="41" viewBox="0 0 41 41" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20.2102" cy="20.5735" r="20.0696" fill="%23E0AF7E" fill-opacity="0.6"/><path d="M18.9219 26.8027L24.9219 20.8027L18.9219 14.8027" stroke="%23020403" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>');
    }

    /* Custom Dots Navigation */
    .nav-slider {
      display: flex;
      {% comment %} overflow-x: hidden; {% endcomment %}
    }

    .custom-dot {
      height: auto;
      aspect-ratio: 9/16;
      cursor: pointer;
      border-radius: 5px;
      overflow: hidden;
      transition: all 0.3s ease;
      border: 2px solid transparent;
    }

    .custom-dot img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Slick Arrow Customization */
    .slick-prev,
    .slick-next {
      width: 40px;
      height: 40px;
      z-index: 1;
    }

    .slick-prev {
      left: 10px;
    }

    .slick-next {
      right: 10px;
    }

    .slick-prev:before,
    .slick-next:before {
      font-size: 30px;
      color: #2c73d2;
    }

    /* Hide default dots */
    .slick-dots {
      display: none !important;
    }

    .main-slider .slick-slide {
      {% comment %} transform: scale(0.35) !important; {% endcomment %}
      {% comment %} background: red; {% endcomment %}
      transition: all 0.5 ease !important;
      transform: scale(1) !important;
      margin: 0 1.52vw !important;
      display: none;
    }

    .main-slider .slick-slide.slick-active {
      {% comment %} transform: scale(0.8) !important; {% endcomment %}
      min-width: 13vw;
      display: block;
    }

    .main-slider .slick-current.slick-current {
      background: #ffffff !important;
      min-width: 46.3vw;
    }

    .main-slider .slide:not(.slick-current) .speaker {
      display:none!important;
    }

    .slick-list,
    .slick-slide {
      max-height: 98vh;
    }
  }

  /* Responsive Adjustments */
  @media (min-width: 769px) and (max-width: 1024px) {
    #shopify-section-{{ section.id }} {
      .product-description * {
        font-size: 14px !important;
      }

      .main-slider .slick-current.slick-current,
      .main-slider .slide {
        transform: scale(1);
        width: 50vw;
      }

      .product-actions {
        .buy-btn {
          .button {
            font-size: 12px;
          }
        }
      }
    }
  }

  @media (max-width: 1280px) {
    #shopify-section-{{ section.id }} {
      .main-slider .slick-current.slick-current,
      .main-slider .slide {
        transform: scale(1);
        width: 60vw;
      }
    }
  }

  @media (max-width: 768px) {
    {% comment %} .main-slider .slide img {
      height: 300px;
    } {% endcomment %}
    .main-slider .slide:not(.slick-current) {
      min-width:100%;
      display:block!important;
    }

    .custom-dot {
      width: 60px;
      height: 45px;
    }

    .slick-list,
    .slick-slide {
      max-height: 100%!important;
      height: 100vh!important;
    }

    .slick-track{
      height: auto;
      max-width:100vw;
      display: block !important;
    }
  }

  @media (max-width: 480px) {
    {% comment %} .main-slider .slide img {
      height: 250px;
    } {% endcomment %}

    .custom-dot {
      width: 40px;
      height: 30px;
    }

    .nav-slider {
      gap: 5px;
    }
  }

  @media(min-width: 769px){
    #shopify-section-{{ section.id }} {
        .header__icon.header__icon{
          display:none; 
        }
      }
  }
  
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      .product-infom {
        width: 100%;
        height: 90%;
        opacity: 1;
        aspect-ratio: auto;
      }

      .main-slider .slick-current.slick-current,
      .main-slider .slide {
        max-height: 100vh;
        min-width: 100%!important;
        max-width: 100vw;
        aspect-ratio: 9/16;
        margin: 0!important;
        border: 0!important;
        border-radius: 0!important;
      }



      .hidden.hidden.sm\:flex {
        display: flex;
      }
    }
  }

  #shopify-section-{{ section.id }} .product-card {
    .custom-scrollbar {
      scrollbar-width: thin !important;
      scrollbar-color: #c1c1c1 transparent;
    }

    .custom-scrollbar::-webkit-scrollbar {
      height: 8px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background-color: #c1c1c1;
      border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }

    .product-card {
      display: flex;
      flex-direction: column;
    }

    .product-images div {
      aspect-ratio: 3/4;
      max-width: 45%;
      min-width: 45%;
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      background: #BE935F4D;
    }

    .product-images div * {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
    }

    .product-infom {
      text-align: left;
    }

    .variant-button,
    .more-info {
      padding: 1.1vh 2.8rem;
      margin: 0;
      border: 1px solid #000;
      background: none;
      cursor: pointer;
      text-align: center;
    }

    .variant-button.selected {
      background: #BE935F;
      border: 1px solid #BE935F;
    }

    .product-actions {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      min-width: max-content;
      width: 100%;

      && * {
        margin: 0;
        leading: 1;
      }

      a {
        min-width: max-content;
        width: 50%;
        padding: 1.1vh 2rem;
      }

      .buy-btn {
        width: 50%;

        .button {
          min-width: max-content;
          width: 100%;
          padding: 1.1vh 2rem;
          text-align: center;
          background: #BE935F;
          border: 1px solid #BE935F;
          color: #000;
          font-size: 14px;
          font-weight: 700;
          cursor: pointer;
        }
      }
    }
  }
</style>
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

<div class="container page-width mx-auto">
  {% if section.settings.title or section.settings.description %}
    <div class="contentPart flex flex-col items-center justify-center text-center mb-[32px] sm:mb-[px]">
      {% if section.settings.title %}
        {{ section.settings.title }}
      {% endif %}
      {% if section.settings.description %}
        <p class="text-[1.2rem] text-[#000] font-sans font-normal leading-[1.4] max-w-[80%]">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>
  {% endif %}

  <!-- Custom Dot Navigation -->
  <div class="nav-slider w-full scroll-container flex items-center justify-start gap-2">
    {% for block in section.blocks %}
      <div class="custom-dot min-w-[20.75%] sm:min-w-[calc(38%-(1.8rem/2))] gap-[1.8rem]">
        {%- assign nav_video_alt = block.settings.product.title | default: 'Product Video' -%}
        {% assign video_tag_output = block.settings.nav_video
          | video_tag: image_size: '400x', loop: true, controls: false, muted: true, autoplay: true
        %}

        {% capture video_tag_html %}
          {{ video_tag_output | split: '<img ' | first }}
          <img alt = "{{ nav_video_alt }}" loading="lazy"
          {{ video_tag_output | split: '<img ' | last }}
        {% endcapture %}

        {{ video_tag_html }}
      </div>
    {% endfor %}
  </div>

  <!-- Main Center Mode Slider -->

  <main-slider class="hidden relative sm:h-[100vh!important] z-20 sm:w-[100vw!important]">
    <button
      onclick="$('main-slider').css('display', 'none');"
      class="fixed top-[10px] right-[10px] z-20 w-[30px] h-[30px] rounded-full bg-[#fffcfc5e] hover:bg-[#ffffff] transition-all hover:rotate-180 flex items-center justify-center text-[#000!important] font-bold text-[16px] md:text-[14px]"
    >
      {% render 'icon-close' %}
    </button>
    <div class="main-slider flex items-center w-[95vw]  max-h-[98vh] sm:max-h-screen sm:h-full  sm:w-[100vw]">
      {% for block in section.blocks %}
        <div class="slide overflow-hidden sm:aspect-[9/16] p-[0!important] rounded-[0.74vh]">
          <div class="flex sm:flex-col w-full gap-0 h-full items-center">
            <div class="product-video sm:h-full relative aspect-[9/16] w-full max-w-1/2 sm:max-w-full z-0">
              {% comment %} {{
                block.settings.video
                | video_tag: image_size: '500x', loop: true, controls: false, muted: true, autoplay: false
              }} {% endcomment %}

              {%- assign main_video_alt = block.settings.product.title | default: 'Product Video' -%}
              {% assign main_video_output =  block.settings.video
                | video_tag: image_size: '500x', loop: true, controls: false, muted: true, autoplay: false
              %}
      
              {% capture main_video_tag_html %}
                {{ main_video_output | split: '<img ' | first }}
                <img alt = "{{ main_video_alt }}" loading="lazy"
                {{ main_video_output | split: '<img ' | last }}
              {% endcapture %}
      
              {{ main_video_tag_html }}

              <div
                id="overlay-{{ block.id }}"
                class="hidden opacity-0 sm:block absolute top-0 left-0 w-full h-full bg-[#00000080] z-10"
              ></div>
              <div class="absolute top-0 left-0 w-full h-full bg-[#00000060] z-10"></div>
              {% comment %} <label
                for="mute-{{ block.id }}"
                onclick="const video = document.querySelector(`#overlay-{{ block.id }}`).previousElementSibling; video.muted = true; video.setAttribute('muted','true'); const unmuteLabel = this.nextElementSibling;  this.style.display = 'none'; unmuteLabel.style.display = 'flex'; "
                class="speaker absolute top-[10px] sm:top-[calc(100%-185px)] sm:-translate-y-full cursor-pointer right-[10px] sm:right-[14px] z-20 w-[45px] h-[45px] rounded-[8px] bg-[#ffffff] hover:bg-[#f0f0f0] transition-all flex items-center justify-center text-[#000] font-bold text-[12px]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  height="20"
                  width="20"
                  fill="currentColor"
                  stroke="currentColor"
                >
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                </svg>
              </label>
              <label
                for="unmute-{{ block.id }}"
                onclick="const video = document.querySelector(`#overlay-{{ block.id }}`).previousElementSibling; video.muted = false; video.setAttribute('muted','false'); const muteLabel = this.previousElementSibling;  this.style.display = 'none'; muteLabel.style.display = 'flex'; "
                class="speaker absolute top-[10px] sm:top-[calc(100%-185px)] sm:-translate-y-full cursor-pointer right-[10px] sm:right-[14px] z-20 w-[45px] h-[45px] rounded-[8px] bg-[#ffffff] hover:bg-[#f0f0f0] transition-all flex items-center justify-center text-[#000] font-bold text-[12px]"
                style="display: none;"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  height="20"
                  width="20"
                  fill="currentColor"
                  stroke="currentColor"
                >
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line>
                </svg>
              </label> {% endcomment %}
              <a
                href="{{ routes.cart_url }}"
                class="header__icon header__icon--cart link focus-inset absolute hidden sm:top-[calc(100%-175px)] cursor-pointer right-[10px] sm:right-[23px] z-20 w-[45px] h-[45px] rounded-[8px] bg-[#ffffff] hover:bg-[#f0f0f0] transition-all sm:flex items-center justify-center text-[#000] font-bold text-[12px]"
                id="cart-icon-bubble-slider"
                aria-label="{{ 'general.accessibility.cart' | t }}"
              >
                {%- liquid
                  if cart == empty
                    render 'icon-cart-empty'
                  else
                    render 'icon-cart'
                  endif
                -%}
                <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
                {%- if cart != empty -%}
                  <div class="cart-count-bubble">
                    {%- if cart.item_count < 100 -%}
                      <span aria-hidden="true" class="cart-count">{{ cart.item_count }}</span>
                    {%- endif -%}
                    <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
                  </div>
                {%- endif -%}
              </a>

              <input type="radio" id="mute-{{ block.id }}" name="mute-toggle-{{ block.id }}" class="hidden">
              <input type="radio" id="unmute-{{ block.id }}" name="mute-toggle-{{ block.id }}" class="hidden" checked>

              {% assign product = block.settings.product %}

              <div class="hidden sm:block p-[14px]  absolute bottom-[14px] translate-y-[-14px] left-0 w-full max-h-[98px] z-10">
                <div class="flex p-[10px] bg-white rounded-[0.74vh] w-full gap-[22px] items-center justify-between">
                  <div class="flex gap-[11px] w-[70%]">
                    {% comment %}
                      <img
                        src="{{ product.selected_or_first_available_variant.featured_media | image_url: width: 100, height: 100 }}"
                        alt="{{ product.title }}"
                        class="rounded-[0.74vh] w-[55px] h-[55px] object-cover object-center"
                        width="100"
                        height="100"
                      >
                    {% endcomment %}
                    {% assign image_alt = product.selected_or_first_available_variant.featured_media.alt
                      | default: product.title
                    %}

                    {{
                      product.selected_or_first_available_variant.featured_media
                      | image_url: width: product.selected_or_first_available_variant.featured_media.width
                      | image_tag:
                        widths: '320, 480, 768, 1024',
                        class: 'rounded-[0.74vh] w-[55px] h-[55px] object-cover object-center',
                        alt: image_alt,
                        width: product.selected_or_first_available_variant.featured_media.width,
                        height: product.selected_or_first_available_variant.featured_media.height,
                        loading: 'lazy'
                    }}
                    <div class="flex gap-[8px] flex-col items-start justify-center">
                      <h6 class="text-tertiary font-sans text-[12px] font-bold">
                        {{ product.title }}
                      </h6>
                      <p class="weight-price font-sans text-[10px]">
                        <span class="product-weight  text-[10px] font-sans">
                          {% assign weight = product.selected_or_first_available_variant.weight
                            | default: product.weight
                          %}
                          {% assign weight_unit = product.selected_or_first_available_variant.weight_unit %}
                          {% assign weight_divider = product.selected_or_first_available_variant.metafields.custom.weight_divider.value | default: 1 %}
                                  {% case weight_unit %}
                                    {% when 'kg' %}
                                      {% assign weight_in_g = weight | times: 1000 %}
                                    {% when 'lb' %}
                                      {% assign weight_in_g = weight | times: 453.592 %}
                                    {% when 'oz' %}
                                      {% assign weight_in_g = weight | times: 28.3495 %}
                                    {% else %}
                                      {% assign weight_in_g = weight  %}
                                  {% endcase %}
                                  {% assign weight_in_g = weight_in_g | divided_by: weight_divider %}


                                  {% assign weight_in_oz = weight_in_g | divided_by: 28.3495 %}
                          {{ weight_in_g | round: 1 -}}
                          g | {{ weight_in_oz | round: 1 -}}
                          oz {% if weight_divider != 1 %} x{{ weight_divider }}{% endif %} -
                        </span>
                        <span class="product-price text-[10px] font-sans">
                          <del class="text-[#0204034D] mr-[5px]">{{ product.compare_at_price | money }}</del>
                          {{- product.price | money }}
                        </span>
                      </p>
                    </div>
                  </div>
                  <button
                    onclick="document.getElementById('content-{{block.id}}').style.transform = 'translateY(0)';document.getElementById('overlay-{{ block.id }}').style.opacity = '1';"
                    style="font-size:14px!important; padding:5.5px 18px!important;"
                    class="button font-sans max-w-max"
                  >
                    Shop Now
                  </button>
                </div>
              </div>
            </div>
            <div
              id="content-{{block.id }}"
              class="aspect-[9/16] z-[1] sm:bg-[#fff] product-infom h-full sm:before:w-full sm:before:h-[150%] sm:before:bg-[#00000040] sm:absolute sm:bottom-0 sm:left-0 sm:translate-y-[150%] sm:overflow-hidden sm:transition-all w-full max-w-1/2 sm:max-w-full"
            >
              <button
                onclick="document.getElementById('content-{{block.id}}').style.transform = 'translateY(150%)';document.getElementById('overlay-{{ block.id }}').style.opacity = '0';"
                class="absolute hidden sm:flex top-[10px] right-[10px] z-20 w-[30px] h-[30px] rounded-full bg-[#fff] items-center justify-center text-[#000] font-bold text-[16px] md:text-[14px]"
              >
                {% render 'icon-close' %}
              </button>
              <div class="h-full p-[1vh_0_2.2vh_0] sm:p-[0.925vh_0_1.85vh_0] {% capture contentPadding %} px-[2rem] sm:px-[1.6rem] {% endcapture %} w-full">
                {% assign product_form_id = block.id %}
                <div class="product-card relative h-full overflow-visible">
                  <div class="product-images  max-h-[26vh]  {{contentPadding}}  flex scroll-container gap-[1.8rem] overflow-x-[auto!important] custom-scrollbar">
                    {% for media in product.media %}
                      {% if media.id != product.featured_media.id %}
                        <div>
                          {% case media.media_type %}
                            {% when 'image' %}
                              {% comment %}
                                <img
                                  src="{{ media | image_url }}"
                                  alt="{{ media.alt | default: product.title }}"
                                  width="300"
                                  height="300"
                                >
                              {% endcomment %}
                              {% assign image_alt = media.alt | default: product.title %}

                              {{
                                media
                                | image_url: width: media.width
                                | image_tag: widths: '320, 480, 768, 1024', alt: image_alt
                                | default: product.title, width: media.width, height: media.height, loading: 'lazy'
                              }}
                            {% when 'video' %}
                              <video
                                src="{{ media.src }}"
                                controls
                                width="300"
                                height="300"
                                muted

                                loop
                                autoplay
                              ></video>
                            {% when 'model' %}
                              <model-viewer
                                src="{{ media.src }}"
                                alt="{{ media.alt | default: product.title }}"
                                auto-rotate
                                camera-controls
                                style="width: 300px; height: 300px;"
                              ></model-viewer>
                          {% endcase %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                  <div class="product-infom">
                    <div class="product-top">
                      <h3 class="product-title {{contentPadding}} text-tertiary text-[2.4rem] md:text-[16px] sm:text-[16px] font-bold mt-[1.1vh] mb-[0.74vh]">
                        {{ product.title }}
                      </h3>
                      <p class="weight-price {{contentPadding}}">
                        <span class="product-weight text-[1.2rem] font-sans">
                          {% assign weight = product.selected_or_first_available_variant.weight
                            | default: product.weight
                          %}
                          {% assign weight_unit = product.selected_or_first_available_variant.weight_unit %}
                          {% assign weight_divider = product.selected_or_first_available_variant.metafields.custom.weight_divider.value | default: 1 %}
                                  {% case weight_unit %}
                                    {% when 'kg' %}
                                      {% assign weight_in_g = weight | times: 1000 %}
                                    {% when 'lb' %}
                                      {% assign weight_in_g = weight | times: 453.592 %}
                                    {% when 'oz' %}
                                      {% assign weight_in_g = weight | times: 28.3495 %}
                                    {% else %}
                                      {% assign weight_in_g = weight  %}
                                  {% endcase %}
                                  {% assign weight_in_g = weight_in_g | divided_by: weight_divider %}


                                  {% assign weight_in_oz = weight_in_g | divided_by: 28.3495 %}
                          {{ weight_in_g | round: 1 -}}
                          g | {{ weight_in_oz | round: 1 -}}
                          oz {% if weight_divider != 1 %} x{{ weight_divider }}{% endif %} -
                        </span>
                        <span class="product-price text-[12px] font-sans">
                          <del class="text-[#0204034D] mr-[5px]">{{ product.compare_at_price | money }}</del>
                          {{- product.price | money }}
                        </span>
                      </p>
                      <hr class="h-[0.37vh] my-[1.1vh]">
                      <div class="variants-selector flex gap-[1.1vh] flex-col mb-[1.48vh] {{contentPadding}} ">
                        {%- for option in product.options_with_values -%}
                          <div class="variant-selector flex gap-[1.1vh] flex-col ">
                            <label class="capatalize font-sans form__label w-full text-[#000] text-base  md:text-[14px] sm:text-[14px] font-medium leading-9 mb-[0!important]"
                              >Select {{ option.name -}}
                            </label>
                            <div class="flex-nowrap gap-[0.74vh] flex scroll-container variant-options">
                              {% for variant in product.variants %}
                                <button
                                  class="variant-button  font-sans text-[14px] md:text-[12px] font-bold text-[#000] min-w-max  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}"
                                  {% if variant.available == false %}
                                    disabled
                                  {% endif %}
                                  data-compare=" {{ variant.compare_at_price | money }}"
                                  data-price="{{variant.price | money }}"
                                  data-id="{{ variant.id }}"
                                  {% assign weight = variant.weight %}
                                  {% assign weight_unit = variant.weight_unit %}

                                  {% assign weight_divider = variant.metafields.custom.weight_divider.value | default: 1 %}
                                  {% case weight_unit %}
                                    {% when 'kg' %}
                                      {% assign weight_in_g = weight | times: 1000 %}
                                    {% when 'lb' %}
                                      {% assign weight_in_g = weight | times: 453.592 %}
                                    {% when 'oz' %}
                                      {% assign weight_in_g = weight | times: 28.3495 %}
                                    {% else %}
                                      {% assign weight_in_g = weight  %}
                                  {% endcase %}
                                  {% assign weight_in_g = weight_in_g | divided_by: weight_divider %}


                                  {% assign weight_in_oz = weight_in_g | divided_by: 28.3495 %}
                                  

                                  data-weight="{{- weight_in_g | round: 1 -}}g | {{- weight_in_oz | round: 1 -}}oz {%- if weight_divider != 1 -%}{{ ' ' }}x{{- weight_divider -}}{{ ' ' }} {%- endif -%}- "
                                >
                                  {{ variant.title }}
                                </button>
                              {% endfor %}
                            </div>
                          </div>
                        {%- endfor -%}
                      </div>
                    </div>
                    <div
                      class="max-h-[20vh] border-t-[0.37vh] text-base md:text-[14px] sm:text-[14px]  mt-[1.1vh] product-description font-sans leading-[1.4] {{contentPadding}} overflow-hidden text-ellipsis"
                      style="--line-clamp:5; display: -webkit-box; -webkit-line-clamp: var(--line-clamp); -webkit-box-orient: vertical;"
                    >
                      <h3 class="product-title text-tertiary text-[2.4rem]  md:text-[16px] sm:text-[16px] font-bold mb-[0.74vh]">
                        {{ 'products.product.description' | t }}
                      </h3>
                      {{ product.description | strip_html }}
                    </div>
                    <div class="w-full bottom-[-5px] product-bottom absolute left-0">
                      <hr class="h-[0.37vh] my-[1.6vh]">
                      <div class="product-actions gap-[0.74vh] {{contentPadding}}  w-full  flex">
                        <a
                          href="{{ product.url }}"
                          class="more-info font-sans text-[14px] md:text-[12px] font-bold w-1/2"
                          {% comment %} aria-label="More details about {{ product.title | default: 'our mad honey' }}" {% endcomment %}
                          >More info <span class="hidden">about {{ product.title | default: 'our mad honey' }}</span></a
                        >
                        {%- render 'buy-buttons',
                          block: block,
                          product: product,
                          product_form_id: product_form_id,
                          section_id: section.id,
                          show_pickup_availability: true
                        -%}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </main-slider>
</div>

<script
  defer
>
  document.addEventListener('DOMContentLoaded', function () {
    // Handle variant selection
    $('#shopify-section-{{ section.id }} .variant-button').on('click', function () {
      // Update selected variant button
      $('#shopify-section-{{ section.id }} .variant-button').removeClass('selected');
      $(this).addClass('selected');

      // Update product price and weight
      let variantPrice = $(this).data('price');
      let variantId = $(this).data('id');
      let comparePrice = $(this).data('compare');
      let compareWeight = $(this).data('weight');
      let $productInfom = $(this).closest('.product-infom');

      $productInfom.find('.product-weight').html(compareWeight);
      $productInfom.find('.product-price').html(`<del>${comparePrice}</del> ${variantPrice}`);

      let $variantIdInput = $productInfom.find("[name='id']");
      if ($variantIdInput.length) {
        $variantIdInput.val(variantId);
      }
    });

    // Initialize the main slider
    $('#shopify-section-{{ section.id }} .main-slider').slick({
      centerMode: true,
      slidesToShow: 3,
      centerPadding: '3.33vw',
      variableWidth: true,
      slideToScroll: 1,
      focusOnSelect: true,
      draggable: false,
      swipeToSlide: false,
      swipe: false,
      speed: 500,
      dots: false,
      arrows: true,
      responsive: [
        { breakpoint: 1280, settings: { slidesToShow: 1 } },
        { 
          breakpoint: 768, 
          settings: 
          { 
            slidesToShow: 1 ,
            centerMode: true,
            centerPadding: '0',
            variableWidth: false,
            draggable: true,
            swipeToSlide: true,
            arrows: false,
            vertical: true,
            verticalSwiping: true,
            swipe: true,
          } 
        },
      ],
    });


    

    // Custom dot navigation
    $('#shopify-section-{{ section.id }} .custom-dot').on('click', function () {
      let index = $(this).index();
      $('#shopify-section-{{ section.id }} .main-slider').slick('slickGoTo', index);

      let currentVideo = $('#shopify-section-{{ section.id }} .main-slider .slick-current video').get(0);
      if (currentVideo) currentVideo.play();
      if (currentVideo) currentVideo.muted = false;

      $('#shopify-section-{{ section.id }} main-slider').css('display', 'flex');

      // Update active state
      $('#shopify-section-{{ section.id }} .custom-dot').removeClass('active');
      $(this).addClass('active');
    });

    // Update the height of .product-description
    function updateProductDescriptionHeight() {
      let $currentSlide = $('#shopify-section-{{ section.id }} .main-slider .slick-current');
      let currentHeight = $currentSlide.find('.product-card').height();
      let productInfomHeight = currentHeight - $currentSlide.find('.product-images').height();
      let productTopHeight = $currentSlide.find('.product-top').height();
      let productBottomHeight = $currentSlide.find('.product-bottom').height();
      let newDescriptionHeight = productInfomHeight - (productTopHeight + productBottomHeight);
      let fontSize = parseFloat($currentSlide.find('.product-description').css('line-height'));
      let lineClamp = Math.floor(newDescriptionHeight / fontSize);

      $('#shopify-section-{{ section.id }} .main-slider .product-description').css({
        'max-height': `${newDescriptionHeight - 8}px`,
        height: `${newDescriptionHeight - 8}px`,
        '--line-clamp': lineClamp,
        '-webkit-line-clamp': 'var(--line-clamp)',
      });
    }

    // Update custom dots on slide change
    $('#shopify-section-{{ section.id }} .main-slider').on('afterChange', function (event, slick, currentSlide) {
      $('#shopify-section-{{ section.id }} .custom-dot').removeClass('active');
      $('#shopify-section-{{ section.id }} .custom-dot').eq(currentSlide).addClass('active');
    });

    // Call the function on slider initialization and after slide change
    updateProductDescriptionHeight();
    $('#shopify-section-{{ section.id }} .main-slider').on('afterChange', updateProductDescriptionHeight);

    // Handle video playback in the main slider
    $('#shopify-section-{{ section.id }} .main-slider').on('afterChange', function () {
      $('#shopify-section-{{ section.id }} .main-slider .slick-slide video').each(function () {
        this.pause();
      });
      $('#shopify-section-{{ section.id }} .main-slider .slick-current video').each(function () {
        this.play();
        this.muted = false;
      });
    });

    // Loop videos in the navigation slider
    {% comment %} $('#shopify-section-{{ section.id }} .nav-slider video').each(function () {
      let video = this;
      let checkReady = setInterval(function () {
        if (video.readyState >= 2) {
          clearInterval(checkReady);
          setInterval(function () {
            video.currentTime = 0;
            video.play();
          }, 3200);
        }
      }, 100);
    }); {% endcomment %}

    // Pause all videos when the slider is closed
    {% comment %} $('#shopify-section-{{ section.id }} main-slider').on('click', function () {
      $('#shopify-section-{{ section.id }} .main-slider .slick-slide video').each(function () {
        this.pause();
      });
    }); {% endcomment %}

    // Pause all videos when the overlay is clicked
    {% comment %} $('#shopify-section-{{ section.id }} #overlay-{{ block.id }}').on('click', function () { {% endcomment %}
      {% comment %} $('#shopify-section-{{ section.id }} .main-slider .slick-slide video').each(function (video) {
        video.on('click', function () {
        this.pause();
      });
    }); {% endcomment %}

    // Pause all videos when the close button is clicked
    $('#shopify-section-{{ section.id }} .icon-close').on('click', function () {
      $('#shopify-section-{{ section.id }} .main-slider .slick-slide video').each(function () {
        this.pause();
      });
    });

    // Close the slider when clicking outside
    {% comment %} $(document).on('click', function (event) {
      if (
        !$(event.target).closest('#shopify-section-{{ section.id }} .main-slider').length &&
        !$(event.target).closest('#shopify-section-{{ section.id }} .nav-slider').length
      ) {
        $('#shopify-section-{{ section.id }} main-slider').css('display', 'none');
        $('#shopify-section-{{ section.id }} .main-slider .slick-slide video').each(function () {
          this.pause();
        });
      }
    }); {% endcomment %}
  });
</script>
{% schema %}
{
  "name": "Basmil Products Showcase",
  "settings": [
    {
      "type": "html",
      "id": "title",
      "label": "Title",
      "default": "<h1>Premium Product Showcase</h1>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose Product"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Product Video"
        },
        {
          "type": "video",
          "id": "nav_video",
          "label": "Product Short Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Basmil Products Showcase",
      "category": "Custom"
    }
  ]
}
{% endschema %}
