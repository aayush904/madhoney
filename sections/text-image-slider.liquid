
<style>
    #shopify-section-{{ section.id }} .wrapper{
      color:{{ section.settings.content_color }}; 
      padding: {{ section.settings.section_padding }}; 
      margin: {{ section.settings.section_margin }}; 
      background: {% if section.settings.background_type == 'color' %}{{ section.settings.background_color }}{% else %}url('{{ section.settings.background_image | image_url: width: 1920 }}'){% endif %};
      background-size: {{ section.settings.background_size }}; 
      background-position: {{ section.settings.background_position }};
    }

    /* Slider Container */
    #shopify-section-{{ section.id }} .slider-container {
      position: relative;
      width: 100%;
      --width: clamp(20px,2vw,40px);
    }

    /* Custom Arrows */
    #shopify-section-{{ section.id }} .custom-slick-prev,
    #shopify-section-{{ section.id }} .custom-slick-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 0;
      width: var(--width);
      height: var(--width);
      background: rgba(255,255,255,0.4);
      border: 2px solid rgba(255,255,255,0.5);
      border-radius: 50%;
      cursor: pointer;
      display: {% if section.settings.show_arrows %}flex{% else %}none{% endif %} !important;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    #shopify-section-{{ section.id }} .custom-slick-prev:hover,
    #shopify-section-{{ section.id }} .custom-slick-next:hover {
      background: rgba(255,255,255,1);
      transform: translateY(-50%) scale(1.1);
    }

    #shopify-section-{{ section.id }} .custom-slick-prev {
      left: calc((var(--width) + 5px )* -1);
    }

    #shopify-section-{{ section.id }} .custom-slick-next {
      right: calc((var(--width) + 5px )* -1);
    }

    #shopify-section-{{ section.id }} .custom-slick-prev:before {
      content: url('data:image/svg+xml,<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17.0072 1.00533L6.00376 12.0019L17.0003 23.0053" stroke="%234B5441" stroke-width="2"/></svg>');
      color: {{ section.settings.content_color }};
      font-weight: bold;
    }

    #shopify-section-{{ section.id }} .custom-slick-next:before {
      content: url('data:image/svg+xml,<svg  viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7 23L18 12L7 1" stroke="%234B5441" stroke-width="2"/></svg>');
      color: {{ section.settings.content_color }};
      font-weight: bold;
    }

    #shopify-section-{{ section.id }} .slick-arrow:before{
      line-height:0;
      width:8px;
      height:8px;
    }

    /* Dots Styling */
    #shopify-section-{{ section.id }} .slick-dots {
      text-align: center;
      {% comment %} margin-top: 20px; {% endcomment %}
      {% unless section.settings.show_dots %}display: none !important;{% endunless %}
    }

    #shopify-section-{{ section.id }} .slick-dots li button:before {
      color: rgb(190 147 95 / var(--tw-text-opacity));
      opacity: 0.5;
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .slick-dots li.slick-active button:before {
      opacity: 1;
    }

    @media(max-width:768px){
      {% if section.settings.section_padding contains '12rem' %}
        {% assign updated_padding = section.settings.section_padding | replace: '12rem', '6.25rem' %}
         #shopify-section-{{ section.id }} .wrapper.wrapper{
          padding: {{ updated_padding }};
        }
      {% endif %}
      

      #shopify-section-{{ section.id }} .custom-slick-prev:before,
      #shopify-section-{{ section.id }} .custom-slick-next:before {
        font-size: 16px;
      }
    }

    @media(max-width:480px){
      #shopify-section-{{ section.id }} .custom-slick-prev {
        left: -12px;
      }
      #shopify-section-{{ section.id }} .custom-slick-next {
        right: -12px;
      }
    }
</style>

<div
  id="{{section.settings.custom_id}}"
  class="wrapper {{section.settings.custom_class}} text-image-slider p-4 flex items-center justify-center"
  style=""
>
  <div
    class="flex flex-col gap-32 items-center justify-center  sm:max-w-[100%!important] "
    style="width:100%; max-width: {{ section.settings.section_width }}; min-height: {{ section.settings.section_min_height }}"
  >
    <!-- Main Section Heading and Description -->
    <div
      class="main-content mb-8 sm:max-w-[100%!important]"
      style="text-align: {{ section.settings.content_alignment }}; width:100%; max-width: {{ section.settings.content_part_width }}; "
    >
      <h2 class="text-tertiary">{{ section.settings.main_heading }}</h2>
      <p class="text-base mt-2">{{ section.settings.main_content }}</p>
    </div>

    <!-- Slider Container with Arrows -->
    <div class="slider-container" style="width:100%;">
      <!-- Custom Arrows -->
      {% if section.settings.show_arrows %}
      <button type="button" class="custom-slick-prev"></button>
      <button type="button" class="custom-slick-next"></button>
      {% endif %}

      <!-- Slides Container -->
      <div class="slides slick-slider">
        {% for block in section.blocks %}
        <div
          class="
            slide items-center gap-20
          {% if block.settings.image_layout == 'left' %}
             flex-row
          {% elsif block.settings.image_layout == 'right' %}
              flex-row-reverse
          {% elsif block.settings.image_layout == 'top' %}
               flex-col
          {% else %}
              flex-col-reverse
          {% endif %}
             sm:flex-col
          "
          style="display:flex!important;"
        >
          <!-- Slide Image -->
          <div class="slide-image flex-1 justify-center flex items-center h-max max-h-max">
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | default: block.settings.heading }}"
              class="w-full h-auto"
              loading="lazy"
              width="800"
              height="450"
            >
          </div>

          <!-- Slide Content -->
          <div
            class="slide-content flex-1 text-center flex flex-col gap-6"
            style="text-align: {{ block.settings.slider_content_alignment }};"
          >
            <h2 class="text-tertiary ">{{ block.settings.heading }}</h2>
            <h3 class="tracking-[2%] richText" style="color:{{ section.settings.content_color }};">
              {{ block.settings.subheading }}
            </h3>
            <p class="text-base">{{ block.settings.paragraph }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script type="text/javascript" defer>
  document.addEventListener('DOMContentLoaded', function () {
    const sliderSelector = '#shopify-section-{{ section.id }} .slides';
    const prevArrow = '#shopify-section-{{ section.id }} .custom-slick-prev';
    const nextArrow = '#shopify-section-{{ section.id }} .custom-slick-next';
    
    $(sliderSelector).slick({
      infinite: true,
      slidesToShow: 1,
      slidesToScroll: 1,
      arrows: {{ section.settings.show_arrows | json }},
      dots: {{ section.settings.show_dots | json }},
      draggable: true,
      autoplay: {{ section.settings.autoplay | json }},
      autoplaySpeed: 2000,
      speed: 500,
      fade: true,
      cssEase: 'ease',
      pauseOnHover: true,
      prevArrow: $(prevArrow).length ? prevArrow : false,
      nextArrow: $(nextArrow).length ? nextArrow : false,
      appendDots: $(sliderSelector).closest('.slider-container'),
    });
  });
</script>

<!-- Schema remains the same as previous version -->
{% schema %}
{
  "name": "Text Image Slider",
  "class": "text-image-slider",
  "settings": [
    {
      "type": "header",
      "content": "Contents"
    },
    {
      "type": "richtext",
      "id": "main_heading",
      "label": "Section Heading"
    },
    {
      "type": "richtext",
      "id": "main_content",
      "label": "Section Description"
    },
    {
      "type": "header",
      "content": "Slider Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true,
      "info": "Custom styled arrows positioned outside slider"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    },
        {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "content_part_width",
      "label": "Content Part Width",
      "default": "800px"
    },
    {
      "type": "text",
      "id": "section_padding",
      "label": "Section Padding",
      "default": "6rem"
    },
    {
      "type": "text",
      "id": "section_margin",
      "label": "Section Margin",
      "default": "0"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    },
    {
      "type": "text",
      "id": "section_width",
      "label": "Section Width",
      "info": "eg: 50% | 50rem | 50px",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "section_min_height",
      "label": "Section Min Height",
      "default": "500px"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background Type",
      "options": [
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content Color",
      "default": "#000"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background Position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "richtext",
          "id": "paragraph",
          "label": "Paragraph"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_layout",
          "label": "Image Layout",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            },
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "slider_content_alignment",
          "label": "Content Alignment",
          "default": "center",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text Image Slider",
      "category": "Custom",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}