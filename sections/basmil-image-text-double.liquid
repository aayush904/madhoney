{% stylesheet %}
  /*.doubletextimage-wrapper  */
  .doubletextimage-wrapper {
    padding-top: 3.2rem;
    padding: 0;
  }
  .doubletextimage-wrapper h1 {
    color: rgba(190, 147, 95, 1);
    padding-top: 8rem;
    font-size: 4.8rem;
    font-weight: 700;
    text-align: center;
    font-family: 'Crimson Text', serif;
  }
  /* Flag container section */
  .doubletextimage-wrapper .flag {
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    align-items: center;
  }

  .doubletextimage-wrapper .flag-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4.8rem;
    width: 100%;
    max-width: 144rem;
    margin: auto;
  }

  .doubletextimage-wrapper .flag-content-wrapper {
    width: 100%;
    padding: 6rem 1.6rem;
  }

  .doubletextimage-wrapper .flag-content-wrapper:nth-child(2n) {
    background-color: rgba(241, 229, 207, 1) !important;
  }

  .doubletextimage-wrapper .flag-row:nth-child(2n) .flag-info {
    background-color: rgba(241, 229, 207, 1) !important;
  }

  .doubletextimage-wrapper .flag-row:nth-child(2n-1) .flag-info {
    background-color: transparent !important;
  }
  .doubletextimage-wrapper .flag-container {
    display: flex;
    align-items: start;
    text-align: justify;
    gap: 2.4rem;
    height: 35.3rem;
    background-color: transparent;
    position: relative;
  }

  .doubletextimage-wrapper .flag-info {
    width: 50.28%;
    background-color: transparent;
  }

  .doubletextimage-wrapper .flag-info h4 {
    font-family: 'Crimson Text', serif;
    font-size: 2.4rem;
    font-weight: 600;
  }

  .doubletextimage-wrapper .flag-info ul {
    margin-top: 1.6rem;
    list-style: disc;
    margin-left: 1.25em;
    padding-left: 0;
    line-height: 1.5;
  }

  .doubletextimage-wrapper .flag-svg {
    position: relative;
    width: 46.26%;
    height: 30.6rem;
    background-color: rgba(255, 255, 255, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .doubletextimage-wrapper .flag-svg svg {
    width: 23rem;
  }

  @media (max-width: 1230px) {
    .doubletextimage-wrapper .flag-container {
      display: flex;
      flex-direction: column-reverse;
      align-items: center;
      text-align: justify;
      gap: 2.4rem;
      height: auto;
      padding: 1.6rem;
    }
    .doubletextimage-wrapper .flag-content-wrapper:nth-child(2n),
    .doubletextimage-wrapper .flag-content-wrapper:nth-child(2n-1),
    .doubletextimage-wrapper .flag-row:nth-child(2n),
    .doubletextimage-wrapper .flag-row:nth-child(2n-1) {
      background-color: transparent !important;
    }
    .doubletextimage-wrapper .flag-info {
      justify-content: center;
      flex: 2;
      margin-top: 0;
      font-size: 1.8rem;
      line-height: 1.5;
    }
    .doubletextimage-wrapper .flag-info h3 {
      text-align: center !important;
      gap: 4.8rem;
      font-family: 'Crimson Text', serif;
    }
    .doubletextimage-wrapper .flag-info ul {
      text-align: left !important;
    }
    .doubletextimage-wrapper .flag-svg {
      flex: 1;
      font-size: 1.8rem;
      width: 40rem;
      height: 80rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: rgba(255, 255, 255, 1) !important;
      margin: 0 auto;
    }
    .doubletextimage-wrapper .flag-svg svg {
      object-fit: contain;
      object-position: center;
      width: 45rem;
      height: 35rem;
      max-width: 50%;
      max-height: 50%;
    }
  }

  @media (max-width: 768px) {
    .doubletextimage-wrapper .banner .default-svg {
      display: none;
    }

    .doubletextimage-wrapper .banner .mobile-svg {
      display: block;
    }

    .doubletextimage-wrapper .doubletextimage-wrapper h1 {
      font-size: 2.4rem !important;
      padding-top: 2.4rem !important;
    }

    .doubletextimage-wrapper .flag-row {
      grid-template-columns: repeat(1, 1fr);
    }
    .doubletextimage-wrapper .flag-container {
      flex-direction: column;
      align-items: center;
      text-align: left;
      height: auto;
    }
    .doubletextimage-wrapper .flag-svg {
      order: -1;
      width: 100%;
      height: auto;
      /* padding: 7.0rem 4.0rem 6.5rem 4.0rem; */
      margin-top: 1.2rem;
    }
    .doubletextimage-wrapper .flag-info {
      width: 100%;
    }
    .doubletextimage-wrapper .flag-info h3 {
      font-size: 2.4rem;
      font-weight: 600;
      text-align: left !important;
      margin-bottom: 0.8rem !important;
    }
    .doubletextimage-wrapper .flag-info ul {
      font-size: 1.2rem !important;
      font-weight: 300;

      font-family: 'Work Sans';

      line-height: 1.408rem;
      letter-spacing: 0.02em;
      text-align: justified;
      text-underline-position: from-font;
      text-decoration-skip-ink: none;
    }
    .doubletextimage-wrapper .flag-svg svg {
      width: 71.42%;
      object-fit: contain;
      object-position: center;
    }
    .doubletextimage-wrapper .flag-content-wrapper:nth-child(2n),
    .doubletextimage-wrapper .flag-content-wrapper:nth-child(2n-1),
    .doubletextimage-wrapper .flag-row:nth-child(2n),
    .doubletextimage-wrapper .flag-row:nth-child(2n-1) {
      background-color: transparent !important; /* Override with no background */
    }

    .text-section {
      max-width: 100%;
      text-align: left;
      margin-top: 0;
      order: 0;
    }

    .image-section {
      order: -1;
      width: 100%;
      height: auto;
    }
    .doubletextimage-wrapper .flag-content-wrapper {
      padding: 0 !important;
    }
    .doubletextimage-wrapper .flag-row {
      gap: 0 !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Basmil Image Text Double",
  "class": "basmil-image-text-double-container",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Title"
    },
    {
      "type": "richtext",
      "label": "Description",
      "id": "description"
    },
    {
      "type": "header",
      "content": "Class/ID"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "text",
      "id": "section_class",
      "label": "Section Class"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Add images and text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "select",
          "id": "image_type",
          "label": "Image Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "svg",
              "label": "SVG"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "html",
          "id": "svg",
          "label": "SVG Code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Basmil Image Text Double"
    }
  ]
}
{% endschema %}
