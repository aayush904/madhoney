<div class="doubletextimage-wrapper {{ section.settings.section_class }}" id="{{ section.settings.section_id }}">
  {% if section.settings.title != blank and section.settings.description != blank %}
    <div class="flex flex-col gap-[3.2rem] justify-center items-center">
      {% if section.settings.title != blank %}
        <h1>{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.description != blank %}
        <p>{{ section.settings.description }}</p>
      {% endif %}
    </div>
  {% endif %}
  <div class="flag">
    {% assign blocks = section.blocks %}
    {% for block in blocks %}
      {% assign order = forloop.index0 | modulo: 2 %}
      {% if forloop.first or order == 0 %}
        <div class="flag-content-wrapper">
          <div class="flag-row">
      {% endif %}

      <div class="flag-container">
        <div
          class="flag-info"
          {% if block.settings.svg != blank or block.settings.image != blank %}
          {% else %}
            style="width:100%;"
          {% endif %}
        >
          {{ block.settings.content }}
        </div>
        {% if block.settings.svg != blank or block.settings.image != blank %}
          <div class="flag-svg">
            {% if block.settings.image_type == 'image' %}
              <img
                src="{{ block.settings.image | image_url }}"
                width="{{ block.settings.image.width}}"
                height="{{ block.settings.image.height}}"
                alt="{{ block.settings.image.alt |  default: "flag"  }}"
              >
            {% else %}
              {{ block.settings.svg }}
            {% endif %}
          </div>
        {% endif %}
      </div>
      {% assign order2 = forloop.index0 | modulo: 2 %}

      {% if order2 == 1 or forloop.last %}
        </div>
        </div>
      {% endif %}
    {% endfor %}

    {% comment %}
      <div class="flag-content-wrapper">
