<section
  class="flex flex-col justify-center mx-auto py-8  {{ section.settings.custom_class }}"
  id="{{ section.settings.custom_id }}"
  style="
      gap: {{ section.settings.gap_between_sections }};
    padding: {{ section.settings.padding }};
    margin: {{ section.settings.margin }};
    max-width: {{ section.settings.width }};
    width:100%;
    min-height: {{ section.settings.min_height }};
    {% if section.settings.background_type == 'Color' %}
      background-color: {{ section.settings.background_color }};
    {% elsif section.settings.background_type == 'Image' %}
      background-image: url('{{ section.settings.background_image | img_url: 'master' }}');
      background-position: {{ section.settings.background_position }};
      background-size: {{ section.settings.background_size }};
    {% endif %}
  "
>
  {% if section.settings.heading or section.settings.description %}
    <div style="width: {{ section.settings.content_part_width }}; text-align: {{ section.settings.content_alignment }};">
      {% if section.settings.heading %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description %}
        <p>{{ section.settings.description }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div
    class="image-column-layout flex justify-between flex-wrap sm:justify-center sm:gap-[2rem!important]"
    style="gap: calc({{ section.settings.image_gap}} - 1rem);"
  >
    {% for block in section.blocks %}
      {% comment %} <div class="break-inside-avoid"> {% endcomment %}
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | img_url: 'master' }}"
          alt="{{ block.settings.image.alt }}"
          class="w-full h-full sm:max-w-[25vw!important] sm:max-h-[25vw!important] object-center "
          style="max-width: {{ section.settings.wimage_size }}; max-height: {{section.settings.himage_size }}; "
          width="300"
          height="300"
        >
      {% endif %}
      {% comment %} </div> {% endcomment %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Images Grid Basmil",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "default": "Left",
      "options": [
        {
          "value": "Left",
          "label": "Left"
        },
        {
          "value": "Center",
          "label": "Center"
        },
        {
          "value": "Right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "text",
      "id": "content_part_width",
      "label": "Content Part Width",
      "default": "50%"
    },
    {
      "type": "text",
      "id": "gap_between_sections",
      "label": "Gap Between Content and Image Grid",
      "default": "5.4rem"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Number of columns",
      "default": 3,
      "step": 1,
      "min": 1,
      "max": 5
    },
    {
      "type": "text",
      "id": "wimage_size",
      "label": "Image width with unit (px, rem, em, etc.)",
      "default": "20rem"
    },
    {
      "type": "text",
      "id": "himage_size",
      "label": "Image height with unit (px, rem, em, etc.)",
      "default": "20rem"
    },
    {
      "type": "select",
      "id": "object_fit",
      "label": "Image Object Fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "fill",
          "label": "Fill"
        },
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "scale-down",
          "label": "Scale Down"
        }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "image_gap",
      "label": "Gap between images with unit (px, rem, em, etc.)",
      "default": "10rem",
      "info": "This is the gap between images in the grid."
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "default": "16px 16px 16px 16px"
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "default": "16px 16px 16px 16px"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    },
    {
      "type": "text",
      "id": "width",
      "label": "Section Width",
      "default": "100rem"
    },
    {
      "type": "text",
      "id": "min_height",
      "label": "Section Height",
      "default": "100rem"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background Type",
      "default": "Color",
      "options": [
        {
          "value": "Color",
          "label": "Color"
        },
        {
          "value": "Image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background Position",
      "default": "Center",
      "options": [
        {
          "value": "Center",
          "label": "Center"
        },
        {
          "value": "Top",
          "label": "Top"
        },
        {
          "value": "Bottom",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "default": "cover",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Choose Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Images Grid Basmil",
      "category": "Custom"
    }
  ]
}
{% endschema %}
