{% assign sections = section.settings %}

<style>
    #shopify-section-{{ section.id }} .video-thumbnail-container {
      position: relative;
      cursor: pointer;
    }


    #shopify-section-{{ section.id }} .wrapper{
      margin:{{sections.margin}}; padding: {{sections.padding}};
      {% if sections.background_type == 'color' %}
        background: {{ sections.background_color }};
      {% elsif sections.background_type == 'image' %}
        background: url('{{ sections.background_image  | image_url }}') no-repeat {{ sections.background_position }};
        background-size: {{ sections.background_size }};
      {% endif %};
    }

    #shopify-section-{{ section.id }}  .video-thumbnail {
      position: relative;
      display: inline-block;
    }

    #shopify-section-{{ section.id }}  .video-thumbnail-img {
      width: 100%;
      height: auto;
      display: block;
    }

    #shopify-section-{{ section.id }}  .play-button {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      /* background: rgba(0, 0, 0, 0.7); */
      color: white;
      border: none;
      font-size: 2rem;
      padding: 1rem;
      /* border-radius: 50%; */
      cursor: pointer;
    }

    #shopify-section-{{ section.id }}  .lightbox {
      display: none;
      position: fixed;
          justify-content: center;
          align-items: center;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      max-height:100vh;
      max-width:100vw;
      background: rgba(0, 0, 0, 0.8);
      z-index: 1000;
    }

    #shopify-section-{{ section.id }}  .lightbox-content {
      position: relative;
      width: 100%;
      max-width: 100%;
      max-height: 100vh;
      margin: 5% auto;
      background: #000;
      {% comment %} padding: 1rem; {% endcomment %}
    }

    #shopify-section-{{ section.id }}  .close-button {
      position: absolute;
      top: 15px;
      right: 20px;
      scale: 2;
      font-size: 2rem;
      cursor: pointer;
    }

    #shopify-section-{{ section.id }}  .lightbox-video-container {
      width: 100%;
      height: 0;
      padding-bottom: 56.25%;
      /* 16:9 Aspect Ratio */
      position: relative;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .lightbox-video-container iframe,
    #shopify-section-{{ section.id }} .lightbox-video-container video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    @media (max-width: 1200px) {
      #shopify-section-{{ section.id }} .main-wrapper {
        max-width: 116.6rem !important;
      }
    }

    @media (max-width: 768px) {
      #shopify-section-{{ section.id }} .main-wrapper {
        padding-left: 0 16px 4rem 16px !important;
        max-width: 100% !important;
      }
    }

    @media(max-width:768px){
      {% if sections.padding contains '12rem' %}
        {% assign updated_padding = sections.padding | replace: '12rem', '6.25rem' %}
      {% elsif sections.padding contains '15rem' %}
        {% assign updated_padding = sections.padding | replace: '15rem', '56px' %}
      {% else %}
        {% assign updated_padding = sections.padding %}
      {% endif %}
      #shopify-section-{{ section.id }} .wrapper.wrapper{
      padding: {{ updated_padding }};
    }
  }
</style>

