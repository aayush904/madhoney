{% for block in section.blocks %}
  {% case block.type %}
    {% when 'content' %}
      {% capture contents %}
        {% if block.settings.title != blank %}
          <h2 class="text-tertiary -mb-[1.7rem] {{sections.alignment}} sm:text-center">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="{{sections.alignment}} sm:text-center">{{ block.settings.description }}</div>
        {% endif %}
        {% if block.settings.button_text != blank%}
          <a class="{{sections.alignment}} button border-none  justify-center sm:text-center" href="{{ block.settings.button_link }}">
            {{- block.settings.button_text -}}
          </a>
        {% endif %}
        {% if videoButton and section.settings.show_play_button_on =='content' %}
          {{ videoButton }}
        {% endif %}
      {% endcapture %}

    {% when 'video' %}
      {%- capture sizes -%}
        {% if section.settings.full_width -%}
          100vw
        {%- else -%}
          (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 769px)
          calc(100vw - 10rem), 100vw
        {%- endif %}
      {%- endcapture -%}

      {% capture video %}
        {% comment %} {% assign video_url =  %} {% endcomment %}
