                    </svg>
                    </button>
                    {% endif %}
                </div>
            {% endif %}
        
          {% elsif block.settings.video_type == 'self_hosted' %}
            {% if block.settings.video_controls == "true" %}
              {% if block.settings.video %}
                <!-- Thumbnail and Play Button -->
                <div class="video-thumbnail  w-full" >
