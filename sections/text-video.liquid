                       </svg>
                     </button> 
                    {% endif %}
                </div>
              {% endif %}
            {% else %}
              {% assign videoMp = '' %}

              {% assign videoId =  'video-' | append:block.id  %}

              {% comment %} <video class="video " 
                {% comment %} style="display:none;" {% endcomment %}
                  id="video-{{ block.id }}" autoplay='false' preload="auto" muted playsinline loop width="100%" height="100%"  poster="{{ block.settings.video_thumbnail | image_url: width:800 }}">
                
                 <!-- <source src="{{block.settings.video.sources[0].url}}" type="video/m3u8"> -->
              {% if block.settings.video != blank %}
                {% for  source in block.settings.video.sources %}
                  {% if source.url contains  '.mp4' %}
                    <source src="{{ source.url }}" type="video/mp4">
                    {% assign videoMp = source.url %}
                    
                  {% else %}
                    <source src="{{ source.url }}" type="video/m3u8">
                  {% endif %}
                  Your browser does not support the video tag.
                {% endfor %}
              {% else %}
                <source src="{{ 'home-video.mp4' | asset_url }}" type="video/mp4">
                   
              {% endif %}
              </video> {% endcomment %}
              {%  if block.settings.video_thumbnail != blank %}
                {% assign poster = block.settings.video_thumbnail | image_url: width:800 %}
              {% else %}
                {% assign poster = block.settings.video.video_thumbnail | image_url: width:800 %}
              {% endif %}
              {% assign video_tag_output = block.settings.video | video_tag: image_size: '80x', class:'video', id: videoId, 
                poster: poster,
                 loop:true, controls: false, muted: true, autoplay:
                true, width: 1920, height: 968, loading: 'lazy',
                widths: '750, 1100, 1500, 1780, 2000, 3000, 3840' %}
                

                {% capture video_tag_html %}
                  {{ video_tag_output | split: '<img ' | first }}
                  <img loading="lazy" alt = "{{ block.settings.video_thumbnail.alt | default: 'video thumbnail' }}" 
                  {{ video_tag_output | split: '<img ' | last }}
                {% endcapture %}
        
                {{ video_tag_html }}
                
                                       {% if template.name == 'index' %}
                <script type="application/ld+json">
                  {
                    "@context": "https://schema.org",
                    "@type": "VideoObject",
                    "name": "{{ block.settings.video_title | default: 'Beyond The Cliffs: The Unseen Story of Himalayan Mad Honey Hunters' }}",
                    "description": "{{ block.settings.video_description | default: 'Get ready to embark on a thrilling journey with our brave Gurung honey hunters as they venture into the heart of the Himalayas to collect the rare and precious mad honey. This captivating video takes you behind the scenes of a world far away, where ancient traditions meet modern-day challenges.' }}",
                    "thumbnailUrl": "{{ block.settings.video_thumbnail | image_url }}",
                    "uploadDate": "{{ block.settings.upload_date | default: '2024-12-01T00:00:00+05:45' }}",
                    "contentUrl": {{ 'home-video.mp4' | asset_url | json}},
                    "embedUrl": {{ block.settings.youtube_url | json}},
                    "duration": "{{ block.settings.video_duration | default: 'PT0M9S' }}",
                    "publisher": {
                      "@type": "Organization",
                      "name": {{ shop.name | json }},
                      "logo": {
                        "@type": "ImageObject",
                        "url": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }}
                      }
                    },
                    "isFamilyFriendly": "{{ block.settings.is_family_friendly | default: 'true' }}"
                  }
                </script>
              {% endif %}
              {% comment %} {% if block.settings.video_thumbnail != blank %}
                  <img class="video relative top-0 left-0 z-0" id="image-{{ block.id }}" src="{{ block.settings.video_thumbnail | image_url: width:800 }}" width="500" height="500" alt="Hero banner" />
                   <script defer="defer">
                    // Wait until the window is fully loaded
                    window.addEventListener('load', function() {
                      const video = document.querySelector('#video-{{ block.id }}'); 
                      const placeholder = document.querySelector('#image-{{ block.id }}'); 
                      video.style.position = 'relative';
                      
                      video.setAttribute('autoplay', 'true'); 
                      video.load(); 
                      setTimeout(
                        ()=>{                      
                      placeholder.remove();
                      video.style.display = 'block';
                        },2000)
                    });
                  </script> 
                {% endif %} {% endcomment %}

            {% endif %}
          {% endif %}
        </div>
        <!-- Lightbox Modal -->
        <div class="lightbox" id="video-lightbox-{{ section.id }}">
          <div class="lightbox-content">
            <span class="close-button z-10 text-tertiary">&times;</span>
            <div class="lightbox-video-container">
              <!-- Video will be dynamically inserted here -->
            </div>
          </div>
        </div>
      {% endcapture %}
  {% endcase %}
{% endfor %}

<div
  {% if sections.custom_id %}
    id="{{ sections.custom_id }}"
  {% endif %}
  class="main-wrapper wrapper flex justify-center w-full {{ sections.custom_class }}"
  style="max-width:{{ sections.width }};"
>
  <div
    class="
      relative
      flex {{ sections.layout }} flex-nowrap {{sections.alignment}} justify-between w-[100%] gap-[5.3rem] sm:gap-[4rem] sm:flex-col sm:justify-center sm:text-center sm:items-center
      {% if sections.valignment == 'center '%} items-center {% elsif sections.valignment == 'start' %} items-start {% elsif sections.valignment == 'end' %} items-end {% endif %}
    "
  >
    {% if contents != blank %}
      <div
        class="content-side flex {{sections.alignment}} gap-[3.2rem] flex-col items-start max-w-1/2 sm:max-w-[100%!important] sm:text-center sm:items-center w-full "
        style="max-width:{{ sections.content_width }};"
      >
        {{ contents }}
      </div>
    {% endif %}
    {{ video }}
  </div>
</div>

<script
  defer="defer"
>
  document.addEventListener('DOMContentLoaded', function () {
    var sectionId = document.querySelector('#shopify-section-{{ section.id }}');
    var lightbox = document.getElementById('video-lightbox-{{ section.id }}');
    var closeButton = lightbox.querySelector('.close-button');
    var videoContainer = lightbox.querySelector('.lightbox-video-container');

    sectionId.querySelectorAll('.play-button').forEach((button) => {
      button.addEventListener('click', function () {
        var videoType = this.getAttribute('data-video-type');
        let videoEmbed = '';
        if (videoType === 'youtube') {
          var videoId = this.getAttribute('data-video-id');
          videoEmbed = `<iframe width="100%" height="100%" src="https://www.youtube.com/embed/${videoId}?autoplay=1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
        } else if (videoType === 'self_hosted') {
          var videoSrc = this.getAttribute('data-video-src');
          videoEmbed = ` <video class="video" controls autoplay width="100%" height="100%"><source src="${videoSrc}" type="video/mp4">Your browser does not support the video tag.</video>`;
        }

        videoContainer.innerHTML = videoEmbed;
        lightbox.style.display = 'flex';
      });
    });

    closeButton.addEventListener('click', function () {
      lightbox.style.display = 'none';
      videoContainer.innerHTML = '';
    });
  });
</script>

