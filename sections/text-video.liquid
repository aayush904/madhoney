                    src="{{ block.settings.video_thumbnail | image_url }}" 
                    alt="{{ block.settings.video_thumbnail.alt | default: 'video thumbnail' }}" class="video-thumbnail-img" width="500" height="500">

                    {% if videoButton and section.settings.show_play_button_on =='image' %}
                      <button class="play-button top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" data-video-type="self_hosted" data-video-src="{{ block.settings.video.sources[1].url }}"><svg style="width:7.9rem; height:6.4rem" viewBox="0 0 79 64" fill="none" xmlns="http://www.w3.org/2000/svg">
