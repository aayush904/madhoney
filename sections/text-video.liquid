                <div class="video-thumbnail w-full relative">
                  <div class="absolute image-overlay bg-[#00000060] top-0 left-0 w-full h-full empty:block"></div>

                  {% assign video_id = block.settings.youtube_url | split: '/' | last %}
                        

                        {% if video_id contains 'v=' %}
                            {% assign video_id = video_id | split: 'v=' | last %}
                            {% if video_id contains '&' %}
                              {% assign video_id = video_id | split: '&' | first %}
                            {% endif %}
                        {% elsif   video_id contains 'shorts/' %}
                          {% assign video_id = video_id | split: 'shorts/' | last %}
                        {% endif %}
                        
                    {% if block.settings.video_thumbnail != blank %}
                        <img 
                          loading="lazy"                          
                          src="{{ block.settings.video_thumbnail | image_url }}" 
                          alt="Video Thumbnail" class="{{ block.settings.video_thumbnail.alt | default: 'video-thumbnail-img'}}" width="500" height="500">
                    {% else %}
                        
