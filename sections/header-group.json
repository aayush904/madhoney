          "settings": {
            "image": "shopify://shop_images/BLACKFRIDAY_BANNER.webp",
            "title": "<style>\n#shopify-section-{{section.id}} .popup-image{\nmax-height:100%;\n}\n#shopify-section-{{section.id}} .popup-image img{\npadding:0;\n}\n#shopify-section-{{section.id}} .popup-text{\nposition:absolute;\nwidth:100%;\nbottom:20.5%;\npadding:0;\n}\n#shopify-section-{{section.id}} .popup-text *:not(.h2 *):not(.h2){\ndisplay:none;\n}\n\n#shopify-section-{{section.id}} .popup-content{\nheight:auto;\nwidth:clamp(320px, 30vw, 55rem);\nmargin:0;\nmax-height:auto;\nmax-width:calc(100dvw - 32px);\n}\n\n#shopify-section-{{section.id}} .coupon_pop.popup-overlay{\nalign-items:center;\njustify-content:center;\n}\n\n#shopify-section-{{section.id}}  .close-button{\nbackground:transparent;\ncolor:#fff;\nmax-width:24px;\npadding:0;\n}\n#shopify-section-{{section.id}} .popup-text b{\nwidth:100%;\nmargin-right:6px;\n}\n#shopify-section-{{section.id}} timer{\nwidth: 61%;\nmargin: auto;\njustify-content: space-between;\ndisplay: flex;\n}\n\n#shopify-section-{{section.id}}  box{\ncolor:#000;\nwidth: 22%;\nfont-family:\"Lato\";\nfont-size:clamp(32px,3.8dvw, 56px);\nfont-weight:700;\naspect-ratio:7/10;\nheight:100%;\ndisplay:flex;\njustify-content:center;\nalign-items:center;\nfilter: drop-shadow(2px 4px 4px #00000080);\nposition:relative;\n}\n\n#shopify-section-{{section.id}}  box:before{\nfilter: drop-shadow(0px 0px 0px #00000001);\n\ncontent:attr(data-content);\nfont-size:clamp(8px,1dvw, 12px);\nposition:absolute;\ntop:3%;\nmargin-left:2px;\nwidth:100%;\ntext-align:center;\n}\n\n#shopify-section-{{section.id}}  box:nth-child(3){\nmargin-left:10px;\n}\n</style>\n<timer>\n  <box id=\"dh1\"></box><box id=\"dh2\"></box>\n  <box id=\"hm1\"></box><box id=\"hm2\"></box>\n</timer>",
            "message": "<script>\n  var eventDate = new Date('2025-11-28T00:00:00-08:00');\n  function pad2(n) { return n.toString().padStart(2, '0'); }\n\n    function updateTimer() {\n    var now = new Date();\n    var diffMs = eventDate - now;\n    if (diffMs < 0) diffMs = 0;\n\n    var totalSec = Math.floor(diffMs / 1000);\n    var totalMin = Math.floor(totalSec / 60);\n    var totalHr  = Math.floor(totalMin / 60);\n    var totalDay = Math.floor(totalHr  / 24);\n\n    var dh1 = document.getElementById('dh1');\n    var dh2 = document.getElementById('dh2');\n    var hm1 = document.getElementById('hm1');\n    var hm2 = document.getElementById('hm2');\n    \n    const updateBoxes = (a,b,c,d,x,y) => {\n      dh1.textContent = a;\n      dh1.dataset.content = x;\n      \n      dh2.textContent = b;\n      dh2.dataset.content = x;\n      \n      hm1.textContent = c;\n      hm1.dataset.content = y;\n      \n      hm2.textContent = d;\n      hm2.dataset.content = y;\n    }\n    \n    if (totalDay > 0) {\n      var dayStr = pad2(totalDay);\n      var hrStr = pad2(totalHr % 24);\n      updateBoxes(dayStr[0], dayStr[1], hrStr[0], hrStr[1], \"Days\",\"Hours\");\n    } else if (totalHr > 0) {\n      var hrStr = pad2(totalHr);\n      var minStr = pad2(totalMin % 60);\n      updateBoxes(hrStr[0], hrStr[1], minStr[0], minStr[1], \"Hours\", \"Minutes\");\n    } else {\n      var minStr = pad2(totalMin);\n      var secStr = pad2(totalSec % 60);\n      updateBoxes(minStr[0], minStr[1], secStr[0], secStr[1], \"Minutes\", \"Seconds\");\n    }\n  }\n  setInterval(updateTimer, 1000);\n</script>",
            "code": ""
          }
