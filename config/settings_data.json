      "careers": {
        "type": "careers",
        "settings": {
          "title": "We’re hiring positions",
          "description": "<p>At Medicinal Mad Honey, we are more than just a honey brand, we are a community rooted company dedicated to bringing the ancient himalayan honey to the world. Our mission is to reconnect the world with the healing wonders of the Himalayas through ethically sourced, wild-harvested mad honey and other honey based products.</p><p>If you're passionate about export, sustainability, and creating global impact from local roots  we’d love to have you be part of our journey.</p>",
          "image": "shopify://shop_images/Mask_group_c067a64d-5e22-42db-89ce-9eb9068755a6.webp",
          "mail": "<p> </p><h2><strong>How to Apply</strong></h2><p>Ready to be a part of the Medicinal Mad Honey family?</p><p>Send your resume and a cover letter outlining your experience and why you want to be part of our team to <a href=\"mailto:contact@medicinalmadhoney.com \" target=\"_blank\" title=\"Mail Medicinal Mad Honey\">contact@medicinalmadhoney.com </a></p><p>We’re excited to hear from you and grow together. </p>",
          "follow": "<p><strong> </strong></p><h2><strong>Connect with Us</strong></h2><p>Follow us on social media to stay updated on the latest job openings and company news: </p>"
        }
      }
    },
