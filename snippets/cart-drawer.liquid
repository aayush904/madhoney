{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}
  <script src="{{ 'selling-plans.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }

  #CartDrawer-Checkout {
    max-height: 44px;
    margin-top: 0 !important;
  }

  .express-checkout.express-checkout,
  shopify-paypal-button,
  .wallet-cart-grid,
  .wallet-cart-button-container {
    width: 100%;
    display: block;
    margin: 0 !important;
  }

  .base.base.base {
    color: #664e36;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer w-[34.48%] sm:w-full" style="max-width:370px">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    <div
      class="drawer__inner h-screen overflow-hidden"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div
            style="justify-content:space-between"
            class="cart-drawer__warnings  py-[3rem] pb-[1rem] center {% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}"
          >
            <div class="flex justify-center relative pb-[1.4rem] border-b border-[#0000001A] ">
              <b class="base text-center font-bold h2" style="color:#664E36;"> 
                {{ 'sections.cart.title' | t }}
              </b>

              <button
                class="absolute top-0 right-0 p-4 -translate-y-1/4"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <svg
                  width="12"
                  height="13"
                  viewBox="0 0 12 13"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M11 1.5L1 11.5"
                    stroke="#664E36"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path
                    d="M1 1.5L11 11.5"
                    stroke="#664E36"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
              </button>
            </div>
            <div class="cart-drawer__empty-content flex flex-col gap-[0.8rem]">
              <b class="base text-[#0000004D] font-sans uppercase">{{ 'sections.cart.empty' | t }}</b>
              <b class="text-[1.2rem] xl:text-[1.4rem]">Add your favorite item to your cart.</b>
              {% comment %} <button class="drawer__close hidden" type="button" onclick="this.closest('cart-drawer').close()" aria-label="{{ 'accessibility.close' | t }}" > {% render 'icon-close' %} </button> {% endcomment %}

              {% comment %}
                 {%- if shop.customer_accounts_enabled and customer == null -%}
                  <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                  <p class="cart__login-paragraph">
                    {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                  </p>
                {%- endif -%}
              {% endcomment %}
              <a
                href="{{ routes.all_products_collection_url }}"
                class="text-[1.4rem] font-sans xl:text-[1.6rem] sm:text-[1.8rem] mt-[1.6rem] text-[#00A3FF] flex gap-[8px] items-center justify-center"
              >
                SHOP NOW
                <svg width="14" height="9" viewBox="0 0 14 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13.4764 4.85355C13.6716 4.65829 13.6716 4.34171 13.4764 4.14645L10.2944 0.964466C10.0991 0.769204 9.78253 0.769204 9.58727 0.964466C9.39201 1.15973 9.39201 1.47631 9.58727 1.67157L12.4157 4.5L9.58727 7.32843C9.39201 7.52369 9.39201 7.84027 9.58727 8.03553C9.78253 8.2308 10.0991 8.2308 10.2944 8.03553L13.4764 4.85355ZM0 5H13.1228V4H0V5Z" fill="#00A3FF"/>
                </svg>
              </a>
            </div>
            {% if cart == empty %}
              <a href="{{ routes.all_products_collection_url }}" class="button py-[1.6vh] border-b border-[#0000001A]">
                {{ 'general.continue_shopping' | t }}
              </a>
            {% endif %}
          </div>

          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% comment %} {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %} {% endcomment %}
            </div>
          {%- endif -%}

          {% render 'cart-drawer-cross-sell', csell_collections: settings.cart_drawer_collection %}
        </div>
      {%- endif -%}

      {% if cart != empty %}
        <div class="flex justify-center relative pb-[1.4rem] border-b border-[#0000001A] ">
          <b class="base text-center text-[#664E36!important] font-bold">
            {{ 'sections.cart.title' | t }}
          </b>

          <button
            class="absolute top-0 right-0 p-4 -translate-y-1/4"
            type="button"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <svg
              width="12"
              height="13"
              viewBox="0 0 12 13"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M11 1.5L1 11.5"
                stroke="#664E36"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round" />
              <path
                d="M1 1.5L11 11.5"
                stroke="#664E36"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      {% endif %}

      {% if cart != empty and settings.show_shipping_bar %}
        <div style="padding-top:1.2vh;" class="flex justify-center border-b border-[#0000001A] ">
          {% render 'cart-drawer-tracker' %}
        </div>
      {% endif %}
      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty pt-[2.4rem] hidden"
        {% endif %}
        class="h-[56vh] overflow-auto my-[1.2vh] pr-6 -mr-6"
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <div class="cart-items" role="table">
                  {% comment %}<thead role="rowgroup"> <tr role="row"> <th id="CartDrawer-ColumnProductImage" role="columnheader"> <span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span> </th> <th id="CartDrawer-ColumnProduct" class="caption-with-letter-spacing" scope="col" role="columnheader"> {{ 'sections.cart.headings.product' | t }} </th> <th id="CartDrawer-ColumnTotal" class="right caption-with-letter-spacing" scope="col" role="columnheader"> {{ 'sections.cart.headings.total' | t }} </th> <th id="CartDrawer-ColumnQuantity" role="columnheader"> <span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span> </th> </tr> </thead>{% endcomment %}

                  <div role="rowgroup">
                    {%- for item in cart.items -%}
                      <div
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item mb-[1.2rem]"
                        role="row"
                      >
                        <div class="cart-item__media w-[31.6%]" headers="CartDrawer-ColumnProductImage">
                          {% if item.image %}
                            {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                            <a
                              href="{{ item.url }}"
                              class="cart-item__link"
                              tabindex="-1"
                              aria-hidden="true"
                            ></a>
                            <img
                              class="cart-item__image w-full object-contain object-center"
                              src="{{ item.image | image_url: width: 300 }}"
                              alt="{{ item.image.alt | escape }}"
                              loading="lazy"
                              width="150"
                              height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                            >
                          {% endif %}
                        </div>
                        <div class="cart-item__details" headers="CartDrawer-ColumnProduct">
                          {%- if settings.show_vendor -%}
                            <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                          {%- endif -%}

                          <a
                            href="{{ item.url }}"
                            class="cart-item__name font-sans base font-bold break hover:no-underline"
                          >
                            {{- item.product.title | escape -}}
                          </a>

                          {%- if item.original_price != item.final_price -%}
                            <div class="cart-item__discounted-prices text-[#664E36B2]">
                              <span class="visually-hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </span>
                              <s class="cart-item__old-price product-option text-[#664E36B2]">
                                {{- item.original_price | money -}}
                              </s>
                              <span class="visually-hidden">
                                {{ 'products.product.price.sale_price' | t }}
                              </span>
                              <strong class="cart-item__final-price product-option text-[#664E36B2]" style="font-size:clamp(1.2rem,1vw,12px)">
                                {{ item.final_price | money }}
                              </strong>
                            </div>
                          {%- else -%}
                            <div class="product-option text-[#664E36B2]" style="font-size:clamp(1.2rem,1vw,12px)">
                              {{ item.original_price | money }}
                            </div>
                          {%- endif -%}

                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option" style="font-size:clamp(1.2rem,1vw,12px)">
                                    <dt>{{ option.name }}:</dt>
                                    <dd>
                                      {{ option.value -}}
                                      {%- unless forloop.last -%}
                                        ,
                                      {% endunless %}
                                    </dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}

                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  <div class="product-option">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a
                                          href="{{ property.last }}"
                                          class="link"
                                          target="_blank"
                                          aria-describedby="a11y-new-window-message"
                                        >
                                          {{ property.last | split: '/' | last }}
                                        </a>
                                      {%- else -%}
                                        {{ property.last }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                            </dl>

                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}

                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in item.discounts -%}
                              <li class="discounts__discount " style="font-size:clamp(6px,9vw,10px);">
                                <svg
                                  aria-hidden="true"
                                  focusable="false"
                                  class="text-tertiary icon icon-discount "
                                  viewBox="0 0 12 12"
                                >
                                  <path
                                    fill-rule="evenodd"
                                    clip-rule="evenodd"
                                    d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z"
                                    fill="currentColor">
                                </svg>

                                {{ discount.title }}
                              </li>
                            {%- endfor -%}
                          </ul>
                          <div class="cart-item__quantity w-max" headers="CartDrawer-ColumnQuantity">
                            <div class="cart-item__quantity-wrapper border border-[#664E3699]  justify-center">
                              <quantity-input class="quantity cart-quantity px-[1.7rem] text-tertiary min-h-[3.2rem!important]">
                                <button
                                  class="quantity__button w-max no-js-hidden text-tertiary "
                                  name="minus"
                                  type="button"
                                >
                                  <span class="visually-hidden">
                                    {{-
                                      'products.product.quantity.decrease'
                                      | t: product: item.product.title
                                      | escape
                                    -}}
                                  </span>
                                  {% render 'icon-minus' %}
                                </button>
                                <input
                                  class="quantity__input focus-visible:outline-none focus-visible:border-none focus-visible:shadow-none text-[1.1rem] xl:text-[1.4rem] xxl:text-[1.8rem] md:text-[1rem] sm:text-[1.8rem] "
                                  type="number"
                                  data-quantity-variant-id="{{ item.variant.id }}"
                                  name="updates[]"
                                  value="{{ item.quantity }}"
                                  {% # theme-check-disable %}
                                  data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                  min="{{ item.variant.quantity_rule.min }}"
                                  {% if item.variant.quantity_rule.max != null %}
                                    max="{{ item.variant.quantity_rule.max }}"
                                  {% endif %}
                                  step="{{ item.variant.quantity_rule.increment }}"
                                  {% # theme-check-enable %}
                                  aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                  id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                  data-index="{{ item.index | plus: 1 }}"
                                >
                                <button
                                  class="quantity__button w-max no-js-hidden text-tertiary"
                                  name="plus"
                                  type="button"
                                >
                                  <span class="visually-hidden">
                                    {{-
                                      'products.product.quantity.increase'
                                      | t: product: item.product.title
                                      | escape
                                    -}}
                                  </span>
                                  {% render 'icon-plus' %}
                                </button>
                              </quantity-input>
                              {% comment %} <cart-remove-button id="CartDrawer-Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}"><button type="button" class="button button--tertiary" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"> {% render 'icon-remove' %} </button> </cart-remove-button> {% endcomment %}
                            </div>

                            <div
                              id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                              class="cart-item__error"
                              role="alert"
                            >
                              <small class="cart-item__error-text"></small>
                              <svg
                                aria-hidden="true"
                                focusable="false"
                                class="icon icon-error"
                                viewBox="0 0 13 13"
                              >
                                <circle
                                  cx="6.5"
                                  cy="6.50049"
                                  r="5.5"
                                  stroke="white"
                                  stroke-width="2" />
                                <circle
                                  cx="6.5"
                                  cy="6.5"
                                  r="5.5"
                                  fill="#EB001B"
                                  stroke="#EB001B"
                                  stroke-width="0.7" />
                                <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white" />
                                <path
                                  d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z"
                                  fill="white"
                                  stroke="#EB001B"
                                  stroke-width="0.7">
                              </svg>
                            </div>
                          </div>
                        </div>

                        <div
                          {% comment %}
                            class="cart-item__totals right"
                          {% endcomment %}
                          headers="CartDrawer-ColumnQuantity"
                        >
                          <div class="cart-item__quantity-wrapper">
                            <cart-remove-button
                              id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                              <button
                                type="button"
                                class="button button--tertiary bg-[transparent!important] text-[black!important] min-w-[9px!important] min-h-[9px!important]"
                                aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                              >
                                <svg
                                  width="26"
                                  height="25"
                                  viewBox="0 0 26 25"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path
                                    d="M17.5703 8L8.57031 17"
                                    stroke="#664E36"
                                    stroke-width="1.3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round" />
                                  <path
                                    d="M8.57031 8L17.5703 17"
                                    stroke="#664E36"
                                    stroke-width="1.3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round" />
                                </svg>
                              </button>
                            </cart-remove-button>
                          </div>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
            <p
              id="CartDrawer-LiveRegionText"
              class="visually-hidden"
              role="status"
            ></p>
            <p
              id="CartDrawer-LineItemStatus"
              class="visually-hidden"
              aria-hidden="true"
              role="status"
            >
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>
            {% if cart != empty %}

      {% render 'cart-drawer-cross-sell', csell_collections: settings.cart_drawer_collection %}
      {% endif %}
      <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="base summary__title">
                {{ 'sections.cart.note' | t }}
                {% render 'icon-caret' %}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          <div class="totals" role="status">
            <b class="base text-center text-[#3B2D1F99!important] font-normal">
              {{ 'sections.cart.subtotal' | t }}
          </b>
            <p class="totals__subtotal-value base text-[#981515!important]">
              {{ cart.total_price | money_with_currency }}
            </p>
          </div>

          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul
                class="discounts list-unstyled"
                role="list"
                aria-label="{{ 'customer.order.discount' | t }}"
              >
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--end">
                    {%- render 'icon-discount' -%}
                    {{ discount.title }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <small class="tax-note caption-large rte custom-tax-note text-[#3B2D1F99]">
            {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
            {%- elsif cart.taxes_included -%}
              {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
            {%- elsif shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
            {%- else -%}
              {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
            {%- endif -%}
          </small>
        </div>

        <!-- CTAs -->
        <div>
          <div class="cart__ctas flex items-center" {{ block.shopify_attributes }}>
            <noscript>
              <button
                type="submit uppercase"
                class="cart__update-button button button--secondary"
                form="CartDrawer-Form"
              >
                {{ 'sections.cart.update' | t }}
              </button>
            </noscript>

          {%- if additional_checkout_buttons -%}
            <div class="express-checkout">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}

            <button
              type="submit"
              id="CartDrawer-Checkout"
              class="mt-[0!important] max-h-[44px] cart__checkout-button button uppercase"
              name="checkout"
              form="CartDrawer-Form"
              {% if cart == empty %}
                disabled
              {% endif %}
            >
              {{ 'sections.cart.checkout' | t }}
            </button>
          </div>
          
          {% comment %} {%- if additional_checkout_buttons -%}
            <div class="express-checkout mt-[1.6rem]">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%} {% endcomment %}
        
                {% comment %} <paypal-button-container style="display:block; margin-top:10px;" id="paypal-button-container"></paypal-button-container> {% endcomment %}

        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>
