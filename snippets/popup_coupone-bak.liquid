<style>
  .coupon_pop.popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 999999;

    &&.show {
      display: flex;
      opacity: 1;
      /* Fade-in effect when shown */
    }

    && .popup-content {
      position: relative;
      display: flex;
      padding: 10px;
      width: 100%;
      max-width: 810.78px;
      min-height: 31.875rem;
      border-radius: 16px;
      background-color: rgba(31, 46, 29, 1);
      transform: translateY(-3.125rem);
      transition: transform 0.5s ease;
      animation: slideIn 0.5s forwards ease;
      overflow: hidden;
    }
    && .popup-text {
      flex: 1;
      padding: 10rem 3.25rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }
    && .close-button {
      position: absolute;
      right: 15px;
      z-index: 1;
      top: 0;
      background: none;
      border: none;
      font-size: 3rem;
      cursor: pointer;
      color: #1f2e1d;
    }

    && h2 {
      font-weight: 700;
      color: #fee0ad;
      margin-bottom: 1.5rem;
    }

    && h2 red {
      color: #fe3520;
    }

    && .message {
      font-weight: 400;
      color: #fee0ad;
      margin-bottom: 1.5rem;
    }

    && .message-bold {
      font-size: 1.125rem;
      font-weight: 700;
      line-height: 1.4625rem;
      color: #fee0ad;
    }

    && .coupon-code {
      border: 0.0625rem dashed #fee0ad;
      padding: 1.37rem 0.5rem;
      margin-bottom: 1.5rem;
      width: 100%;
      max-width: 35.8rem;
    }

    && .coupon-code p {
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 3rem;
      margin: 0;
      color: #fe3520;
    }
    && .copy-button {
      background-color: #3b5948;
      color: #fee0ad;
      border: none;
      padding: 1.37rem 0.5rem;
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 3rem;
      cursor: pointer;
      transition: background-color 0.3s;
      width: 100%;
      max-width: 35.8rem;
    }
    && .copy-button:hover {
      background-color: #1a2819;
    }
    && .popup-image {
      width: 43%;
      display: block;
    }
    && .popup-image img {
      width: 100%;
      height: 100%;
      border-radius: 8px;
      object-fit: cover;
    }
  }

  @media (max-width: 48rem) {
    .coupon_pop.popup-overlay {
      && .popup-content {
        max-width: 85%;
      }

      && .popup-image {
        display: none;
      }

      && .close-button {
        font-size: 4rem;
        color: #fee0ad;
      }
    }
  }

  @keyframes slideIn {
    from {
      transform: translateY(-3.125rem);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes glow {
    0% {
      filter: brightness(0.8) contrast(1);
    }
    50% {
      filter: brightness(1.8) contrast(1.5);
    }
    100% {
      filter: brightness(0.8) contrast(1);
    }
  }

  .christmas-lights {
    display: block;
    /* or inline-block depending on usage */
    width: auto;
    /* Adjust to your preferred size */
    animation: glow 1.5s infinite;
  }
</style>
<div id="popupOverlay" class="popup-overlay coupon_pop font-serif ">
  <div class="popup-content ">
    <button id="closeButton" class="close-button">&times;</button>
    <div class="popup-text relative">
      <img
        class="christmas-lights"
        src="https://cdn.shopify.com/s/files/1/0663/9966/6326/files/cristmas_light.png?v=1733914064"
        alt="Christmas Light"
        style="position: absolute;top: 0;left: 0;max-width: 100%;height: auto;scale: 1.09;object-fit: cover;z-index: -1;"
        width="500"
        height="500"
      >
      <h2>{{ title }}</h2>
      <p class="message">
        {{ message }}
      </p>
      <div class="coupon-code">
        <p>CODE: {{ code }}</p>
      </div>
      <button id="copyButton" class="copy-button">Copy Code</button>
      <img
        class="christmas-lights"
        src="https://cdn.shopify.com/s/files/1/0663/9966/6326/files/Group_27671.png?v=1733914680"
        alt="Christmas Light"
        style="position: absolute; bottom: -10px; left: 0; max-width: 100%; height: auto; object-fit: cover; z-index: -1;"
        width="500"
        height="500"
      >
    </div>
    <div class="popup-image">
      <img
        src="{{image | image_url }}"
        alt="{{ image.alt }}"
        width="500"
        height="500"
      >
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const popupOverlay = document.getElementById('popupOverlay');
    const popupContent = document.querySelector('.popup-content');
    const popupButton = document.getElementById('popupButton');
    const closeButton = document.getElementById('closeButton');
    const copyButton = document.getElementById('copyButton');
    const POPUP_KEY = 'popupCount';
    const POPUP_EXPIRY_KEY = 'popupExpiry';
    const POPUP_EXPIRY = 24 * 60 * 60 * 1000; // 24 hours in milliseconds
    const MAX_POPUP_COUNT = 2; // Maximum popups allowed in 24 hours

    let popupShown = false;

    function showPopup() {
      popupOverlay.style.display = 'flex';
      popupOverlay.classList.add('show');
      popupShown = true;

      // Update popup count and timestamp
      const popupCount = parseInt(localStorage.getItem(POPUP_KEY), 10) || 0;
      localStorage.setItem(POPUP_KEY, popupCount + 1);

      const expiryTime = localStorage.getItem(POPUP_EXPIRY);
      if (!expiryTime) {
        localStorage.setItem(POPUP_EXPIRY, Date.now());
      }
    }

    function closePopup() {
      popupOverlay.classList.remove('show');
      setTimeout(() => {
        popupOverlay.style.display = 'none';
      }, 500); // Matches the CSS transition duration
    }

    closeButton.addEventListener('click', closePopup);
    popupOverlay.addEventListener('click', function (event) {
      if (!popupContent.contains(event.target)) {
        closePopup();
      }
    });

    copyButton.addEventListener('click', function () {
      navigator.clipboard
        .writeText('HOLIDAYS')
        .then(function () {
          copyButton.textContent = 'Copied!';
          setTimeout(function () {
            copyButton.textContent = 'Copy Code';
          }, 2000);
        })
        .catch(function (err) {
          console.error('Failed to copy: ', err);
        });
    });

    // Check if the popup should be shown
    function shouldShowPopup() {
      const popupCount = parseInt(localStorage.getItem(POPUP_KEY), 10) || 0;
      const expiryTime = parseInt(localStorage.getItem(POPUP_EXPIRY), 10);

      // Reset count if 24 hours have passed
      if (expiryTime && Date.now() - expiryTime > POPUP_EXPIRY) {
        localStorage.setItem(POPUP_KEY, '0');
        localStorage.setItem(POPUP_EXPIRY, Date.now());
        return true;
      }

      // Allow popup only if count is below the maximum allowed
      return popupCount < MAX_POPUP_COUNT;
    }

    // Detect homepage or other page behavior
    if (shouldShowPopup()) {
      if (window.location.pathname === '/') {
        // Show on homepage after scrolling
        window.addEventListener('scroll', function () {
          if (!popupShown && window.scrollY > window.innerHeight / 2) {
            showPopup();
          }
        });
      } else {
        // Show on other pages only after staying for a specific duration
        setTimeout(() => {
          if (!popupShown) {
            showPopup();
          }
        }, 10000); // Adjust time (10 seconds here)
      }
    }

    // Popup button should always work regardless of limits
    popupButton.addEventListener('click', showPopup);
  });
</script>
