<style>
  .coupon_pop.popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #3a230733;
    display: none;
    justify-content: right;
    align-items: end;
    z-index: 999999;
    padding: 24px;
    
    &&.show {
      display: flex;
      opacity: 1;
    }

    && .popup-content {
      position: relative;
      display: flex;
      padding: 0px;
      width: 100%;
      max-width: 44.4rem;
      {% comment %} margin: 16px; {% endcomment %}
      height: max-content;
      max-height:96dvh;
      border-radius: 16px;
      background-color: #f5f4f0;
      transform: translateY(-3.125rem);
      transition: transform 0.5s ease;
      animation: slideIn 0.5s forwards ease;
      overflow: hidden;
    }
    && .popup-text {
      flex: 1;
      padding: 3.7rem 4rem 5.2rem 4rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      height: max-content;
      max-height: max-content;
    }
    && .close-button {
      position: absolute;
      {% comment %} right: 16px;
      top: 16px; {% endcomment %}
      right:24px;
      top:24px;
      z-index: 10;
      background: #f5f5f5;
      border: none;
      font-size: 3rem;
      cursor: pointer;
      color: #1f2e1d;
      width: 3.2rem;
      height: 3.2rem;
      display: flex;
      justify-content: center;
      align-items: center;
      box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.1);
      border-radius: 50%;

      &&:hover {
        scale: 1.1;
      }
    }

    && h2 {
      font-weight: 700;
      color: #fee0ad;
      margin-bottom: 1.5rem;
    }

    && h3 {
      margin-bottom: 2.4rem;
    }

    && h2 red {
      color: #fe3520;
    }

    && .message {
      font-weight: 400;
      color: #737373;
      margin-bottom: 1.5rem;
    }

    && .message-bold {
      font-weight: 700;
      line-height: 1.4625rem;
      color: #737373;
    }

    && .coupon-code {
      padding: 1.37rem 0.5rem;
      margin-bottom: 1.5rem;
      width: 100%;
      max-width: 35.8rem;
    }

    && .coupon-code p {
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 3rem;
      margin: 0;
      color: #fe3520;
    }

    && .popup-image {
      width: 100%;
      display: block;
      margin: auto;
      background: #f2ede1;
      max-height: 44%;
      /* padding: 8rem 4rem 4.8rem 4rem; */
    }
    && .popup-image img {
      width: 100%;
      max-width: 100%;

      height: 100%;
      /* border-radius: 8px; */
      object-fit: contain;
      margin: auto;
    }

    && .newsletter-form__field-wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
    }

    && .field__input {
      padding: 1.25rem 1.6rem !important;
    }
    && .field:after,
    .field:before {
      content: none !important;
    }

    && .field__label {
      top: calc(1.2rem + var(--inputs-border-width));
    }

    && .field__input:focus ~ .field__label {
      top: calc(var(--inputs-border-width) + 0.5rem);
    }
    && .newsletter-form__button {
      position: static;
      width: 100%;
      font-size: 1.8rem;
      border-radius: 48px;
      border: 2px solid #3a2307;
      padding: 12px;
      margin-top: 2rem;
      height: max-content;
      line-height: 1;
      margin-bottom: 2rem;
    }
  }

  .copy-code-wrap,
  .coupon-code {
    margin-top: 16px;
    z-index: 1;

  }
  #copy-effect#copy-effect {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    display:none; 
    background: #d9ffd9;
    padding: 13px;
    border-radius: 4px;
    width: 100%
  }

  .copy-code-wrap{
    position:relative;
    border: 1px dashed rgb(58, 35, 7);
    border-radius:4px;

  }

  .message {
    margin-bottom: 0 !important;
  }
  @media (max-width: 768px) {
    .coupon_pop.popup-overlay {
      && .popup-content {
        width: 95%;
        && h3 {
          font-size: 2.4rem;
        }
      }
    }
  }

  @media (max-width: 480px) {
    .coupon_pop.popup-overlay {
      justify-content:center;
      
      && .popup-content {
        width: 95%;
      }

      /* && .popup-image img {
        max-width: 85.5%;
      } */

      && .popup-text {
        padding: 3.7rem 2rem 5.2rem 2rem;
      }

      && .close-button {
        font-size: 4rem;
      }
    }
  }

  @keyframes slideIn {
    from {
      transform: translateY(-3.125rem);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes glow {
    0% {
      filter: brightness(0.8) contrast(1);
    }
    50% {
      filter: brightness(1.8) contrast(1.5);
    }
    100% {
      filter: brightness(0.8) contrast(1);
    }
  }

  .christmas-lights {
    display: block;
    /* or inline-block depending on usage */
    width: auto;
    /* Adjust to your preferred size */
    animation: glow 1.5s infinite;
  }
</style>

<div id="popupOverlay" class="popup-overlay coupon_pop font-serif ">
  <div class="popup-content">
    <button id="closeButton" style="transform: rotate(45deg)" class="close-button">
      <svg
        fill="none"
        height="24"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        viewBox="0 0 24 24"
        width="24"
      >
        <path d="M12 5v14M5 12h14"></path>
      </svg>
    </button>
    {% if title != "christmas" %}
      <div class="flex flex-col" style="height: max-content; max-height: max-content;">
        <div class="popup-image">
          <img
            src="{{image | image_url }}"
            alt="{{ image }}"
            width="500"
            height="500"
            loading="lazy"
          >
        </div>

        <div class="popup-text relative">
          <b class="font-serif h2">
            {{ title }}
          </b>
          {% if code != blank %}
            <div class="copy-code-wrap w-full">
              <div
                id="clipboard-copy"
                class="w-full font-medium font-sans"
                style="padding:13px; font-size:1.8rem;"
              >
                Use Code: {{ code }}
              </div>
              <div
                id="copy-effect"
              >
                Copied!
              </div>
            </div>
            <a
              href="https://medicinalmadhoney.com/collections/all"
              class="font-sans block h-max newsletter-form__button field__button"
              name="commit"
              id="Subscribe"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >
              Shop Now
            </a>
          {% else %}
            <!-- <button id="copyButton" class="copy-button">Copy Code</button> -->
            {% form 'customer', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="newsletter-form__field-wrapper">
                <div class="field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="Newsletter-success--{{ section.id }}"
                    {% endif %}
                    placeholder="{{ 'newsletter.label' | t }}"
                    required
                  >
                  <label class="field__label" for="NewsletterForm--{{ section.id }}">
                    {{ 'newsletter.label' | t }}
                  </label>
                </div>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  Sign Up
                </button>
                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                    {%- render 'icon-error' -%}
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
              </div>
              {%- if form.posted_successfully? -%}
                <h3
                  class="newsletter-form__message newsletter-form__message--success form__message"
                  id="Newsletter-success--{{ section.id }}"
                  tabindex="-1"
                  autofocus
                >
                  {% render 'icon-success' -%}
                  {{- 'newsletter.success' | t }}
                </h3>
              {%- endif -%}
            {% endform %}
          {% endif %}
          <p class="message mb-0 blog-text font-sans">
            {{ message }}
          </p>
        </div>
      </div>
    {% else %}
      {% comment %} <style>
.coupon_pop.popup-overlay{
 display:flex!important;
}
</style>  {% endcomment %}
 
      
