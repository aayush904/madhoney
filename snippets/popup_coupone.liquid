    function showPopup() {
      popupOverlay.style.display = 'flex';
      popupOverlay.classList.add('show');
      popupShown = true;

      // Update popup count and timestamp
      const popupCount = parseInt(localStorage.getItem(POPUP_KEY), 10) || 0;
      localStorage.setItem(POPUP_KEY, popupCount + 1);

      const expiryTime = localStorage.getItem(POPUP_EXPIRY);
      if (!expiryTime) {
        localStorage.setItem(POPUP_EXPIRY, Date.now());
      }
    }

    function closePopup() {
      popupOverlay.classList.remove('show');
      setTimeout(() => {
        popupOverlay.style.display = 'none';
      }, 500); // Matches the CSS transition duration
    }

    closeButton.addEventListener('click', closePopup);
    popupOverlay.addEventListener('click', function (event) {
      if (!popupContent.contains(event.target)) {
        closePopup();
      }
    });

    // copyButton.addEventListener('click', function () {
    //   navigator.clipboard
    //     .writeText('HOLIDAYS')
    //     .then(function () {
    //       copyButton.textContent = 'Copied!';
    //       setTimeout(function () {
    //         copyButton.textContent = 'Copy Code';
    //       }, 2000);
    //     })
    //     .catch(function (err) {
    //       console.error('Failed to copy: ', err);
    //     });
    // });

    // Check if the popup should be shown
    function shouldShowPopup() {
      const popupCount = parseInt(localStorage.getItem(POPUP_KEY), 10) || 0;
      const expiryTime = parseInt(localStorage.getItem(POPUP_EXPIRY), 10);

      // Reset count if 24 hours have passed
      if (expiryTime && Date.now() - expiryTime > POPUP_EXPIRY) {
        localStorage.setItem(POPUP_KEY, '0');
        localStorage.setItem(POPUP_EXPIRY, Date.now());
        return true;
      }

      // Allow popup only if count is below the maximum allowed
      return popupCount < MAX_POPUP_COUNT;
    }

    // Detect homepage or other page behavior
    if (shouldShowPopup()) {
        setTimeout(() => {
      if (window.location.pathname === '/') {
        // Show on homepage after scrolling
        window.addEventListener('scroll', function () {
          if (!popupShown && window.scrollY > window.innerHeight / 2) {
            showPopup();
          }
        });
      } else {
        // Show on other pages only after staying for a specific duration
          if (!popupShown) {
            showPopup();
          }
      }
        }, 10000); // Adjust time (10 seconds here)
    }

    // Popup button should always work regardless of limits
    popupButton.addEventListener('click', showPopup);
  });

  // copy code

  {% if code != blank %}

  // Get the elements
  const copyButton = document.getElementById('clipboard-copy');
  const copyEffect = document.getElementById('copy-effect');

  // Add the hover effect for cursor
  copyButton.style.cursor = 'copy';

  // Add the click event listener
  copyButton.addEventListener('click', () => {
    // Create a temporary text area element to hold the text for copying
    const tempTextArea = document.createElement('textarea');
    tempTextArea.value = '{{ code }}'; // Replace with the actual text you want to copy
    document.body.appendChild(tempTextArea);

    // Select the text inside the textarea
    tempTextArea.select();
    tempTextArea.setSelectionRange(0, 99999); // For mobile devices

    // Execute the copy command
    try {
      document.execCommand('copy');
      // Show the "Copied!" effect
      showCopyEffect();
    } catch (err) {
      console.error('Unable to copy', err);
    }

    // Remove the temporary textarea element
    document.body.removeChild(tempTextArea);
  });

  // Function to show the copy effect
  function showCopyEffect() {
    // Position the copy effect
    copyEffect.style.display = 'block';

    // Hide the effect after 1 second
    setTimeout(() => {
      copyEffect.style.display = 'none';
    }, 1000);
  }
  {% endif %}
</script>
