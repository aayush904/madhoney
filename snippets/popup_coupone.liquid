 <style>
  .body,.popup-content {
    width: 100dvw!important;
    height: 100dvh!important;
    max-width: 95dvw!important;
    max-height: 95dvh!important;
    margin:auto;
    font-family: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }


  .hero {
    min-height: 100vh;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
        background: #c90016;

  }

  .hero-left,
  .hero-right {
    flex: 1 1 50%;
    display:flex!important;
    min-height: 50vh;
    position: relative;
  }

  /* Left: image side */
  .hero-left {
    background-image:linear-gradient(rgba(0, 0, 0, 0), rgb(0 0 0 / 0%)), url(https://cdn.shopify.com/s/files/1/0663/9966/6326/files/image_334.webp?v=1765797879);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index:1;
  }

  /* Right: red content side */
  .hero-right {
    background: #c90016;
    color: #ffe7c8;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
  }

  .hero-content {
    width: 100%;
    max-width: 36dvw;
    position: relative;
  }

  #shopify-section-{{section.id}} img{
      mix-blend-mode: normal!important;
    opacity: 1!important;
    padding: 0!important;}

  /* Responsive SVG heading */
  .hero-heading-svg {
    width: 100%;
    height: auto;
    max-width: 460px;
    margin: 0 auto 26px;
    display: block;
  }

  .hero-heading-svg text {
    font-family: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    text-anchor: middle;
    fill: #ffe7c8;
  }

  .hero-heading-svg .top {
    font-size: 20px;
    font-weight: 500;
  }

  .hero-heading-svg .middle {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: 3px;
    fill: #ffe472;
  }

  .hero-heading-svg .bottom {
    font-size: 32px;
    font-weight: 500;
  }

  p.subcopy {
    margin: clamp(40px, 5vw, 10.5rem) auto;
    width: 89%;
  }

  .cta-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 14px 38px;
    width: 70.55%;
    border-radius: 999px;
    border: none;
    background: #ffffff;
    color: #111;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.35);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(0, 0, 0, 0.45);
    background: #ffe472;
  }

  /* 30% OFF badge */
  .discount-badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -10%);
    width: clamp(80px,11vw,250px);
    height: auto;
    aspect-ratio:1/1;
    border-radius: 50%;
    background: #fffdf5;
    border: 6px solid #ffc557;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #d30000;
    font-weight: 700;
    text-align: center;
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.35);
    z-index: 3;
    animation: floatBadge 6s ease-in-out infinite;
    /* ambient float */
  }

  .discount-badge .percent {
    font-size: clamp(20px,4vw,34px);
    line-height: 1;
  }

  .discount-badge .off {
    font-size: clamp(18px,4vw,28px);
    line-height: 1.2;
  }



  /* Ornament */
  .ornament {
    position: absolute;
    top: 0px;
    left: 0;
    width: 16.66dvw;
    z-index: 1;
    animation: floatOrnament 7s ease-in-out infinite;
  }

  /* Small floating dots */
  .corner-dot {
    position: absolute;
    width: 10%;
    animation: floatDot 8s ease-in-out infinite;
  }

  .corner-dot.top-left {
    top: 0;
    left: 50%;
    animation-delay: 0s;
  }

  .coral{
    left:50%;
    bottom:0;
    position:absolute;
    height:100%;
    width:auto;
    translate:-40%;
    z-index:1;
  }

  .coral2{
    right:0;
    bottom:0;
    position:absolute;
    height:100%;
    width:auto;
    translate: 5%;
    z-index:1;
  }

  /* Ambient animations using keyframes [web:62][web:69] */
  @keyframes floatBadge {

    0%,
    100% {
      transform: translate(-50%, -45%);
    }

    50% {
      transform: translate(-50%, -55%);
    }
  }

  @keyframes pulseCircle {

    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }

    50% {
      transform: scale(1.05);
      opacity: 0.75;
    }
  }

  @keyframes floatOrnament {

    0%,
    100% {
      transform: translate(-50%, -50%);
    }

    50% {
      transform: translate(-50%, -60%);
    }
  }

  @keyframes floatDot {

    0%,
    100% {
      transform: translate(-50%, -0%);
      opacity: 0.9;
    }

    50% {
      transform: translate(-50%, -5%);
      opacity: 0.6;
    }
  }

  /* Respect prefers-reduced-motion for accessibility [web:67][web:73] */
  @media (prefers-reduced-motion: reduce) {

    .discount-badge,
    .ornament,
    .corner-dot {
      animation: none !important;
    }
  }

  /* Responsive tweaks */
  @media (max-width: 768px) {

    .hero-left,
    .hero-right {
      flex: 1 1 100%;
      max-height:50dvw;
      height:100%;
    }


    .hero-content{
      max-width:45dvw;
    }

    .discount-badge {
      top: 50%;
      left:50%;
      bottom: auto;
    }

    .coral2,.coral {
      height:50%;
    }

    .corner-dot{
      width:5%;
    }

    .coral {
      left:0%;
    }
  }

  @media (max-width: 600px) {
    .hero-heading-svg .top {
      font-size: 18px;
    }
    .hero-content{
      max-width:60dvw;
    }
    .hero-heading-svg .middle {
      font-size: 40px;
      letter-spacing: 2px;
    }

    .hero-heading-svg .bottom {
      font-size: 26px;
    }

    p.subcopy {
      font-size: 14px;
    }

    .ornament {
      left: 0px;
      top: 0px;
    }


  }

      @media (max-width: 580px) {
              .hero-content{
      max-width:73dvw;
    }
  }
</style>

