<script>
  // Updated dosage data
  let dosageData = {};

  // Fetch dosage data from the PHP API
  async function fetchDosageData() {
    document.getElementById('result').textContent = 'Calculating...';

    try {
      const response = await fetch('https://api.medicinalmadhoney.com/honey-dosages/index.php');
      dosageData = await response.json();
    } catch (error) {
      console.error('Error fetching dosage data:', error);
    }
  }

  async function calculateDosage() {
    await fetchDosageData();

    const honeyType = document.querySelector('.honey-type-btn.active').textContent.trim();
    const madHoneyType = honeyType === 'Mad Honey' ? document.getElementById('mad-honey-type').value : 'Regular Honey';
    const age = document.getElementById('age-range').value;
    const weight = document.querySelector('[name="weight-range"]:checked').value;
    const usageType = document.getElementById('usage-type').value;

    let selectedHoneyType = honeyType === 'Mad Honey' ? madHoneyType : 'Regular Honey';
    let dosage = dosageData[selectedHoneyType][age][weight][usageType];
    document.getElementById('result').textContent = dosage || 'Invalid combination';
    console.log(honeyType, madHoneyType, age, weight, usageType, dosage, selectedHoneyType);
  }

  // Handle button click events
  function handleButtonClick(buttonClass) {
    document.querySelectorAll(`.${buttonClass}`).forEach((button) => {
      button.addEventListener('click', function () {
        document.querySelectorAll(`.${buttonClass}`).forEach((b) => b.classList.remove('active'));
        this.classList.add('active');
        if (buttonClass === 'honey-type-btn') {
          const madHoneySection = document.getElementById('mad-honey-section');
          if (this.textContent.trim() === 'Mad Honey') {
            document.querySelector('#usage-type').appendChild(new Option('Strong Effect', 'effect'));
            madHoneySection.classList.remove('hidden');
          } else {
            madHoneySection.classList.add('hidden');
            // Remove strong effect option if not mad honey
            const effectOption = document.querySelector('#usage-type option[value="effect"]');
            if (effectOption) {
              effectOption.remove();
            }
            // Set default usage type to general if not mad honey
            document.getElementById('usage-type').value = 'general';
          }
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', async () => {
    {% comment %} calculateDosage(); {% endcomment %}
    handleButtonClick('honey-type-btn');
    // Set default active buttons
    if (!document.querySelector('.honey-type-btn.active')) {
      document.querySelector('.honey-type-btn').classList.add('active');
    }
    // Show/hide mad honey section based on initial selection
    const selectedHoneyType = document.querySelector('.honey-type-btn.active').textContent.trim();
    const madHoneySection = document.getElementById('mad-honey-section');
    if (selectedHoneyType === 'Mad Honey') {
      madHoneySection.classList.remove('hidden');
    } else {
      madHoneySection.classList.add('hidden');
    }
    document.querySelector('.calculate-btn').addEventListener('click', calculateDosage);

    // Reset to default values on AC button click
    document.querySelector('.btn-container .reset').addEventListener('click', () => {
      document.querySelectorAll('.honey-type-btn').forEach((button) => button.classList.remove('active'));
      document.querySelector('.honey-type-btn').classList.add('active');
      const madHoneySection = document.getElementById('mad-honey-section');
      madHoneySection.classList.remove('hidden');
      document.getElementById('age-range').value = 'Adult';
      document.querySelectorAll('[name="weight-range"]').forEach((input) => (input.checked = false));
      document.querySelector('[name="weight-range"][value="40-80"]').checked = true;
      document.getElementById('usage-type').value = 'general';
      document.getElementById('result').textContent = '0';
      document.querySelector('dosage-type').textContent = 'General';
    });

    // Update dosage-type text content on usage type change
    document.getElementById('usage-type').addEventListener('change', function () {
      const selectedOption = this.options[this.selectedIndex].value;
      document.querySelector('dosage-type').textContent =
        selectedOption == 'general' ? 'General' : selectedOption == 'medicinal' ? 'Medicinal' : 'Strong Effect';
    });
  });
</script>

