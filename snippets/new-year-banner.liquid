<script>
const target = new Date('2026-01-01T00:00:00-05:00').getTime();
  const unitDays = document.getElementById('unitDays');
  const unitHours = document.getElementById('unitHours');
  const unitMins = document.getElementById('unitMins');
  const unitSecs = document.getElementById('unitSecs');
  const digits = {
    daysTens: document.getElementById('daysTens'),
    daysOnes: document.getElementById('daysOnes'),
    hoursTens: document.getElementById('hoursTens'),
    hoursOnes: document.getElementById('hoursOnes'),
    minsTens: document.getElementById('minsTens'),
    minsOnes: document.getElementById('minsOnes'),
    secsTens: document.getElementById('secsTens'),
    secsOnes: document.getElementById('secsOnes'),
  };

  function set2(elTens, elOnes, n) {
    const s = String(n).padStart(2, '0');
    elTens.textContent = s[0];
    elOnes.textContent = s[1];
  }

  function showOnlyTwoUnits(first, second) {
    [unitDays, unitHours, unitMins, unitSecs].forEach((u) => u.classList.add('is-hidden'));
    first.classList.remove('is-hidden');
    second.classList.remove('is-hidden');
  }

  function tick() {
    let diff = target - Date.now();
    if (diff < 0) diff = 0;
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const minutes = Math.floor((diff / (1000 * 60)) % 60);
    const seconds = Math.floor((diff / 1000) % 60);
    set2(digits.daysTens, digits.daysOnes, days);
    set2(digits.hoursTens, digits.hoursOnes, hours);
    set2(digits.minsTens, digits.minsOnes, minutes);
    set2(digits.secsTens, digits.secsOnes, seconds);
    // show only 2 units (4 digit boxes) at a time
    if (days > 0) {
      showOnlyTwoUnits(unitDays, unitHours);
    } else if (hours > 0) {
      showOnlyTwoUnits(unitHours, unitMins);
    } else {
      showOnlyTwoUnits(unitMins, unitSecs);
    }
  }
  tick();
  setInterval(tick, 1000);
</script>
