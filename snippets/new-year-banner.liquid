<style>
  .pop-container {
    --bg: #f6efdf;
    --border: #e2d5b9;
    --label: #4b3a2f;
    --digit: #b00000;
  }



  .pop-container .countdown {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    width: 100%;
    margin: 4.3% auto -1% auto;
    --gap: 16px;
    gap: var(--gap);
  }

  .pop-container .unit {
    display: flex;
    gap: var(--gap);
    align-items: stretch;
    width: 40%;
  }

  .pop-container .digit-box {
    width: calc(50% - var(--gap)/2);
    height: auto;
    aspect-ratio: 88/105;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    align-items: center;
  }

  .pop-container .label {
    font-size: clamp(8px,0.8vw,12px);
    color: var(--label);
  }

  .pop-container .digit {
    font-size: clamp(48px,4vw,64px);
    font-weight: 800;
    color: var(--digit);
    line-height: 0.75;
  }

  .pop-container .is-hidden {
    display: none;
  }

  .pop-container {
    display: flex;
    justify-content: space-between;
    padding: 16px;
    background: #F8EFDC;
    gap: 12px;
    max-width: 1353px;
    overflow:hidden;
  }

  .pop_banner {
    width: 61.78%;
    padding:0!important;
  }

  .pop_content {
    width: 37.31%;
    border: 1px solid #2631134D;
    position: relative;
    padding: 6% 0 10px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pop_star {
    width: 13.5%;
    position: absolute;
    right: -18px;
    top: 26%;
  }

  .pop_button {
    width: 71%;
    background: #FFBE32;
    margin: 0 auto;
    margin-top: 4.3%;
    padding: clamp(12px,1.4vw,16px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #3A2307;
    border-radius: 32px;
    box-shadow: 0px 2px 5px 0px #0000000D, 0px 9px 9px 0px #0000000A, 0px 20px 12px 0px #00000008, 0px 35px 14px 0px #00000003,
      0px 55px 15px 0px #00000000;
    font-size:clamp(16px,1.6vw,24px);
    line-height:1;
  }

  .pop_leaves{
    position:absolute;

  }
  .pop_leaves1{
    top:0;
    left:0;
    transform:translate(-30%,-60%) rotate(5deg);
    width:40%;
    height:auto;
  }
    .pop_leaves2{
    bottom:0;
    right:0;
    transform:translate(45%,50%) rotate(155deg);
    width:37%;
    height:auto;
  }
  .pop_content img{
padding:0!important;}
  @media(max-width:980px){
            .pop-container .countdown{
    --gap: 10px;
    }
  }
    @media(max-width:768px){
    .pop-container{
      max-width:80vw;
      width:100vw;
      height:auto;
      max-height:95dvh;
      aspect-ratio:493.28/739.56;
    }

    .countdown{
    --gap: 12px;
    }

    .pop_banner{
      display:none;
    }
    .pop_content{
      width:100%;
      justify-content:center;
    }
  }

    @media(max-width:500px){
      .pop-container{
        max-width:90vw;
      }
          .unit{
      width: 45%;
    }
          .countdown{
    --gap: 8px;
    }
  }
</style>
