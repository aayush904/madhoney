<!-- Product Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": "{{ product.title | escape }}",
  "url": "{{ shop.url }}{{ product.url }}",
  "image": [
    {% for image in product.images %}
      "https:{{ image | image_url: width: 2048 }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "description": "{{ product.description | strip_html | strip_newlines | escape }}",
  "sku": "{{ product.selected_or_first_available_variant.sku }}",
  "category": "{{ product.type | escape }}",
  "brand": {
    "@type": "Brand",
    "name": "{{ product.vendor | escape }}"
  }

  {% comment %}
{% if product.metafields.reviews.rating.value %}

,"aggregateRating": {
  "@type": "AggregateRating",
  "ratingValue": "{{ product.metafields.reviews.rating.value.rating }}",
  "bestRating": "{{ product.metafields.reviews.rating.value.scale_max }}",
  "reviewCount": "{{ product.metafields.reviews.rating_count }}"
}

{% endif %}
{% endcomment %}

  ,
  "offers": [
    {% for variant in product.variants %}
    {
      "@type": "Offer",
      "name": "{{ variant.title | escape }}",
      "url": "{{ shop.url }}{{ variant.url }}",
      "sku": "{{ variant.sku }}",
      "priceCurrency": "{{ cart.currency.iso_code }}",
      "price": "{{ variant.price | divided_by: 100.0 }}",
      "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "seller": {
        "@type": "Organization",
        "name": "{{ shop.name | escape }}"
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
    {% else %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          }
            {%- if template.name == 'collection' -%}
            {%- assign breadcrumb_index = 2 -%}
            {%- if current_tags == blank -%}
              ,
              {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "name": "{{ collection.title }}",
              "item": "{{ shop.url }}{{ collection.url }}"
              }
            {%- endif -%}
            {%- elsif template.name == 'product' -%}
            {%- assign breadcrumb_index = 2 -%}
            ,
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              {%- assign variant_name = product.selected_variant.title  -%}
              {%- assign title_postfix = product.selected_or_first_available_variant.metafields.custom.title_postfix.value  -%}
              {% if variant_name != 'Default Title' and variant_name != blank %}
                {% assign title_postfix = title_postfix | append: ' | ' | append: variant_name %}
                {% assign product_url = shop.url | append: product.selected_variant.url %}
              {% else %}
                {% assign title_postfix = title_postfix %}
                {% assign product_url = shop.url | append: product.url %}
              {% endif %}
              "name": "{{ product.title | append : ' - ' | append: title_postfix }}",
              "item": "{{product_url}}"
            }
            {%- elsif template.name == 'blog' -%}
            {%- assign breadcrumb_index = 2 -%}
            ,
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "name": "{{ blog.title }}",
              "item": "{{ shop.url }}{{ blog.url }}"
            }
            {%- elsif template.name == 'article' -%}
            {%- assign breadcrumb_index = 2 -%}
            ,
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "name": "Mad Honey",
              "item": "{{ shop.url }}/blogs/mad-honey"
            }
            {%- assign breadcrumb_index = breadcrumb_index | plus: 1 -%}
            ,
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "name": "{{ article.title }}",
              "item": "{{ shop.url }}{{ article.url }}"
            }
            {%- elsif template.name == 'page' -%}
            {%- assign breadcrumb_index = 2 -%}
            ,
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "name": "{{ page.title }}",
              "item": "{{ shop.url }}{{ page.url }}"
            }
            {%- endif -%}
        ]
      }
    </script>
    {% endif %}

