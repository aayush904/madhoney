    "basmil_image_text_9cE9b7": {
      "type": "basmil-image-text",
      "blocks": {
        "content_6WDJXT": {
          "type": "content",
          "settings": {
            "title": "The Roman-Turkey Battle\n<style>\n#mithridates-gradient::after{\ncontent:'';\nwidth:100%;\nheight: 60%;\n  background: linear-gradient(0, #000000 0%, rgba(0, 0, 0, 0) 45.77%);\nposition:absolute;\nbottom:0;\n}\n\n@media(max-width:768px){\n#mithridates-gradient::after{\ncontent:none;\n}\n}\n</style>",
            "subtitle": "",
