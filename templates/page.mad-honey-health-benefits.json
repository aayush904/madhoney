    "basmil_image_text_DRYT73": {
      "type": "basmil-image-text",
      "blocks": {
        "content_rrJzzJ": {
          "type": "content",
          "settings": {
            "title": "Mad Honey Health benefits Testament by the Gurungs of Nepal",
            "subtitle": "",
            "description": "<p>The tradition of Nepal shows immense respect for ancient spices, herbs and food. Due to their habits of depending on the traditional way, the older generation is still robust and active. Likewise, the Gurungs are called the bravest and strongest tribesmen of Nepal. While hunting the honey for their livelihood, they also consumed the honey harvested during the process. Here is a testament of Mad Honey health benefits by the Gurungs of Nepal.</p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        }
      },
      "block_order": [
        "content_rrJzzJ"
      ],
