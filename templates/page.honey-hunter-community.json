          "settings": {
            "title": "The Honey Hunters of Nepal: A Heritage of <br>Skill and Courage",
            "subtitle": "",
            "description": "<p>Fearless adventurers who climb high cliffs and brave the wild to gather sweet, prized mad honey. With rich traditions passed down through generations, they maintain a deep connection with nature, tradition, and incredible Himalayan giant bees.</p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
