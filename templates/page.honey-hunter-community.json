    "custom_liquid_RMXnre": {
      "type": "custom-liquid",
      "custom_css": [
        "* {display: none;}"
      ],
      "settings": {
        "custom_liquid": "<script>\n    // Get the main elements\n    const videoContainer = document.getElementById('video-youtube');\n    const img = videoContainer.querySelector('img');\n    const originalPlayButton = videoContainer.querySelector('.play-button');\n    const contentSide = videoContainer.querySelector('.content-side');\n    // Store original styles\n    const originalStyles = {\n        position: originalPlayButton.style.position,\n        transform: originalPlayButton.style.transform\n    };\n    \n    // Function to handle responsive layout\n    function handleResponsiveLayout() {\n        const screenWidth = window.innerWidth;\n        \n        if (screenWidth <= 1024) {\n            // Clone the play button if it hasn't been done yet\n            if (!videoContainer.querySelector('.playbutton-clone')) {\n                const playButtonClone = originalPlayButton.cloneNode(true);\n                playButtonClone.classList.add('playbutton-clone');\n                \n                // Remove specific classes from clone\n                playButtonClone.classList.remove('top-[auto!important]', 'left-[auto!important]');\n                playButtonClone.style.position = 'absolute';\n                playButtonClone.style.transform = 'translate(-50%, -50%) scale(0.7)';\n                \n                // Remove original play button\n                originalPlayButton.remove();\n                \n                // Insert clone after the image\n                img.insertAdjacentElement('afterend', playButtonClone);\n            }\n        } else {\n            // Restore original layout for larger screens\n            if(!contentSide.querySelector('.play-button')){\n                contentSide.appendChild(originalPlayButton);\n                const clonedButton = videoContainer.querySelector('.playbutton-clone');\n                \n                if (clonedButton) {\n                    clonedButton.remove();\n                    \n                    // Restore original styles\n                    originalPlayButton.style.position = originalStyles.position;\n                    originalPlayButton.style.transform = originalStyles.transform;\n                    \n                }\n            }\n        }\n    }\n    \n    // Initial check\n    handleResponsiveLayout();\n    \n    // Listen for window resize\n    window.addEventListener('resize', handleResponsiveLayout);\n    </script>",
        "color_scheme": "background-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
