    "basmil_image_text_xRzLJX": {
      "type": "basmil-image-text",
      "blocks": {
        "content_tzFbBg": {
          "type": "content",
          "settings": {
            "title": "Our Product is Eco-Friendly",
            "description": "<p>Mad Honey Soap celebrates sustainability and eco-friendly innovation. We repurpose the wax residue from mad honey into something worthwhile. The Gurung honey hunters rejoice in the creative use of the waste, which was once a hurdle for them to manage.  Every ingredient—olive oil, fruit oil, tea leaves, and seeds is natural and eco-friendly. <\/p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
        "image_UKXN96": {
          "type": "image",
          "settings": {
            "image_type": "image",
            "image": "shopify:\/\/shop_images\/image_66.png",
            "image_alt": "Mad Honey",
            "svg": "",
            "image_width": "30.96%"
          }
        }
      },
