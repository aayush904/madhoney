    "basmil_image_text_49NCQq": {
      "type": "basmil-image-text",
      "blocks": {
        "content_jExBbw": {
          "type": "content",
          "settings": {
            "title": "How to Use it?",
            "description": "<p>Keep your Mad Honey Soap happy by letting it dry on a well-drained dish between uses. Too big to handle? Just cut it in half! Do a quick patch test first, and if it doesn’t vibe with your skin, you can stop using it. <\/p><h2>For a Healthy Glowing Skin <\/h2><ol><li>Wash your face daily with Mad Honey Soap for a natural, gentle cleanse.<\/li><li>Let the tea leaves and seeds in the soap softly exfoliate your skin.<\/li><li>Enjoy its moisturizing properties for a hydrated, healthy glow.<\/li><li>Wash your face with it after you apply any natural face pack for smoother, brighter skin over time.<\/li><li>Pair it with a good skincare routine for the ultimate radiant look.<\/li><\/ol><p><\/p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
        "image_PBqbEi": {
