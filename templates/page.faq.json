    "faq_WWPC3P": {
      "type": "faq",
      "blocks": {
        "text_RxTyZp": {
          "type": "text",
          "settings": {
            "question": "Are your mad honey and mad honey-based products lab tested and certified?",
            "answer": "<p>Yes, each batch of our mad honey is tested in Nepal Government food laboratories and independently verified in the USA.</p>"
          }
        },
        "text_AbCdEf": {
          "type": "text",
          "settings": {
            "question": "Are your products suitable for vegans?",
            "answer": "<p>No. All of our products contain honey or beeswax making them unsuitable for vegans.</p>"
          }
        },
        "text_GhIjKl": {
          "type": "text",
          "settings": {
            "question": "Are your products suitable for pregnant and breastfeeding women?",
            "answer": "<p>We would not advise our products to be used if you are pregnant or breastfeeding without discussing this with your physician.</p>"
          }
        },
        "text_MnOpQr": {
          "type": "text",
          "settings": {
            "question": "Are your products tested on animals?",
            "answer": "<p>Absolutely not!</p>"
          }
        },
        "text_StUvWx": {
          "type": "text",
          "settings": {
            "question": "Are your products eco-friendly?",
            "answer": "<p>Yes, we use sustainable jars and packaging materials.</p>"
          }
        },
        "text_YzAbCd": {
          "type": "text",
          "settings": {
            "question": "Are your products organic?",
            "answer": "<p>Our products are not certified organic but we endeavor to use natural ingredients where possible.</p>"
          }
        },
        "text_EfGhIj": {
          "type": "text",
          "settings": {
            "question": "What is the lifespan of your products?",
            "answer": "<p>Our honey is collected in small quantities from various regions across Nepal and is properly stored in our packaging facility. We produce our soap and lip balms in small batches to ensure they are as fresh as possible at the point of sale. Each product label indicates its shelf life after the first opening.</p>"
          }
        },
        "text_KlMnOp": {
          "type": "text",
          "settings": {
            "question": "Do you take custom or bulk orders?",
            "answer": "<p>Yes, we do! Mad Honey is available in stock throughout the year. However, please note that cold process soaps and lip balms take 4-6 weeks to cure. So if you’d like to place a custom order, we would need to finalize the design, fragrance, etc., at least one month in advance to be able to give you your finished product in time.</p><p>For bulk orders as well, unless we do have stock available, you might need to place your order with us at least 3 weeks in advance.</p>"
          }
        },
        "text_QrStUv": {
          "type": "text",
          "settings": {
            "question": "How do you collaborate with honey hunters?",
            "answer": "<p>We work with over 84 honey-hunting communities in Nepal to source the finest mad honey and beeswax. We are collaboratively working with the government and honey hunters to save the Himalayan giant bees and hives every year through our social initiatives.</p>"
          }
        },
        "text_WxYzAb": {
          "type": "text",
          "settings": {
            "question": "Are your honey jars glass or plastic?",
            "answer": "<p>Our premium mad honey jars are made from 100% recycled plastic (rPET), which is food-safe and BPA-free. After extensive research, we found that recycled plastics are more environmentally friendly than glass from a lifecycle perspective, making them the better choice for sustainability.</p><p>For our limited reserve jars, we use glass, which preserves the honey's purity and potency over an extended period. All our jars, whether plastic or glass, are fully recycled and 100% recyclable. By ensuring your jar ends up in the recycling bin, you are contributing to a more sustainable future.</p>"
          }
        }
      },
