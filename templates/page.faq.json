    "faq_zFKNGw": {
      "type": "faq",
      "blocks": {
        "text_AcDeFg": {
          "type": "text",
          "settings": {
            "question": "How often will my honey arrive?",
            "answer": "<p>The default subscription timeframe is every 30 or 60 days. You can change this either when you place your first subscription order, or at any time from your customer dashboard.</p>"
          }
        },
        "text_HiJkLm": {
          "type": "text",
          "settings": {
            "question": "How do I cancel my subscription?",
            "answer": "<p>You can cancel your subscription at any time via your customer dashboard. You must cancel at least 4 days before your next subscription order is due to arrive, otherwise you will be charged for one last order.</p>"
          }
        },
        "text_NoPqRs": {
          "type": "text",
          "settings": {
            "question": "How can I change the honey I have on my subscription?",
            "answer": "<p>Simply go to your customer dashboard, and click 'edit subscription' - this will allow you to change the product you have subscribed to, or add a one-off product to your next order.</p>"
          }
        },
        "text_TuVwXy": {
          "type": "text",
          "settings": {
            "question": "Can I pause my subscription?",
            "answer": "<p>You can skip a delivery in your subscription at any time, if you are going to be away for the next scheduled delivery, or if you feel that you still have enough honey and won't need any until your next scheduled delivery date.</p>"
          }
        },
        "text_ZaBcDe": {
          "type": "text",
          "settings": {
            "question": "How do I change the address on my subscription?",
            "answer": "<p>Visit your customer dashboard, and click 'edit my details.' Enter your new address. You must change your address at least 7 days before your next subscription delivery is due, or it may be delivered to your old address.</p>"
          }
        },
        "text_FgHiJk": {
          "type": "text",
          "settings": {
            "question": "What are the benefits of ordering on subscription?",
            "answer": "<p>You will receive a 20% discount on every single jar you purchase with us!</p><p>You don't have to remember to purchase, simply wait for the honey to arrive at the same time every month so you always have a supply of raw MadHoney.</p><p>You can still take advantage of our promotions and sales if there is a different jar you would like that is discounted. Simply make a purchase as normal, or add a jar to your next subscription delivery by visiting your customer dashboard.</p>"
          }
        }
      },
