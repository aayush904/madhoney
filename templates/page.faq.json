    "faq_XNhREX": {
      "type": "faq",
      "blocks": {
        "text_AbCdEf": {
          "type": "text",
          "settings": {
            "question": "What is your soap packaged in?",
            "answer": "<p>Recycled paper, plastic wrap and cardboard. We have chosen these materials as it keeps your soaps free from contact and other contaminants whilst awaiting purchase and can decompose leaving no mark on our beautiful planet.</p>"
          }
        },
        "text_GhIjKl": {
          "type": "text",
          "settings": {
            "question": "I'm confused, I thought your soaps were natural but they contain things such as oils, why is this?",
            "answer": "<p>Our current soaps are entirely natural. They are, for the most part, derived from vegetables and we use natural colours and scents.</p>"
          }
        },
        "text_MnOpQr": {
          "type": "text",
          "settings": {
            "question": "Are your soaps suitable for young children?",
            "answer": "<p>All of our <a href=\"https://medicinalmadhoney.com/products/mad-honey-soap\" target=\"_blank\" title=\"Mad Honey Soap\">soaps</a> are human tested. We are advised they should be avoided for children under the age of 7.</p>"
          }
        },
        "text_StUvWx": {
          "type": "text",
          "settings": {
            "question": "Can I use the soap on my face?",
            "answer": "<p>Yes, but please avoid contact with eyes or mouth. If you do accidentally get it in your eyes or mouth please rinse thoroughly with clean water.</p>"
          }
        },
        "text_YzAbCd": {
          "type": "text",
          "settings": {
            "question": "Why does my soap have imperfections? Why doesn’t it look exactly like the photo?",
            "answer": "<p>Our soaps are handcrafted in small batches and cut by hand and therefore no two bars will be alike. Various uncontrolled factors affect how saponification takes place and hence soaps vary from batch to batch as do designs. These are artisanal products so please allow for slight variations and imperfections, these make each bar unique and that’s what we love about it.</p>"
          }
        }
      },
