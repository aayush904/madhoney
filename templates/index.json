    "mad_honey_tabs_NUjgnM": {
      "type": "mad-honey-tabs",
      "blocks": {
        "tab_K3HpjK": {
          "type": "tab",
          "settings": {
            "tab_image": "shopify://shop_images/DSC02705-2_blurr_1.webp",
            "tab_label": "hive",
            "tab_title": "Hundreds of Metres Above the Ground",
            "tab_subtitle": "HIVES OF THE WILD",
            "tab_content": "Apis laboriosa chooses to shelter in sheer granite faces standing amidst the dense forests of the mountains. They build multiple huge open-air hives hundreds of metres above the forest floor where a single colony containing hundreds to one hundred thousand bees resides. Hives extend up to 6 feet in both width and length where hundreds of kilograms of honey can be stored. The honey hunters harvest what the hive can spare. They cut the combs leaving portions on which developing brood feed.",
            "button_text": "Hive to Jar Process",
            "button_link": "shopify://pages/hive-to-jar"
          }
        },
        "tab_Cq9rpV": {
          "type": "tab",
          "settings": {
            "tab_image": "shopify://shop_images/Mask_group_b9bc1810-a193-4080-bd3d-ed40a16a851d.webp",
            "tab_label": "origin",
            "tab_title": "Nepal and Turkey’s Liquid Gold",
            "tab_subtitle": "Mad Honey Origins",
            "tab_content": "Mad honey from Nepal has created a buzz. It is a result of Himalayan giant honeybees meeting alpine and subalpine flowers thriving in the altitude, soil, and environment of the mountains. The only other region where mad honey has been reported is Turkey's Black Sea coast but it does not match the truly wild Himalayan origin of Nepal. There, bees naturally select their suitable habitat and build hives from scratch, unlike in Turkey where beekeepers build traditional hives and secure them in trees near the rhododendron forests.",
            "button_text": "Trace Mad Honey Origins",
            "button_link": "shopify://pages/mad-honey-nepal-turkey-origins"
          }
        },
        "tab_BPPiPG": {
          "type": "tab",
          "settings": {
            "tab_image": "shopify://shop_images/Mask_group-1_182ded2d-6f44-4499-bfd8-de718fabd40c.webp",
            "tab_label": "usage",
            "tab_title": "How to Enjoy Himalayan Mad Honey",
            "tab_subtitle": "MAD HONEY USAGE",
            "tab_content": "Rhododendron is the most common mountain flora among different high-altitude flowering species. Its nectar and other different parts of rhododendron naturally contain grayanotoxin making its trace presence a characteristic feature of mad honey. This presence demands responsible consumption practices. All new users should begin consumption with one teaspoon, slowly increasing it to one tablespoon. In the meantime, all introduced doses need tolerance monitoring. This calculative approach allows users to establish a responsible dosing pattern.",
            "button_text": "Read Responsible Use Guide",
            "button_link": "shopify://pages/health-benefits-of-mad-honey"
          }
        },
        "tab_Y33w4i": {
          "type": "tab",
          "settings": {
            "tab_image": "shopify://shop_images/Group_28470.webp",
            "tab_label": "certification",
            "tab_title": "Lab-Tested &amp; Certified Honey",
            "tab_subtitle": "AUTHENTIC & TRACEABLE",
            "tab_content": "Every batch of our mad honey is lab-tested for purity. We check key honey quality markers such as Moisture, Acidity, HMF, Ash, Fructose/Glucose Ratio, Sucrose  Grayanotoxin (GTNX) Level. Our core lies in identifying mad honey by its source, not only by its name. Our products are packaged with QR-based traceability, allowing verification of harvest details, batch records, and source documentation connected to that specific collection.",
            "button_text": "",
            "button_link": ""
          }
        },
        "tab_rJBmPk": {
          "type": "tab",
          "settings": {
            "tab_image": "shopify://shop_images/image_196.webp",
            "tab_label": "founders",
            "tab_title": "12 Years with Honey Hunters ",
            "tab_subtitle": "Our Experience",
            "tab_content": "We are the honey hunters, the guardians of tradition, and the storytellers of Nepal's liquid gold. Since 2012, we've worked with local communities to bring this honey from Nepal to the world.\nWe don't buy our honey, we save our wild bees while they create it. All our honey is bottled and labeled in Nepal.\nIt all started with our founder's vision and love for bees, and his home town and nature.\nToday, every jar of our honey can be traced back to its origin right down to the honey hunters who harvested it using techniques passed down through generations. ",
            "button_text": "Meet Our Founders",
            "button_link": "shopify://pages/meet-our-founders"
          }
        }
      },
      "block_order": [
        "tab_K3HpjK",
        "tab_Cq9rpV",
        "tab_BPPiPG",
        "tab_Y33w4i",
        "tab_rJBmPk"
      ],
