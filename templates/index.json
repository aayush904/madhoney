        "content_kVn4zm": {
          "type": "content",
          "settings": {
            "title": "<div class=\"flex sm:flex-col gap-[16px_3.2rem] justify-start items-center\" style=\"gap: 0px 2.4rem;\">\n<img class=\"svg\" src=\"https://cdn.shopify.com/s/files/1/0663/9966/6326/files/rare_honey_56af3495-29b2-4320-a141-11b87b24f5b2.svg?v=1764133258\" alt=\"Medicinal Mad Honey's Premium honey\" width=\"\" height=\"\">\n<h2 style=\"font-size:clamp(32px,3.2vw,4rem);\" class=\"font-bold\">\nLimited Reserve<br>Mad Honey\n</h2>\n</div>",
            "subtitle": "",
            "description": "<p><em>Only 200 Jars . One Harvest . Never Again</em></p><p></p><p><em>A creation of altitude and tradition - gathered at 4,500+ meters </em>from the highest cliff hives of <a href=\"/pages/the-himalayan-giant-honey-bees\" target=\"_blank\" title=\"apis laboriosa\"><strong>Apis laboriosa</strong></a>. Each jar is hand-collected on the high cliffs of Lamjung by the region’s most experienced honey hunters, preserving a craft passed down through generations.</p><p></p><ul><li><em>Harvested at 4,500m+ altitude from hives of Apis laboriosa</em></li><li><em>Collected by the oldest and most skilled master honey hunters</em></li><li><em>Raw deep-amber honey with a naturally bold profile</em></li><li><em>In luxury wooden packaging with a signed Certificate of Origin</em></li></ul>",
            "button_text": "Reserve My 2026 Edition",
            "button_link": "shopify://pages/limited-reserve-mad-honey",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
