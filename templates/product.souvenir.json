      "settings": {
        "custom_liquid": "<!-- Start of Judge.me code --> \n  <div class='jdgm-carousel-wrapper'> \n    {% assign jm_metafields = shop.metafields.judgeme %} \n    <div class='jdgm-carousel-title-and-link'> \n      <h2 class='jdgm-carousel-title'>Let customers speak for us</h2> \n      <span class='jdgm-all-reviews-rating-wrapper' href='javascript:void(0)'> \n        <span style='display:block' data-score='{{ jm_metafields.all_reviews_rating }}' class='jdgm-all-reviews-rating' aria-label='{{ jm_metafields.all_reviews_rating }} stars' tabindex='0' role='img'></span> \n        <span style='display: block' class='jdgm-carousel-number-of-reviews' data-number-of-reviews='{{ jm_metafields.all_reviews_count }}'> \nfrom {{ shop.metafields.judgeme.all_reviews_count }} reviews \n        </span> \n      </span> \n    </div> \n    {{ jm_metafields.featured_carousel }} \n  </div> \n<!-- End of Judge.me code -->\n\n<style>\n.custom-liquid .color-background-1.gradient {\n  background: transparent !important;\n  margin: auto;\n  padding: 0 16px;\n  width: 87;\n}\n.jdgm-carousel-item__product-title.jdgm-ellipsis,.jdgm-carousel-item__review-title {\n  color: #fff;\n  font-weight: 600;\n}\n.jdgm-widget p {\n  color: #fff !important;\n}\n.jdgm-carousel-item__reviewer-name,.jdgm-carousel-number-of-reviews {\n  color: #e0af7e!important;\n}\n.jdgm-carousel-wrapper .jdgm-carousel.jdgm-carousel--compact-theme{\nmargin:0 auto;\nfloat:none;\n}\n@media (max-width: 1200px) {\n .custom-liquid  .color-background-1.gradient {\n    max-width: 116.6rem;\n    margin: auto;\n    width: 100%;\n  }\n}\n@media (min-width: 1600px) {\n  .custom-liquid .color-background-1.gradient {\n    max-width: 1440px;\n    margin: auto;\n  }\n}\n</style>",
