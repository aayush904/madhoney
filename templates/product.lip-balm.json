    "text_video_pzEz6J": {
      "type": "text-video",
      "blocks": {
        "content_PQymw3": {
          "type": "content",
          "settings": {
            "title": "How to Use It",
            "description": "<p>Our Mad Honey Lip Balm offers long-lasting hydration, keeping your lips soft and smooth all day or overnight. Reapply as needed for continuous moisture and protection, without fading away. Perfect for morning, evening, or anytime you need a boost.</p><h2>For Soft, Kissable Lips</h2><ul><li>Apply a generous layer of Mad Honey Lip Balm to lock in moisture and nourish your lips.</li><li>Reapply throughout the day to protect your lips from dryness.</li><li>Use it to protect your lips from the wind, sun, or cold weather, keeping them smooth. </li><li>Pair your lip gloss with your favorite lip gloss or lipstick for a more healthy, natural pout.</li><li>Use as an overnight lip mask to get hydrated and refreshed lips by morning.</li></ul>",
            "button_link": "",
            "button_text": ""
          }
        },
