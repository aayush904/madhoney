    "basmil_image_text_eGTpYC": {
      "type": "basmil-image-text",
      "blocks": {
        "content_LHLQ76": {
          "type": "content",
          "settings": {
            "title": "We are Eco-friendly",
            "subtitle": "",
            "description": "<p>We are proud to be the first to uncover the true potential of mad honey, turning mad wax residue into something extraordinary for lips. Mad Honey Lip Balm represents sustainability and eco-friendly creativity. With natural ingredients like olive oil, grapeseed oil, apricot oil, and mad honey beeswax, each application is a guilt-free indulgence. </p>",
            "button_text": "",
            "button_link": "",
