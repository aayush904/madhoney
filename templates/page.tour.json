    "basmil_image_text_jEfDFM": {
      "type": "basmil-image-text",
      "blocks": {
        "content_TXF8hy": {
          "type": "content",
          "settings": {
            "title": "Mad Honey Hunting Tour",
            "subtitle": "",
            "description": "<p><a href=\"/pages/honey-hunter\" target=\"_blank\" title=\"honey hunter\">Mad Honey Hunting</a> is an ancient tradition where Nepal’s honey hunters climb delicate, handwoven ladders that hang from the high cliffs of the Himalayas. The Gurung people have faced this risky journey for centuries, preserving their tradition and sharing remarkable challenges and stories. Each year, we invite a small group of adventurers to join this exclusive expedition, allowing them to experience the stunning views and captivating tales of this timeless honey hunting practice.</p>",
            "button_text": "",
            "button_link": "#",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
