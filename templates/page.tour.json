    "basmil_text_cards_DN8p3M": {
      "type": "basmil-text-cards",
      "blocks": {
        "content_xMEef9": {
          "type": "content",
          "settings": {
            "card_one": "<h3>Personal Care (6 items)</h3><p>First Aid Kit & Medications (Lightweight)<br/>Sunblock, Lip Balm, Sunglasses,<br/>Face Mask, Insect Repellent<br/>Water Bottles (3x 1L) or Hydration System + 1L Bottle<br/>Personal Bathroom Kit: Toilet Paper, Wipes, Hand Cleaner<br/>Sleeping Bag</p>",
            "card_two": "<h3>Other Essentials (6 items)</h3><p>Drone & Camera Accessories<br/>Reading and Writing Materials<br/>Small Binoculars<br/></p>"
          }
        },
        "content_zMzCjy": {
          "type": "content",
          "settings": {
            "card_one": "<h3>Backpack and Storage (3 items)</h3><p>Backpacking Pack (65-75L)<br/>Day Pack (Lightweight, Compressible)<br/>Garbage Bag & Pack Rain Cover</p>",
            "card_two": "<h3>Clothing (8 items)</h3><p>Insulated Jacket or Vest & Gloves<br/>Lightweight Base Layer Tops and Bottoms (Synthetic or Cotton)<br/>Hiking Gear: Sun Hat, Boots, Socks, Pants & Shorts (Quick-Dry)<br/>Long Sleeve Shirts & Tee Shirts (Synthetic, Lightweight)<br/>Rain Jacket & Pants (Lightweight, Waterproof)<br/></p>"
          }
        }
      },
      "block_order": [
