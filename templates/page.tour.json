        "slide_EWcUM9": {
          "type": "slide",
          "settings": {
            "heading": "Day 4",
            "subheading": "Night Stay at a hotel in Besisahar",
            "paragraph": "<p><strong>Accommodation:</strong> Night Stay at a hotel in Besisahar</p><p>A hearty breakfast, a short briefing session about the upcoming trials and with the rising sun, we head towards the mad honey hunting site. Our team ensures that all the joinees have the right gear and prioritizes their safety as our topmost concern.<br/><br/>After a pleasant half-hour to 45-minute walk from the homestay, filled with cascading waterfalls and breathtaking mountain ranges, we reach the mad honey hunting site. The hunting will last for 4 to 5 hours, we will then go to the homestay for rest and food. The night ends with a farewell ceremony helping you feel a lasting bond with the people and place of the Himalayas.</p>",
            "image": "shopify://shop_images/Frame_1618872216.webp",
            "image_layout": "left",
            "slider_content_alignment": "left"
          }
        },
        "slide_6qb39w": {
