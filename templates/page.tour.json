            "title": "<white>Experience the</white> Thrill of Adventure <white>of Honey Hunting.</white>",
            "subtitle": "<style>\n  /* overlay */\n  .tour-init * {\n    font-family: Lato;\n  }\n\n  /* modal container */\n  .tour-init__box {\n    background: #ffffff;\n    padding: 32px 24px;\n    /* 32px top-bottom, 24px left-right */\n    max-width: 400px;\n    /* ­roughly the width in screenshot */\n    width: 90vw;\n    border-radius: 4px;\n    position: relative;\n    font-size: 14px;\n    /* base font 14 px */\n    line-height: 1.45;\n    font-weight: normal;\n    /* ensure no bold text */\n  }\n\n  /* close button */\n  .tour-init__close {\n    position: absolute;\n    top: 18px;\n    right: 18px;\n    background: none;\n    border: 0;\n    font-size: 20px;\n    cursor: pointer;\n  }\n\n  /* headings / section titles */\n  .tour-init__heading {\n    font-size: 14x;\n    /* 16 px */\n    margin-bottom: 8px;\n  }\n\n  /* main price line */\n  .tour-init__price {\n    font-size: 16px;\n    margin-top: 0;\n    margin-bottom: 24px;\n  }\n\n  /* info (duration & group size) */\n  .tour-init__info {\n    display: flex;\n    gap: 18px;\n    justify-content: space-between;\n    margin: 0;\n    margin-bottom: 24px;\n  }\n\n  .tour-init__info-label {\n    font-size: 14px;\n    /* 12 px */\n    color: #000000;\n    margin-bottom: 8px;\n  }\n\n  .tour-init__info-value {\n    font-size: 16px;\n    /* 14 px */\n    color: #000000;\n  }\n\n  /* payment options */\n  .tour-init__group {\n    display: flex;\n    gap: 18px;\n    margin: 0;\n    margin-top: 16px;\n  }\n\n  .tour-init__group {\n    margin-bottom: 24px;\n  }\n\n  .tour-init__option {\n    flex: 1;\n    text-align: center;\n    padding: 1em 0.5em;\n    border: 1px solid #000000;\n    background: #ffffff;\n    color: #000000;\n    cursor: pointer;\n    transition: 0.2s;\n    font-size: 14px;\n  }\n\n  .tour-init__option:hover {\n    background: #BE935F60;\n    /* 38 % opacity hover */\n    color: #BE935F;\n  }\n\n  .tour-init__option.active {\n    background: #BE935F;\n    color: #ffffff;\n  }\n\n  /* departure dates */\n  .tour-init__dates {\n    display: flex;\n    gap: 18px;\n    margin-bottom: 16px;\n  }\n\n  .tour-init__date {\n    flex: 1;\n    text-align: center;\n    padding: 1.1em 0.6em;\n    border: 1px solid #000000;\n    background: #ffffff;\n    color: #000000;\n    cursor: pointer;\n    transition: 0.2s;\n    font-size: 14px;\n  }\n\n  .tour-init__date:hover {\n    background: #BE935F60;\n    color: #BE935F;\n  }\n\n  .tour-init__date.active {\n    background: #BE935F;\n    color: #ffffff;\n  }\n\n  /* primary CTA */\n  .tour-init__btn {\n    display: block;\n    width: 100%;\n    background: #000000;\n    color: #BE935F;\n    text-align: center;\n    padding: 1.15em 0;\n    font-size: 16px;\n    text-decoration: none;\n    margin-bottom: 2em;\n    transition: 0.2s;\n  }\n\n  .tour-init__btn:hover {\n    opacity: 0.85;\n  }\n\n  /* contact list */\n  .tour-init__contact_title {\n    font-size: 14px;\n  }\n\n  .tour-init__contact {\n    padding-left: 0;\n  }\n\n  .tour-init__contact li {\n    list-style: none;\n    display: flex;\n    align-items: center;\n    gap: 0.55em;\n    font-size: 12px;\n    margin-bottom: 0.55em;\n  }\n\n  .tour-init__contact .icon {\n    font-size: 12px;\n  }\n\n  /* ── slide helpers (no \"*\" selector used) ────────────────────────────── */\n  .slide-transition {\n    transition: transform .4s ease, opacity .4s ease;\n  }\n\n  .slide-start {\n    /* element is off-screen to the left     */\n    transform: translateX(100%);\n    opacity: 0;\n  }\n\n  .slide-end {\n    /* element is in its final (visible) spot */\n    transform: translateX(0);\n    opacity: 1;\n  }\n</style>\n\n<div class=\"tour-init\">\n  <div class=\"tour-init__box\">\n    <button class=\"tour-init__close\" aria-label=\"Close\">×</button>\n\n    <p class=\"tour-init__heading\">Starting from</p>\n    <p class=\"tour-init__price\">$1299 Per Person</p>\n\n    <!-- trip info -->\n    <div class=\"tour-init__info\">\n      <div>\n        <div class=\"tour-init__info-label\">Duration of The Journey</div>\n        <div class=\"tour-init__info-value\">5 Days</div>\n      </div>\n      <div>\n        <div class=\"tour-init__info-label\">Group Size</div>\n        <div class=\"tour-init__info-value\">10-15</div>\n      </div>\n    </div>\n\n    <!-- payment planning -->\n    <p class=\"tour-init__heading\">Payment Planning</p>\n    <div class=\"tour-init__group\">\n      <button class=\"tour-init__option active\" data-value=\"Deposit Fee\" data-amount=\"\">Deposit Payment</button>\n      <button class=\"tour-init__option\" data-value=\"Full Payment\" data-amount=\"\">Full Payment</button>\n    </div>\n\n    <!-- departure dates -->\n    <p class=\"tour-init__heading\">Departure Date</p>\n    <div class=\"tour-init__dates\">\n      <div class=\"tour-init__date\">November 2024</div>\n      <div class=\"tour-init__date\">May 2025</div>\n    </div>\n\n    <a href=\"\" data-base=\"https://medicinalmadhoney.com/products/tour\" class=\"tour-init__btn\">Book My Trip</a>\n\n    <!-- contact info -->\n    <p class=\"tour-init__contact_title\" style=\"margin-bottom:8px\">More info:</p>\n    <ul class=\"tour-init__contact\">\n      <li>\n<span class=\"icon\">\n          <svg width=\"16\" height=\"16\" viewbox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#D9D9D9\"></circle>\n            <path d=\"M4 4.5C4 4.36739 4.05268 4.24021 4.14645 4.14645C4.24021 4.05268 4.36739 4 4.5 4H5.5765C5.69485 4.00005 5.80935 4.04209 5.89962 4.11863C5.98989 4.19517 6.05009 4.30125 6.0695 4.418L6.4395 6.6355C6.45718 6.74111 6.44049 6.8496 6.39188 6.94502C6.34328 7.04043 6.26532 7.11771 6.1695 7.1655L5.3955 7.552C5.67305 8.23983 6.08642 8.86464 6.61089 9.38911C7.13536 9.91358 7.76017 10.3269 8.448 10.6045L8.835 9.8305C8.88276 9.73477 8.95997 9.65688 9.05528 9.60828C9.15058 9.55968 9.25897 9.54294 9.3645 9.5605L11.582 9.9305C11.6988 9.94991 11.8048 10.0101 11.8814 10.1004C11.9579 10.1906 11.9999 10.3051 12 10.4235V11.5C12 11.6326 11.9473 11.7598 11.8536 11.8536C11.7598 11.9473 11.6326 12 11.5 12H10.5C6.91 12 4 9.09 4 5.5V4.5Z\" fill=\"black\"></path>\n          </svg>\n\n        </span> +977 - 9823875502</li>\n      <li>\n<span class=\"icon\"><svg width=\"16\" height=\"16\" viewbox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#D9D9D9\"></circle>\n            <path d=\"M4 5.942L7.9985 7.941L11.997 5.942C11.9822 5.68722 11.8705 5.44774 11.6849 5.27261C11.4993 5.09748 11.2537 4.99995 10.9985 5H4.9985C4.74329 4.99995 4.49772 5.09748 4.31209 5.27261C4.12645 5.44774 4.0148 5.68722 4 5.942Z\" fill=\"black\"></path>\n            <path d=\"M12 7.05859L8 9.05859L4 7.05859V9.99959C4 10.2648 4.10536 10.5192 4.29289 10.7067C4.48043 10.8942 4.73478 10.9996 5 10.9996H11C11.2652 10.9996 11.5196 10.8942 11.7071 10.7067C11.8946 10.5192 12 10.2648 12 9.99959V7.05859Z\" fill=\"black\"></path>\n          </svg>\n        </span> contact@medicinalmadhoney.com</li>\n      <li>\n<span class=\"icon\"><svg width=\"16\" height=\"16\" viewbox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#D9D9D9\"></circle>\n            <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M8 12C9.06087 12 10.0783 11.5786 10.8284 10.8284C11.5786 10.0783 12 9.06087 12 8C12 6.93913 11.5786 5.92172 10.8284 5.17157C10.0783 4.42143 9.06087 4 8 4C6.93913 4 5.92172 4.42143 5.17157 5.17157C4.42143 5.92172 4 6.93913 4 8C4 9.06087 4.42143 10.0783 5.17157 10.8284C5.92172 11.5786 6.93913 12 8 12ZM8.5 6C8.5 5.86739 8.44732 5.74021 8.35355 5.64645C8.25979 5.55268 8.13261 5.5 8 5.5C7.86739 5.5 7.74021 5.55268 7.64645 5.64645C7.55268 5.74021 7.5 5.86739 7.5 6V8C7.50003 8.1326 7.55273 8.25975 7.6465 8.3535L9.0605 9.768C9.10696 9.81446 9.16211 9.85131 9.2228 9.87645C9.2835 9.90159 9.34855 9.91453 9.41425 9.91453C9.47995 9.91453 9.545 9.90159 9.6057 9.87645C9.66639 9.85131 9.72155 9.81446 9.768 9.768C9.81446 9.72155 9.85131 9.66639 9.87645 9.6057C9.90159 9.545 9.91453 9.47995 9.91453 9.41425C9.91453 9.34855 9.90159 9.2835 9.87645 9.2228C9.85131 9.16211 9.81446 9.10696 9.768 9.0605L8.5 7.793V6Z\" fill=\"black\"></path>\n          </svg>\n        </span> Mon-Fri 7 am-6 pm PT</li>\n    </ul>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    /* ──────────────────  A. TOUR-INIT MODAL  ────────────────── */\n    const modal = document.querySelector('.tour-init');\n    if (modal) {\n      const payBtns = modal.querySelectorAll('.tour-init__option');\n      const datesWrapper = modal.querySelector('.tour-init__dates')\n      const dateBtns = modal.querySelectorAll('.tour-init__date');\n      const ctaBtn = modal.querySelector('.tour-init__btn');\n      const priceDisplay = modal.querySelector('.tour-init__price');\n\n\n      const baseHref = ctaBtn.getAttribute('data-base')        // safest: supply data-base attr\n        || ctaBtn.getAttribute('href')            // fallback to whatever was there\n        || '#';\n\n\n      const params = {\n        \"selected_method\": '',\n        \"selected_date\": '',\n      };\n\n      // helper: serialise params → query string and push into the button\n      const updateCTA = () => {\n        const qs = new URLSearchParams(params).toString();     // e.g. selected_method=…&selected_date=…\n        ctaBtn.href = `${baseHref}?${qs}`;\n      };\n\n      const markSelected = (el) => {\n        if (el.classList.contains('tour-init__option')) {\n          modal.querySelectorAll('.tour-init__option')\n            .forEach(node => node.classList.toggle('active', node === el));\n        } else {\n          modal.querySelectorAll('.tour-init__date')\n            .forEach(node => node.classList.toggle('active', node === el));\n        }\n      };\n\n      // fetch the price of the the product\n      fetch('https://medicinalmadhoney.com/products/tour.json')\n        .then(response => response.json())\n        .then(data => {\n          const variants = data.product.variants;\n          const depositVariant = variants.find(variant => variant.title === \"Deposit Fee\");\n          const fullVariant = variants.find(variant => variant.title === \"Full Payment\");\n          params.selected_method = depositVariant.title;\n          updateCTA();\n\n          payBtns.forEach(btn => {\n            const label = btn.dataset.value.trim().toLowerCase();\n            const price = label === 'deposit fee' ? depositVariant.price : fullVariant.price;\n            const title = label === 'deposit fee' ? depositVariant.title : fullVariant.title;\n            // Store as a data attribute (data-amount) **and** a JS property for convenience\n            btn.dataset.amount = price;\n            priceDisplay.textContent = `$${depositVariant.price} Per Person`;\n            btn.addEventListener('click', (e) => {\n              markSelected(btn);                      // visual feedback\n              if (priceDisplay) {\n                priceDisplay.textContent = `$${btn.dataset.amount} Per Person`;\n                params.selected_method = btn.dataset.value;\n                updateCTA();\n\n              }\n            });\n          });\n          if (depositVariant) { } else {\n            console.log(\"Deposit Fee variant not found\");\n          }\n        })\n        .catch(error => console.error(\"Error fetching product data:\", error));\n\n\n      function getMayAndNovember() {\n        const now = new Date();\n        const currentYear = now.getFullYear();\n        const currentMonth = now.getMonth(); // 0 = Jan, 4 = May, 10 = Nov\n        const currentDate = now.getDate();\n\n        let firstMonthLabel, secondMonthLabel;\n\n        if (currentMonth < 4 || (currentMonth === 4 && currentDate <= 20)) {\n          // Before or on mid May\n          firstMonthLabel = `May ${currentYear}`;\n          secondMonthLabel = `November ${currentYear}`;\n        } else if (currentMonth < 10 || (currentMonth === 10 && currentDate <= 20)) {\n          // After mid May and before or on mid November\n          firstMonthLabel = `November ${currentYear}`;\n          secondMonthLabel = `May ${currentYear + 1}`;\n        } else {\n          // After mid November\n          firstMonthLabel = `May ${currentYear + 1}`;\n          secondMonthLabel = `November ${currentYear + 1}`;\n        }\n\n        return [firstMonthLabel, secondMonthLabel];\n      }\n\n      const months = getMayAndNovember();\n\n      if (!datesWrapper) throw new Error('datesWrapper not found!');\n\n      // Clear previous content\n      datesWrapper.replaceChildren();\n\n\n      months.forEach(label => {\n        const el = document.createElement('div');\n        el.className = 'tour-init__date';\n        el.textContent = label;\n\n        el.addEventListener('click', (e) => {\n          params.selected_date = e.currentTarget.textContent;  // store the value\n          updateCTA();\n          markSelected(e.currentTarget);                      // visual feedback\n        });\n\n        datesWrapper.appendChild(el);\n      });\n\n      // Optionally pre-select the first month\n      if (months.length) {\n        params.selected_date = months[0];\n        updateCTA();\n        markSelected(datesWrapper.firstElementChild);\n      }\n\n\n    }\n\n    /* ──────────────────  B. SLIDE UTILS  ────────────────── */\n    function slideOutLeft(el) {\n      /* ensure element is visible before sliding out */\n      el.style.display = el.style.display || 'block';\n      el.classList.add('slide-transition', 'slide-end'); // start at visible\n      requestAnimationFrame(() => {\n        el.classList.replace('slide-end', 'slide-start'); // animate to left\n      });\n      el.addEventListener('transitionend', function h() {\n        el.style.display = 'none'; // hide after anim\n        el.classList.remove('slide-transition', 'slide-start');\n        el.removeEventListener('transitionend', h);\n      });\n    }\n\n    function slideInLeft(el) {\n      el.style.display = el.dataset.origDisplay || 'block'; // show first\n      el.classList.add('slide-transition', 'slide-start'); // start off-screen\n      requestAnimationFrame(() => {\n        el.classList.replace('slide-start', 'slide-end'); // animate in\n      });\n      el.addEventListener('transitionend', function h() {\n        el.classList.remove('slide-transition', 'slide-end');\n        el.removeEventListener('transitionend', h);\n      });\n    }\n    /* ──────────────────  C. BANNER STEP-2 : Show only .subtitle ────────────────── */\n    document.querySelectorAll('#banner-content .contentside .button')\n      .forEach(btn => {\n        btn.addEventListener('click', () => {\n          const side = btn.closest('.contentside');\n          const subtitle = side?.querySelector('.subtitle');\n          if (!side || !subtitle) return;\n          Array.from(side.children).forEach(child => {\n            if (child === subtitle) {\n              slideInLeft(child); // keep / slide in subtitle\n            } else {\n              slideOutLeft(child); // slide out other elems\n            }\n          });\n        });\n      });\n    /* ──────────────────  D. BANNER STEP-3 : Restore all, hide subtitle ────────────────── */\n    document.querySelectorAll('#banner-content .contentside .tour-init__close')\n      .forEach(closeBtn => {\n        closeBtn.addEventListener('click', () => {\n          const banner = closeBtn.closest('.contentside');\n          const subtitle = banner?.querySelector('.subtitle');\n          if (!banner || !subtitle) return;\n          Array.from(banner.children).forEach(child => {\n            if (child === subtitle) {\n              slideOutLeft(child); // hide subtitle\n            } else {\n              slideInLeft(child); // restore others\n            }\n          });\n        });\n      });\n  });\n</script>",
