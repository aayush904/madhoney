      "blocks": {
        "content_j4mjtQ": {
          "type": "content",
          "settings": {
            "title": "Mad Honey Dosage Safety Guidelines",
            "subtitle": "",
            "description": "<p>Important Safety Information: Mad honey contains naturally occurring <a href=\"/pages/grayanotoxin\" target=\"_blank\" title=\"grayanotoxin\"><strong>grayanotoxins</strong></a> that can have significant physiological effects. Always follow these safety guidelines: </p><ul><li> Start with the minimum effective dose - Always begin with 1/2 teaspoon (2.5g) or less, especially if you're a first-time user. <br/></li><li>Wait before taking more - Effects can take 30-45 minutes to fully develop. Never consume additional amounts before this waiting period.<br/></li><li>Avoid combining with alcohol or medications - Mad honey can interact with blood pressure medications, beta-blockers, and certain heart medications.</li><li>Do not use if pregnant or breastfeeding - <a href=\"/pages/mad-honey-effects\" target=\"_blank\" title=\"mad honey effects\"><strong>The side effects of grayanotoxins</strong></a> have not been studied in pregnant or nursing women.</li><li>Keep away from children and pets - Store mad honey securely out of reach of children and animals.</li><li>Know the warning signs - Excessive sweating, dizziness, nausea, or irregular heartbeat may indicate you've consumed too much. Discontinue use and seek medical attention if needed.</li><li>Measure precisely - Use our calculator and proper measuring spoons rather than estimating amounts.</li></ul><p> <br/>Disclaimer: This information is not intended as medical advice. Consult your healthcare provider before using mad honey, especially if you have existing health conditions or take medications.</p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
