          "settings": {
            "table_heading": "Measures"
          }
        },
        "content_b7FBn7": {
          "type": "content",
          "settings": {
            "table_content": "Avoid consuming more than 1 teaspoon of mad honey at a time."
          }
        },
        "content_TfTtjV": {
          "type": "content",
          "settings": {
            "table_content": "Only buy mad honey from trusted, clearly labeled sources. Avoid unregulated or homemade varieties"
          }
        },
        "content_LEE6dP": {
          "type": "content",
          "settings": {
            "table_content": "Ensure containers are labeled as containing grayanotoxin or mad honey."
          }
        },
        "content_RUEdwQ": {
          "type": "content",
          "settings": {
            "table_content": "People with heart conditions, low blood pressure, or on heart medications should avoid mad honey entirely."
          }
        },
        "content_UQTjyw": {
          "type": "content",
          "settings": {
            "table_content": "Keep out of reach of children, elderly, and pregnant women. They are more sensitive to toxicity."
          }
        },
        "content_C7dGcQ": {
          "type": "content",
          "settings": {
            "table_content": "In countries like Turkey and Nepal, where mad honey is traditional, travelers should be educated on safe use."
          }
        },
        "content_Me6gkK": {
          "type": "content",
          "settings": {
            "table_content": "Combining mad honey with CNS depressants, alcohol, or other medications can worsen effects."
          }
        }
      },
