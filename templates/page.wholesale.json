      "type": "basmil-image-text",
      "blocks": {
        "content_6KJqed": {
          "type": "content",
          "settings": {
            "title": "**Please note the following terms for Mad Honey Wholesale purchases**",
            "subtitle": "We look forward to starting the conversation and looking at possibilities for Mad Honey wholesale opportunities with you. Get in touch with one of the team by using the contact form below.",
            "description": "<p>International freight costs are regularly changing, while we can discuss your options with you it is your responsibility to find the solution that best suits you.</p><p>All quotes will be provided in USD dollars.</p><p>International transaction fees including fees for importation and customs clearances are the responsibility of the purchaser. Further to this the purchaser is required to adhere to all local government requirements in regards to FDA approvals and similar.</p><p>Purchasers are not permitted to sell on marketplaces like ebay, Amazon Walmart, Etsy . Neither the wholesale customer or their customers are permitted to sell on marketplace platforms.</p><p>While we will supply all relevant testing documentation we have, where there are further requirements requested for the country wise certification process we will accommodate as best we can but can not guarantee that you will not have to carry out your own tests or certifications to comply with local legislation.<br/><br/></p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        }
      },
