        "content_fpc8fR": {
          "type": "content",
          "settings": {
            "title": "We Provide Nepali Mad Honey Wholesale and Private Label to our Customers",
            "subtitle": "",
            "description": "<p>Medicinal Mad Honey is a community-owned premium Nepali Mad honey producer, offering the highest quality Mad Honey Wholesale at competitive prices.</p><p>We travel across the various sites along the western and far western Nepal then processed and packaged in our factory in Kathmandu, Nepal . We combine generations of honey hunters making expertise and the best scientific practices to preserve our honey, with laboratory testing to certify authenticity, strength and quality. Our premium Bulk  Mad Honey Wholesale is Nepal Government Certified and we are 100% Nepal-made and owned.</p>",
            "button_text": "Distributor Form",
            "button_link": "shopify://pages/mad-honey-partner",
            "button_text_2": "Private Labeling",
            "button_link_2": "shopify://pages/white-labeling-mad-honey"
          }
        },
