        "content_hpxP9b": {
          "type": "content",
          "settings": {
            "title": "The Himalayan Giant Honey Bees (Apis Laboriosa)",
            "subtitle": "",
            "description": "<p>Wondering, which bee makes the Mad Honey?</p><p><strong>The Himalayan Giant Bee</strong>, scientifically known as <strong>Apis Laboriosa</strong> produces Mad Honey.<strong> </strong>This unique bee roughly three times the size of ordinary honey bee prefers the high rugged pristine terrains as nesting site in Nepal.</p><p>This Wild Bee not only draws attention with its largest size but also attracts people with the unique honey it produces at the Himalayan Cliffs at altitudes above 1200 meters. </p>",
            "button_text": "Buy Mad Honey",
            "button_link": "shopify://products/medicinal-mad-honey",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
        "image_hGrAic": {
