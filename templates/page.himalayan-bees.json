    "basmil_image_text_zA9ndT": {
      "type": "basmil-image-text",
      "blocks": {
        "content_KGhqYF": {
          "type": "content",
          "settings": {
            "title": "Sensory Organs of Apis Laboriosa",
            "subtitle": "",
            "description": "<p>Sensory organs are vital parts of the Himalayan Giant Bees. These sensory organs detects natural stimulus and helps Giant Bees to gather information, navigate, forage and communicate with other bees in challenging Himalayan terrain.</p><p></p><ul><li><strong>Antennae:</strong> The antenna is vital in terms of communication and locating food the antenna is equipped with thousands of receptors. It senses pheromones, temperature, humidity, and scents.</li><li><strong>Compound Eyes:</strong> The compound eyes made of thousands of mini-lenses offers a wide range of vision as well as UV patterns on flowers and aiding foraging.</li><li><strong>Simple Eyes (Ocelli):</strong> Three light-sensitive eyes on their heads help stabilize these bees during flight in changing light conditions.</li></ul>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        },
