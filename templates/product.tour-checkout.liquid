<script>
  const popup = document.getElementById('popup');
  const popupClose = document.getElementById('popup-close');
  const openPopup = document.getElementById('open-popup');

  // Open popup
  openPopup.addEventListener('click', () => {
    popup.classList.add('active');
  });

  // Close popup on close button click
  popupClose.addEventListener('click', () => {
    popup.classList.remove('active');
  });

  document.getElementById('reserve-btn').addEventListener('click', function () {
    popup.classList.remove('active');
  });

  // Close popup on outside click
  popup.addEventListener('click', (e) => {
    if (e.target === popup) {
      popup.classList.remove('active');
    }
  });
</script>

<script>
(function () {
  // 1. Grab ?selected_method=...
  const params         = new URLSearchParams(window.location.search);
  const selectedMethod = params.get('selected_method');
  if (!selectedMethod) return;                       // nothing to do

  // 2. Convert to slug (handleize-ish)
  const slug = selectedMethod
    .toString()
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')   // strip accents & symbols
    .replace(/[\s_-]+/g, '-')   // collapse whitespace/underscores to "-"
    .replace(/^-+|-+$/g, '');   // trim leading/trailing "-"

  // 3 & 4. Wait for DOM, find element, click
  const clickIfFound = () => {
    const el = document.querySelector(`.${slug}`);
    if (el) el.click();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', clickIfFound);
  } else {
    clickIfFound();
  }
})();
</script>

