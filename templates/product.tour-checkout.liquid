<style>
  .tourform .font-monster {
    font-family: 'Lato';
  }
  .tourform .font-crimson {
    font-family: 'Crimson Text';
  }
  .tourform .font-lato {
    font-family: 'Lato';
  }

  .tourform h3 {
    margin-bottom: 0 !important;
  }

  .tourform .custom-checkbox {
    position: relative;
    display: inline-block;
    width: 1.25rem;
    height: 1.25rem;
    margin-right: 0.5rem;
    border: 0.125rem solid #be935f;
    background-color: #be935f;
    cursor: pointer;
  }
  .tourform .custom-checkbox input {
    opacity: 0;
    position: absolute;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }
  .tourform .custom-checkbox input:checked + .checkmark {
    opacity: 100%;
  }
  .tourform .checkmark:after {
    content: '';
    position: absolute;
    display: none;
    background-color: #be935f;
  }
  .tourform .custom-checkbox input:checked + .checkmark:after {
    display: block;
  }
  .tourform .custom-checkbox .checkmark:after {
    left: 0.3125rem;
    top: 0.125rem;
    width: 0.3125rem;
    height: 0.625rem;
    border: solid white;
    border-width: 0 0.125rem 0.125rem 0;
    transform: rotate(45deg);
  }

  .tourform .error {
    color: red;
    font-size: 0.75rem;
  }

  input {
    box-shadow: none !important;
  }

  @media (max-width: 998px) {
    .columntab {
      flex-direction: column;
    }
  }
</style>

<div class="page-width  mx-auto py-[12rem] sm:py-[6rem] lg:px-[1rem] md:px-[1rem] sm:px-[1rem]">
  <form id="tourForm" class="relative tourform  flex gap-[10rem] md:gap-[6rem] sm:gap-[4rem] sm:flex-col">
    {% comment %} popup {% endcomment %}
    {% comment %} <input type="text" id="selected-date" > {% endcomment %}

    <!-- Step 1 -->
    <section class="w-[52.56%] sticky sm:relative h-max top-[10rem] md:w-3/5 sm:w-full ">
      <div id="step1" class="step">
        <div class="flex flex-col items-center xl:items-start ">
          <div class="flex flex-col items-start mb-8 w-full">
            <p class="font-serif text-3xl font-semibold text-[#0000004D]">Step 1</p>
            <h2 class=" text-black">Begin Booking</h2>
            <p class="base font-serif">In this step you can change the tour date if you change your mind.</p>
          </div>
          <div class="flex flex-col gap-[1.6rem] w-full">
            <div>
              <input
                type="text"
                name="fName"
                class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                placeholder="First Name"
                required
              >
            </div>
            <div>
              <input
                type="text"
                name="lName"
                class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                placeholder="Last Name"
                required
              >
            </div>
            <div>
              <input
                type="email"
                name="email"
                class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                placeholder="Email Address"
                required
              >
            </div>
            <div>
              <input
                type="tel"
                name="phoneNo"
                class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                placeholder="Phone Number"
                required
              >
            </div>

            <h3 class="base font-medium mt-4">Birthdate</h3>
            <div class="flex gap-[1.6rem]">
              <div>
                <input
                  type="text"
                  name="mm"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="MM"
                  required
                >
              </div>
              <div>
                <input
                  type="text"
                  name="dd"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="DD"
                  required
                >
              </div>
              <div>
                <input
                  type="text"
                  name="yy"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="YY"
                  required
                >
              </div>
            </div>

            <button type="button" class="nextBtn mt-4 button w-full">Next</button>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div id="step2" class="step hidden">
        <div class="flex flex-col xl:flex-row xl:items-start items-center gap-8 w-full">
          <div class="flex flex-col items-center xl:items-start w-full">
            <div class="flex flex-col items-start mb-8 w-full">
              <p class="font-serif text-3xl font-semibold text-[#0000004D]">Step 2</p>
              <h2 class=" text-black">Traveler Details</h2>
              <p class="base font-serif">Please provide information for the primary contact and traveler.</p>
            </div>
            <div class="flex flex-col gap-[1.6rem] w-full" id="travelerDetailsContainer">
              <h3 class="base font-medium mt-4">Traveler's Address</h3>
              <div>
                <input
                  type="text"
                  name="country"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Country"
                  required
                >
              </div>
              <div>
                <input
                  type="text"
                  name="address"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Street Address"
                  required
                >
              </div>
              <div>
                <input
                  type="text"
                  name="address2"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Address 2 (Optional)"
                >
              </div>
              <div class="flex gap-[1.6rem]">
                <div>
                  <input
                    type="text"
                    name="city"
                    class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                    placeholder="City"
                    required
                  >
                </div>
                <div>
                  <input
                    type="text"
                    name="state"
                    class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                    placeholder="State"
                    required
                  >
                </div>
              </div>
              <div>
                <input
                  type="text"
                  name="zipcode"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Zip Code"
                  required
                >
              </div>
            </div>

            <button
              type="button"
              id="addTravelerBtn"
              class="mt-[1.6rem] base font-sans"
              style="color: #1E78C3;"
            >
              + Wanna add your buddy?
            </button>

            <div class="flex gap-[1.6rem] mt-6 w-full">
              <button
                type="button"
                class="prevBtn font-sans w-full border border-tertiary bg-transparent hover:bg-[#000] hover:border-[#000] text-tertiary "
              >
                Back
              </button>
              <button type="button" class="nextBtn button w-full">Next</button>
            </div>
          </div>
        </div>
      </div>

      <script>
        const priceUpdater = (travelerCount) => {
          const ids = ['variant-price-counter', 'variant-remaining-price', 'variant-total-price'];
          ids.forEach((id) => {
            const variantPriceCounter = document.getElementById(id);
            const priceString = variantPriceCounter.getAttribute('data-price');
            // Remove dollar sign and commas, then convert to a number
            const price = parseFloat(priceString.replace(/[^0-9.]/g, ''));
            // Calculate the total price
            const totalPrice = price * travelerCount;
            // Update the text content with the formatted price
            variantPriceCounter.textContent = `$${totalPrice.toLocaleString()}`;
          });
        };

        const updateTravelerNumbers = () => {
          const travelerSections = document.querySelectorAll('#travelerDetailsContainer .traveler-section');
          travelerSections.forEach((section, index) => {
            const travelerNumber = index; // Array index starts at 0
            section.querySelector('h3').innerHTML = `
              Traveler ${travelerNumber + 2} Details
              <button type="button" class="remove-traveler-btn text-red-500 font-bold text-[2rem]" aria-label="Remove Traveler">&times;</button>
            `;

            // Update input names dynamically
            section.querySelectorAll('input').forEach((input) => {
              const originalName = input.getAttribute('data-original-name');
              input.setAttribute('name', `travelers[${travelerNumber}].${originalName}`);
            });

            // Rebind the remove button event
            section.querySelector('.remove-traveler-btn').addEventListener('click', function () {
              section.remove();
              updateTravelerNumbers(); // Recalculate numbers after removal
            });
          });

          // Update the displayed traveler count
          document.getElementById('traveller-count').textContent = travelerSections.length + 1;
          priceUpdater(travelerSections.length + 1);
        };

        document.getElementById('addTravelerBtn').addEventListener('click', function () {
          const container = document.getElementById('travelerDetailsContainer');
          const travelerCount = document.querySelectorAll('#travelerDetailsContainer .traveler-section').length;

          const travelerSection = document.createElement('div');
          travelerSection.classList.add(
            'traveler-section',
            'mt-8',
            'relative',
            'flex',
            'flex-col',
            'gap-[1.6rem]',
            'w-full'
          );

          travelerSection.innerHTML = `
            <h3 class="base font-medium mt-4 flex items-center justify-between">
              Traveler ${travelerCount + 1} Details
              <button type="button" class="remove-traveler-btn text-red-500 font-bold text-[2rem]" aria-label="Remove Traveler">&times;</button>
            </h3>
            <div>
              <input type="text" data-original-name="first_name" name="travelers[${travelerCount}].first_name" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="First Name" required>
            </div>
            <div>
              <input type="text" data-original-name="last_name" name="travelers[${travelerCount}].last_name" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Last Name" required>
            </div>
            <div>
              <input type="email" data-original-name="email" name="travelers[${travelerCount}].email" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Email Address" required>
            </div>
            <div>
              <input type="tel" data-original-name="phone_no" name="travelers[${travelerCount}].phone_no" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Phone Number" required>
            </div>

            <h3 class="base font-medium mt-4">Birthdate</h3>
            <div class="flex gap-[1.6rem]">
              <div>
                <input type="text" data-original-name="birthdate.mm" name="travelers[${travelerCount}].birthdate.mm" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="MM" required>
              </div>
              <div>
                <input type="text" data-original-name="birthdate.dd" name="travelers[${travelerCount}].birthdate.dd" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="DD" required>
              </div>
              <div>
                <input type="text" data-original-name="birthdate.yy" name="travelers[${travelerCount}].birthdate.yy" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="YY" required>
              </div>
            </div>

            <h3 class="base font-medium mt-4">Traveler's Address</h3>
            <div>
              <input type="text" data-original-name="address.country" name="travelers[${travelerCount}].address.country" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Country" required>
            </div>
            <div>
              <input type="text" data-original-name="address.street" name="travelers[${travelerCount}].address.street" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Street Address" required>
            </div>
            <div>
              <input type="text" data-original-name="address.street2" name="travelers[${travelerCount}].address.street2" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Address 2 (Optional)">
            </div>
            <div class="flex gap-[1.6rem]">
              <div>
                <input type="text" data-original-name="address.city" name="travelers[${travelerCount}].address.city" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="City" required>
              </div>
              <div>
                <input type="text" data-original-name="address.state" name="travelers[${travelerCount}].address.state" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="State" required>
              </div>
            </div>
            <div>
              <input type="text" data-original-name="address.zipcode" name="travelers[${travelerCount}].address.zipcode" class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none" placeholder="Zip Code" required>
            </div>
            `;

          container.appendChild(travelerSection);

          travelerSection.querySelector('.remove-traveler-btn').addEventListener('click', function () {
            travelerSection.remove();
            updateTravelerNumbers();
          });

          updateTravelerNumbers();
        });
      </script>

      <!-- Step 3 -->
      <div id="step3" class="step hidden">
        <div class="flex flex-col xl:flex-row xl:items-start items-center gap-8 w-full">
          <div class="flex flex-col items-center xl:items-start w-full">
            <div class="flex flex-col items-start mb-8 w-full">
              <p class="font-serif text-3xl font-semibold text-[#0000004D]">Step 3</p>
              <h2 class=" text-black">Accommodations</h2>
              <p class="base font-serif">Choose a rooming option for all travelers</p>
            </div>
            <div class="flex flex-col gap-[1.6rem] w-full">
              <h3 class="base font-medium">Share a room</h3>
              <p class="blog-text text-[#00000099] mb-0">Choose a rooming option for all travelers</p>
              <div>
                <input
                  type="text"
                  name="roommate"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Roommate"
                >
              </div>

              <h3 class="base font-medium">Beds</h3>
              <div class="flex gap-[1.6rem] mb-4">
                <label>
                  <input type="radio" name="bed" value="single" checked required>
                  Single
                </label>
                <label>
                  <input type="radio" name="bed" value="double" required>
                  Double
                </label>
              </div>

              <h3 class="base font-medium">Emergency Contact</h3>

              <div>
                <input
                  type="text"
                  name="firstName"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="First Name"
                  required
                >
              </div>
              <div>
                <input
                  type="text"
                  name="lastName"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Last Name"
                  required
                >
              </div>
              <div>
                <input
                  type="email"
                  name="emailAddress"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Email Address"
                  required
                >
              </div>
              <div>
                <input
                  type="tel"
                  name="phoneNumber"
                  class="w-full border border-[#D9D9D9] bg-transparent blog-text font-sans p-[1.125rem_1rem] outline-none"
                  placeholder="Phone Number"
                  required
                >
              </div>

              <p class="blog-text text-[#00000099] mt-4">Next, select your payment options</p>
              <div class="flex gap-[1.6rem] mt-6">
                <button
                  type="button"
                  class="prevBtn font-sans w-full border border-tertiary bg-transparent hover:bg-[#000] hover:border-[#000] text-tertiary"
                >
                  Back
                </button>
                <button type="submit" class="button w-full">Submit</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {% capture first_summary %}
    <div id="first_summary" class="w-full border border-black rounded-[1rem] p-[2.4rem]">
      <div class="columntab flex gap-[2.4rem] md:flex-col sm:flex-row ">

        <div class="w-full flex flex-col justify-start flex-grow gap-[1.6rem]">
            <div class="base imagetext mb-[0!important] flex gap-[2.4rem] sm:flex-col relative">
                <img src="{{ product.featured_image | image_url }}" alt="{{ product.featured_image.alt | default:'product.title' }}" class="bg-[#D9D9D9] overflow-hidden max-w-[27%] sm:max-w-[27%!important]  w-full h-auto aspect-square object-cover" width="500" height="500" />
              <div class="flex flex-col gap-[1.6rem] max-w-[55.7%] sm:max-w-full w-full width-full">
                Explore the World of Mad Honey Harvesting & Honey Hunters.
              <div class="flex justify-between items-center">
                <p class="blog-text text-[#00000099] -mb-[0.8rem]">Selected Date</p>
                <p id="open-popup" class="blog-text text-[#00000099] -mb-[0.8rem] cursor-pointer" onclick="displayDate()">Change Date</p>
                </div>
              <div
                class="flex justify-between items-center mt-[-0.8rem]"
              >
                <p class="sans-base" id="display_date">Nov 5-10, 2023</p>
              </div>
            </div>
            </div>


            <style>

              @media screen and (max-width: 1024px) {
                .imagetext {
                  flex-direction: column;
                }                
              }

              @media screen and (max-width: 1200px) {
                .width-full {
                  max-width: 100%;
                }                
              }

              .variant-pill {
                display: inline-block;
                padding: 12px;
                margin: 5px;
                color:#000;
                border: 1px solid #000;
                cursor: pointer;
                transition: all 0.3s ease;
              }          
            
              .variant-pill.active {
                background-color: #000000;
                color: #fff;
                border-color: #000;
              }
            
            </style>
            <div class="flex flex-col gap-[8px]">
              <p class="blog-text text-[#00000099] -mb-[0.8rem]">Select Payment Type</p>

              <div id="variant-selector">
                {% for variant in product.variants %}
                    {% assign deposit_price =  product.variants[0].price | divided_by: 100 %}
                    {% assign full_price = product.variants[1].price | divided_by: 100 %}

                  {% assign remaning_amount = full_price | minus: deposit_price | times: 100 | money_without_trailing_zeros  %}
                  <span 
                    class="variant-pill min-w-[40%] text-center {{ variant.title | handleize }} text-[1.4rem] {% if forloop.index0 ==0 %} active {% endif %}" 
                    data-price="{{ variant.price | money_without_trailing_zeros}}" 
                    data-remaning-price="{% if forloop.index0 ==0 %} {{ remaning_amount}} {%else %} 0 {% endif %}" 
                    data-variant-id="{{ variant.id }}"
                    onclick="selectVariant(this)">
                    {{ variant.title }}
                  </span>
                {% endfor %}
              </div>
            </div>

            <hr class="bg-black h-[.0625rem]"/>
          <p class="sans-base -mt-[0.6rem]">Price: <span class="variant-price">{{ product.variants[0].price | money_without_trailing_zeros }}</span> Per Person <span id="remaning-variant-price">(Remaining: {{ remaning_amount }})</span></p>
        </div>
      </div>
      <div class="w-full mt-6">
        <p class="base font-medium mb-2">Note:</p>
        <p class="sans-base">
          The price shown is only for 1 person. If you have a group, you'll need to enter details for each person in the
          next step.
        </p>
      </div>
    </div>
    {% endcapture %}
    <section
      id="tourSummary"
      class="flex bg-[#ffffff] sm:mt-[6rem!important] sm:mb-[8rem!important] max-h-max flex-col items-center xl:items-start xl:mt-0 w-1/2 md:w-2/5 sm:w-full font-sans mt-[9rem] sticky sm:relative top-[10rem]"
    >
      {% capture other_summary %}
        <div id="other_summary" class="w-full border border-black rounded-lg p-6 opacity-0 absolute z-[-1] ">
          <h3 class="base font-medium mb-4">Tour Summary</h3>
          <p class="base mb-2">Explore the World of Mad Honey Harvesting & Honey Hunters</p>
          <p class="blog-text text-[#00000099] mb-1">Selected Date</p>
          <div class="flex justify-between items-center border-b border-black pb-4 mb-4">
            <p class="blog-text display_date">Nov 5-10, 2023</p>
          </div>
          <div class="space-y-2">
            
            <p class="blog-text text-[#00000099] mb-1">Per Traveler</p>
            <div class="flex justify-between">
              <span class="blog-text">Price</span>
              <span class="font-semibold blog-text"><price class="variant-price">{{ product.variants[0].price | money_without_trailing_zeros }}</price> </span>
            </div>
            <div class="flex justify-between border-b border-black border-dashed ">
              <span class="blog-text">Total</span>
              <span class="font-semibold blog-text">{{ product.variants[1].price | money_without_trailing_zeros }} </span>
            </div>
            <p class="blog-text text-[#00000099] my-1">Total Calculation for <b>x<count id="traveller-count">1</count></b> Traveler</p>
            <div class="flex justify-between pt-2">
              <span class="blog-text">Trip deposit </span>
              <span class="font-medium blog-text" id="variant-price-counter" data-price="{{ product.variants[0].price | money_without_trailing_zeros }}">{{ product.variants[0].price | money_without_trailing_zeros }}</span>
            </div>
            <div class="flex justify-between font-medium blog-text">
              <span class="blog-text">Total Amount</span>
              <span id="variant-total-price" class="font-medium blog-text" data-price="{{ product.variants[1].price | money_without_trailing_zeros }}">{{ product.variants[1].price | money_without_trailing_zeros }} </span>
            </div>
            <div class="flex justify-between font-medium blog-text">
              <span class="blog-text">Remaining Amount</span>
              <span id="variant-remaining-price" class=" font-semibold blog-text" data-price="{{ remaning_amount }}">{{ remaning_amount }}</span>
            </div>
          </div>
        </div>
      {% endcapture %}
      {{ first_summary }}
      {{ other_summary }}
    </section>
  </form>
</div>

<script>

  function validateForm(selector) {
    // Select all input fields based on the provided selector
    const inputs = document.querySelectorAll(selector);
    let isValid = true; // Tracks overall form validation status
  
    // Function to display error message
    function showErrorMessage(input, message) {
      // Check if an error message already exists, and remove it
      const existingError = input.parentNode.querySelector('.error-msg');
      if (existingError) {
        existingError.remove();
      }
  
      // Create error message element
      const errorMsg = document.createElement('div');
      errorMsg.setAttribute('class','error-msg text-sm text-red-500');
      errorMsg.textContent = message;
      
      // Insert error message below the input field
      input.parentNode.insertBefore(errorMsg, input.nextSibling);
    }
  
    // Function to remove error message
    function clearErrorMessage(input) {
      const existingError = input.parentNode.querySelector('.error-msg');
      if (existingError) {
        existingError.remove();
      }
    }
  
    // Regular expressions for email, phone, and zip validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const phoneRegex = /^\d{10}$/; // Matches a 10-digit phone number
    const zipRegex = /^\d{5}(?:-\d{4})?$/; // Matches US zip codes (5 digits or ZIP+4)
  
    // Iterate through each input
    inputs.forEach((input) => {
      const inputType = input.getAttribute('type');
      const isRequired = input.hasAttribute('required');
      const inputValue = input.value.trim();
  
      clearErrorMessage(input); // Clear any previous error messages
  
      // Check for required fields
      if (isRequired && !inputValue) {
        showErrorMessage(input, 'Required Field');
        isValid = false;
        return;
      }
  
      // Perform specific validations based on input type
      if (inputType === 'email' && inputValue) {
        if (!emailRegex.test(inputValue)) {
          showErrorMessage(input, 'Please enter a valid email address');
          isValid = false;
        }
      } else if (inputType === 'tel' && inputValue) { // Phone number validation
        if (!phoneRegex.test(inputValue)) {
          showErrorMessage(input, 'Please enter a valid phone number (10 digits)');
          isValid = false;
        }
      } else if (inputType === 'text' && inputValue) { // Zip code validation for text inputs
        if (input.name.includes('zipcode' ) && !zipRegex.test(inputValue)) {
          showErrorMessage(input, 'Please enter a valid zip code');
          isValid = false;
        }
      }
    });
  
    return isValid; // Return overall validation status
  }


