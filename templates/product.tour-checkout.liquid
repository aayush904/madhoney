  document.addEventListener('DOMContentLoaded', () => {
    const steps = Array.from(document.querySelectorAll('.step'));
    const nextBtns = document.querySelectorAll('.nextBtn');
    const prevBtns = document.querySelectorAll('.prevBtn');
    let currentStep = 0;

    // Helper: Show only the current step
    const showStep = (stepIndex) => {
      steps.forEach((step, index) => {
        step.classList.toggle('block', index === stepIndex);
        step.classList.toggle('hidden', index !== stepIndex);

        // Update innerHTML for the current step if applicable
        if (index === stepIndex) {
          const tourSummary = document.querySelector('#tourSummary');
          if (stepIndex === 0) {
            document.getElementById('other_summary').style.opacity = '0';
            document.getElementById('other_summary').style.position = 'absolute';
            document.getElementById('other_summary').style.zIndex = '-1';
            document.getElementById('first_summary').style.opacity = '1';
            document.getElementById('first_summary').style.position = 'relative';
            document.getElementById('first_summary').style.zIndex = '1';
          } else {
            document.getElementById('other_summary').style.opacity = '1';
            document.getElementById('other_summary').style.position = 'relative';
            document.getElementById('other_summary').style.zIndex = '1';
            document.getElementById('first_summary').style.opacity = '0';
            document.getElementById('first_summary').style.position = 'absolute';
            document.getElementById('first_summary').style.zIndex = '-1';
          }
        }
      });
    };

    // Handle Next Button
    nextBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if ((currentStep < steps.length - 1) && validateForm(`#step${currentStep+1} input`)) {          
          currentStep++;
          showStep(currentStep);
        }
      });
    });

    // Handle Previous Button
    prevBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (currentStep > 0) {
          currentStep--;
          showStep(currentStep);
        }
      });
    });

    // Initialize first step
    showStep(currentStep);
  });





