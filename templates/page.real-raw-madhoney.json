    "basmil_image_richtext_AHrVyX": {
      "type": "basmil-image-richtext",
      "blocks": {
        "content_BAihA9": {
          "type": "content",
          "settings": {
            "description": "<h3>Various Flowers </h3><p>Collected from different nectars of flowers, the higher amount comes from flowers like clover, acacia, alfalfa, and lavender.</p><h3>Traditional Beekeeping </h3><p>Regular honey is collected from traditional beekeeping, where bees break down nectar sugars and evaporate water within the hive to create thick honey.</p><h3>Sweetness and Wellness</h3><p>Regular honey has no psychoactive effects and is typically used as a sweetener or for general health benefits.</p>"
          }
        },
        "image_fpyiKV": {
          "type": "image",
          "settings": {
            "image_type": "image",
            "image": "shopify://shop_images/madhoneyjar.webp",
            "image_alt": "Mad Honey",
            "svg": "",
            "image_width": "89.38%; grid-column:2/3;"
          }
        },
        "content_rVa8h9": {
          "type": "content",
          "settings": {
            "description": "<h3>High Glycemic Index</h3><p>Regular honey has a higher glycemic index and can cause a more noticeable spike in blood sugar levels.</p><h3>Simple Packaging</h3><p>Regular honey comes in a plain glass jar with a simple label, focusing on ease and affordability.</p><h3>Gentle and Smooth</h3><p>Sweet, smooth, and has a milder, more familiar taste, providing a gentle, classic sweetness.</p>"
          }
        }
      },
