        "content_kifLpD": {
          "type": "content",
          "settings": {
            "title": "JOURNEY FROM HIMALAYAN HIVES TO JARS",
            "subtitle": "",
            "description": "<p>Our <a href=\"/pages/hive-to-jar\" target=\"_blank\" title=\"honey jar\">honey jar</a> packaging is designed with sustainability in mind, ensuring your mad honey is both protected and authentic. Each jar reflects the genuine essence of Nepal's pristine landscape, resulting from the harmonious relationship between honeybees and humans. We've crafted these jars with distinctive features that are hard to replicate, guaranteeing you receive the true Mad Honey experience—straight from the cliffs to your hands.</p>",
            "button_text": "",
