        "content_hT8PEf": {
          "type": "content",
          "settings": {
            "title": "The Mad Honey Legacy",
            "subtitle": "",
            "description": "<p>Mad Honey has been harvested for centuries through techniques passed down from generation to generation. This ancient wisdom has survived the hunter-gatherer age to modern times. </p><p>Our mad honey embodies the spirits of untold <a href=\"/pages/honey-hunter\" target=\"_blank\" title=\"honey hunter\">honey hunters of Nepal</a>, and our brave ancestor who started this tradition and celebrates it every year. </p><p>A story from a small village in western, nepal to the global tale of the finest honey in the world!</p>",
            "button_text": "",
            "button_link": "",
            "button_text_2": "",
            "button_link_2": ""
          }
        }
      },
