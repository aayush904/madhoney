  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const steps = Array.from(document.querySelectorAll(".step"));
      const nextBtns = document.querySelectorAll(".nextBtn");
      const prevBtns = document.querySelectorAll(".prevBtn");
      const form = document.getElementById("tour_form");
      let currentStep = 0;

      // Helper: Show only the current step
      const showStep = (stepIndex) => {
        steps.forEach((step, index) => {
          step.style.display = index === stepIndex ? "block" : "none";
        });
      };

      // Helper: Display error messages
      const displayError = (input, message) => {
        const errorElement = input.parentElement.querySelector(".error");
        if (message) {
          if (!errorElement) {
            const span = document.createElement("span");
            span.classList.add("error", "text-red-500", "text-sm");
            span.textContent = message;
            input.parentElement.appendChild(span);
          }
        } else {
          errorElement?.remove();
        }
      };

      // Helper: Validate input fields
      const validateInputs = (inputs) => {
        let isValid = true;
        inputs.forEach((input) => {
          const value = input.value.trim();
          const name = input.name;
          let errorMessage = "";

          // Validation logic
          if (!value) {
            //111111111111111111111111111
            if (name === "fName") errorMessage = "First Name is required";
            if (name === "lName") errorMessage = "Last Name is required";
            if (name === "email") errorMessage = "Email is required";
            if (name === "phoneNo") errorMessage = "Phone Number is required";
            //222222222222222222222222222
            if (name === "firstName") errorMessage = "First Name is required";
            if (name === "lastName") errorMessage = "Last Name is required";
            if (name === "emailAddress") errorMessage = "Email is required";
            if (name === "phoneNumber")
              errorMessage = "Phone Number is required";
            if (name === "mm") errorMessage = "Month is required";
            if (name === "dd") errorMessage = "Date is required";
            if (name === "yy") errorMessage = "Year is required";
            if (name === "US") errorMessage = "US Location is required";
            if (name === "address") errorMessage = "Address is required";
            if (name === "city1") errorMessage = "City is required";
            if (name === "states1") errorMessage = "State is required";
            if (name === "zipcode") errorMessage = "Zip Code is required";
            if (name === "roommate") errorMessage = "Roommate is required";
            if (name === "city2") errorMessage = "City is required";
            if (name === "states2") errorMessage = "States is required";
            if (name === "cardName") errorMessage = "Name in Card is required";
            if (name === "cardNumber") errorMessage = "Card Number is required";
            if (name === "sCode") errorMessage = "Security Code is required";
            if (name === "expDate") errorMessage = "Expire Date is required";
          }

          displayError(input, errorMessage);

          if (errorMessage) isValid = false;
        });
        return isValid;
      };

      // Handle Next Button
      nextBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const parentStep = btn.closest(".step");
          const inputs = parentStep.querySelectorAll("input");

          // Validate current step inputs
          if (validateInputs(inputs)) {
            if (currentStep < steps.length - 1) {
              currentStep++;
              showStep(currentStep);
            }
          }
        });
      });

      // Handle Previous Button
      prevBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          if (currentStep > 0) {
            currentStep--;
            showStep(currentStep);
          }
        });
      });

      // Handle Form Submission
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const inputs = form.querySelectorAll("input");

        if (validateInputs(inputs)) {
          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());
          console.log("Form submitted successfully:", data);
          alert("Form submitted successfully!");
          form.reset();
          currentStep = 0;
          showStep(currentStep);
        }
      });

      // Initialize first step
      showStep(currentStep);
    });
  </script>
