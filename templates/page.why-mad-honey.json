    "basmil_image_text_aftWMC": {
      "type": "basmil-image-text",
      "blocks": {
        "content_kHXDFc": {
          "type": "content",
          "settings": {
            "title": "<subtitle>Our Best Seller</subtitle>\nAuthentic Mad Honey from Nepal | Try Pack\n<weight>Size: 250g | 8.8 oz. </weight>\n<p class=\"font-normal\">Premium Mad Honey is a rare and natural honey harvested from the mountainous regions of Nepal and Turkey, derived from Rhododendron flowers. It is traditionally recognized for its distinctive botanical composition and naturally occurring grayanotoxins.\n</p>\n<img style=\"margin-top:20px;\" src=\"https://cdn.shopify.com/s/files/1/0663/9966/6326/files/mmhfeatures.svg?v=1742296392\" alt=\"mad honey from nepal try pack Features\" width=\"\" height=\"\">",
            "subtitle": "",
